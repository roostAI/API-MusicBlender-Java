    @Test
    @Tag("valid")
    public void testValidMusicIdIncrementsCommentCountAndLogsAction() {
        int musicId = 1;
        int startingComments = 5;
        MusicModel mockMusic = mock(MusicModel.class);
        when(musicRepo.findById(musicId)).thenReturn(mockMusic);
        when(mockMusic.getNumberOfComents()).thenReturn(startingComments);
        // Fix: LogModel.getTimeNow() is not static, must mock Date.getTimeNow(). See business logic usage.
        when(Date.getTimeNow()).thenReturn("2024-06-01T12:00:00");
        String result = controller.CommentMusicById(musicId);
        verify(mockMusic).setNumberOfComents(startingComments + 1);
        verify(musicRepo).save(mockMusic);
        ArgumentCaptor<LogModel> logCaptor = ArgumentCaptor.forClass(LogModel.class);
        verify(Log).save(logCaptor.capture());
        LogModel logged = logCaptor.getValue();
        assertEquals((String) "app/comment/{id}", (String) logged.getEndpoint());
        assertEquals((String) "App", (String) logged.getUser());
        assertEquals((String) "2024-06-01T12:00:00", (String) logged.getTime());
        assertEquals((String) "Música Alterada!", (String) result);
    }
