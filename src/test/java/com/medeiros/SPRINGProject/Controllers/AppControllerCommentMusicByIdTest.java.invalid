@ExtendWith(MockitoExtension.class)
class AppControllerCommentMusicByIdTest {
    @Mock
    private MusicRepository musicRepo;
    @Mock
    private LogRepository Log;
    @InjectMocks
    private AppController appController;
    private MusicModel testMusic;
    private LogModel testLog;
    
    @BeforeEach
    void setUp() {
        testMusic = new MusicModel();
        testMusic.setId(1);
        testMusic.setNumberOfComents(5);
        
        testLog = new LogModel("app/comment/{id}", "App", LocalDateTime.now());
    }
    
    @Test
    @Tag("valid")
    void successfulCommentIncrement() {
        // Arrange
        when(musicRepo.findById(1)).thenReturn(testMusic);
        
        // Act
        String result = appController.CommentMusicById(1);
        
        // Assert
        assertEquals("Música Alterada!", result);
        assertEquals(6, testMusic.getNumberOfComents());
        verify(musicRepo).save(testMusic);
        verify(Log).save(any(LogModel.class));
    }
    
    @Test
    @Tag("invalid") 
    void whenMusicNotFound() {
        // Arrange
        when(musicRepo.findById(999)).thenReturn(null);
        
        // Act & Assert
        assertThrows(NullPointerException.class, () -> {
            appController.CommentMusicById(999);
        });
        verify(musicRepo, never()).save(any(MusicModel.class));
    }
    
    @Test
    @Tag("boundary")
    void whenCommentCountIsMaxValue() {
        // Arrange
        testMusic.setNumberOfComents(Integer.MAX_VALUE);
        when(musicRepo.findById(1)).thenReturn(testMusic);
        
        // Act & Assert
        assertThrows(ArithmeticException.class, () -> {
            appController.CommentMusicById(1);
        });
    }
    
    @Test
    @Tag("integration")
    void verifyLogCreation() {
        // Arrange
        when(musicRepo.findById(1)).thenReturn(testMusic);
        
        // Act
        appController.CommentMusicById(1);
        
        // Assert
        verify(Log).save(argThat(log -> {
            // Assuming LogModel has getters for these fields
            try {
                return log.getPath().equals("app/comment/{id}") &&
                       log.getSource().equals("App");
            } catch (Exception e) {
                return false;
            }
        }));
    }
}