        musicModel.setNumberOfComents(5);
        when(musicRepo.findById(1)).thenReturn(musicModel);
        
        try (MockedStatic<Date> dateMock = mockStatic(Date.class)) {
            dateMock.when(Date::getTimeNow).thenReturn("2023-12-01 10:00:00");
            
            // Act
            String result = appController.CommentMusicById(1);
            
            // Assert
            assertEquals("Música Alterada!", result);
            assertEquals(6, musicModel.getNumberOfComents());
            verify(musicRepo, times(1)).save(musicModel);
            verify(Log, times(1)).save(any(LogModel.class));
        }
    }
