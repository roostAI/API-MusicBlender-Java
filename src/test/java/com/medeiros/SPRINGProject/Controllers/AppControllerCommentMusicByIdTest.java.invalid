package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.*;
import org.junit.jupiter.api.*;
import org.mockito.*;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import java.util.Optional;
import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.*;
import com.medeiros.SPRINGProject.algorithm.algorithmBlender;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Map;

@SpringBootTest
public class AppControllerCommentMusicByIdTest {
    @MockBean
    private MusicRepository musicRepo;
    @MockBean
    private LogRepository logRepo;
    @InjectMocks
    private AppController appController;
    @Test
    @Tag("valid")
    public void testCommentIncrementOnValidMusicId() {
        MusicModel music = new MusicModel();
        music.setNumberOfComents(5);
        when(musicRepo.findById(1)).thenReturn(Optional.of(music));
        appController.CommentMusicById(1);
        assertEquals(6, music.getNumberOfComents());
    }
    @Test
    @Tag("valid")
    public void testLoggingOnCommentIncrement() {
        MusicModel music = new MusicModel();
        music.setNumberOfComents(5);
        when(musicRepo.findById(1)).thenReturn(Optional.of(music));
        LogModel log = new LogModel();
        when(logRepo.save(any(LogModel.class))).thenAnswer(i -> i.getArguments()[0]);
        appController.CommentMusicById(1);
        assertEquals("app/comment/{id}", log.getAction());
        assertEquals("App", log.getSource());
        assertNotNull(log.getDate());
    }
    @Test
    @Tag("invalid")
    public void testCommentIncrementOnInvalidMusicId() {
        when(musicRepo.findById(1)).thenReturn(Optional.empty());
        Exception exception = assertThrows(RuntimeException.class, () -> {
            appController.CommentMusicById(1);
        });
        String expectedMessage = "Invalid music ID";
        String actualMessage = exception.getMessage();
        assertTrue(actualMessage.contains(expectedMessage));
    }
}