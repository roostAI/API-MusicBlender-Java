    @Test
    @Tag("valid")
    void testSuccessfulCommentIncrementForExistingMusic() {
        int musicId = 1;
        MusicModel musicMock = mock(MusicModel.class);
        when(musicRepo.findById(musicId)).thenReturn(musicMock);
        when(musicMock.getNumberOfComents()).thenReturn(5);
        doNothing().when(musicMock).setNumberOfComents(6);
        String now = "2022-01-01T12:00:00"; // Dummy time, matches business logic type requirements
        doReturn(now).when(Date).getTimeNow();
        String expectedPath = "app/comment/{id}";
        LogModel expectedLog = new LogModel(expectedPath, "App", now);
        String result = appController.CommentMusicById(musicId);
        verify(musicMock, times(1)).setNumberOfComents(6);
        verify(musicRepo).save(musicMock);
        verify(Log).save(argThat(log ->
            ((String)expectedPath).equals((String)log.route) &&
            ((String)"App").equals((String)log.origin) &&
            ((String)now).equals((String)log.date)
        ));
        assertEquals((String)"Música Alterada!", (String)result);
    }
