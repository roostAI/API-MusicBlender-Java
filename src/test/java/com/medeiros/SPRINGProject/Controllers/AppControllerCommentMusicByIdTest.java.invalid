package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.MusicModel;
import com.medeiros.SPRINGProject.Models.LogModel;
import com.medeiros.SPRINGProject.algorithm.algorithmBlender;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import java.util.Map;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.*;

public class AppControllerCommentMusicByIdTest {
    @Mock
    private MusicRepository musicRepo;
    @Mock
    private LogRepository logRepo;
    @InjectMocks
    private AppController appController;
    @BeforeEach
    public void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void incrementCommentCountForExistingMusic() {
        MusicModel music = new MusicModel();
        music.setNumberOfComents(5);
        when(musicRepo.findById(1)).thenReturn(music);
        String result = appController.CommentMusicById(1);
        assertEquals("Música Alterada!", result);
        assertEquals(6, music.getNumberOfComents());
        verify(musicRepo).save(music);
        verify(logRepo).save(any(LogModel.class));
    }
    @Test
    @Tag("invalid")
    public void handleNonExistentMusicId() {
        when(musicRepo.findById(999)).thenReturn(null);
        String result = appController.CommentMusicById(999);
        assertNull(result);
        verify(musicRepo, never()).save(any(MusicModel.class));
        verify(logRepo, never()).save(any(LogModel.class));
    }
    @Test
    @Tag("integration")
    public void verifyLogEntryCreation() {
        MusicModel music = new MusicModel();
        music.setNumberOfComents(3);
        when(musicRepo.findById(2)).thenReturn(music);
        appController.CommentMusicById(2);
        verify(logRepo).save(argThat(log -> 
            log.getPath().equals("app/comment/{id}") &&
            log.getApplicationName().equals("App") &&
            log.getTimestamp() != null
        ));
    }
    @Test
    @Tag("boundary")
    public void incrementCommentCountWithMaxIntegerValue() {
        MusicModel music = new MusicModel();
        music.setNumberOfComents(Integer.MAX_VALUE);
        when(musicRepo.findById(3)).thenReturn(music);
        Exception exception = assertThrows(Exception.class, () -> {
            appController.CommentMusicById(3);
        });
        assertNotNull(exception);
        verify(musicRepo, never()).save(any(MusicModel.class));
    }
}