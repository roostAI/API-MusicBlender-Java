        inOrder.verify(music).setNumberOfComents(10 + 1);
        inOrder.verify(music).setNumberOfComents(11 + 1);
        inOrder.verify(music).setNumberOfComents(12 + 1);
        verify(musicRepo, times(3)).save(music);
        verify(Log, times(3)).save(any(LogModel.class));
    }
