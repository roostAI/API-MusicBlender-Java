        String now = "2024-01-01T01:01:01";
        doReturn(now).when(Date).getTimeNow();
        int threadCount = 10;
        ExecutorService executor = Executors.newFixedThreadPool(threadCount);
        CountDownLatch latch = new CountDownLatch(threadCount);
        for (int t = 0; t < threadCount; t++) {
            executor.submit(() -> {
                try {
                    appController.CommentMusicById(musicId);
                } finally {
                    latch.countDown();
                }
            });
        }
        latch.await();
        executor.shutdown();
        assertEquals(50 + threadCount, comments[0]);
        verify(musicRepo, times(threadCount)).save(musicMock);
        verify(Log, times(threadCount)).save(any(LogModel.class));
