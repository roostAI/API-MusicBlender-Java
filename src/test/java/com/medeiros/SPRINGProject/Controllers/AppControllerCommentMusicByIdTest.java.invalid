    void testHandleConcurrentCommentRequests() throws Exception {
        int musicId = 99;
        MusicModel musicMock = mock(MusicModel.class);
        // Simulate mutable comment count
        final int[] comments = {50};
        when(musicRepo.findById(musicId)).thenReturn(musicMock);
        when(musicMock.getNumberOfComents()).thenAnswer(invocation -> comments[0]);
        doAnswer(invocation -> {
            comments[0] = invocation.getArgument(0);
            return null;
