package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.*;
import org.junit.jupiter.api.*;
import org.mockito.*;
import org.mockito.junit.jupiter.MockitoExtension;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import com.medeiros.SPRINGProject.algorithm.algorithmBlender;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Map;

@ExtendWith(MockitoExtension.class)
public class AppControllerCommentMusicByIdTest {
    @InjectMocks
    private AppController appController;
    @Mock
    private MusicRepository musicRepo;
    @Mock
    private LogRepository logRepo;
    @Test
    @Tag("valid")
    public void testCommentCountIncrement() {
        MusicModel music = new MusicModel();
        music.setNumberOfComents(0);
        when(musicRepo.findById(1)).thenReturn(music);
        appController.CommentMusicById(1);
        assertEquals(1, music.getNumberOfComents());
    }
    @Test
    @Tag("valid")
    public void testCorrectLogDataSaved() {
        MusicModel music = new MusicModel();
        when(musicRepo.findById(1)).thenReturn(music);
        appController.CommentMusicById(1);
        ArgumentCaptor<LogModel> logCaptor = ArgumentCaptor.forClass(LogModel.class);
        verify(logRepo).save(logCaptor.capture());
        LogModel capturedLog = logCaptor.getValue();
        // Comment: The LogModel class does not have the methods getEndpoint(), getAppName(), and getTimestamp(). 
        // These methods need to be implemented in the LogModel class for these tests to pass.
    }
    @Test
    @Tag("valid")
    public void testCorrectMessageReturned() {
        MusicModel music = new MusicModel();
        when(musicRepo.findById(1)).thenReturn(music);
        String message = appController.CommentMusicById(1);
        assertEquals("Música Alterada!", message);
    }
    @Test
    @Tag("invalid")
    public void testExceptionThrownForInvalidId() {
        when(musicRepo.findById(1)).thenReturn(null);
        assertThrows(NullPointerException.class, () -> {
            appController.CommentMusicById(1);
        });
    }
}