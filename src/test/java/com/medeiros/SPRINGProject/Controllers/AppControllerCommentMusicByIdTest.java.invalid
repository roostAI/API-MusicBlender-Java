    @Test
    @Tag("integration")
    public void testCommentMusicByIdIsConsistentUnderConcurrentAccess() throws Exception {
        int musicId = 6;
        MusicModel mockMusic = mock(MusicModel.class);
        when(musicRepo.findById(musicId)).thenReturn(mockMusic);
        when(mockMusic.getNumberOfComents()).thenReturn(20);
        doNothing().when(musicRepo).save(mockMusic);
        doNothing().when(Log).save(any(LogModel.class));
        when(Date.getTimeNow()).thenReturn((String)"2024-01-01T13:00:00Z");
        int threads = 5;
        Runnable task = () -> {
            synchronized (mockMusic) {
                int current = mockMusic.getNumberOfComents();
                mockMusic.setNumberOfComents(current + 1);
                appController.CommentMusicById(musicId);
            }
        };
        Thread[] threadArr = new Thread[threads];
        for (int i = 0; i < threads; i++) {
            threadArr[i] = new Thread(task);
            threadArr[i].start();
        }
        for (int i = 0; i < threads; i++) {
            threadArr[i].join();
        }
        verify(musicRepo, times(threads)).save(mockMusic);
        verify(Log, times(threads)).save(any(LogModel.class));
    }
