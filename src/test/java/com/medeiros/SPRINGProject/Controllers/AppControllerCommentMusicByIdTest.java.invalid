    @Test
    @Tag("integration")
    public void testMultipleCallsCauseCorrectConsecutiveUpdates() {
        int musicId = 6;
        MusicModel music = mock(MusicModel.class);
        // Simulate consecutive comment counts 10, 11, 12
        when(musicRepo.findById(musicId)).thenReturn(music);
        when(music.getNumberOfComents())
