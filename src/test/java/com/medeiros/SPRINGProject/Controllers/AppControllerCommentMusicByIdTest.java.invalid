package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.*;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.algorithm.algorithmBlender;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Map;

public class AppControllerCommentMusicByIdTest {
    @InjectMocks
    private AppController appController;
    @Mock
    private MusicRepository musicRepo; // Changed to MusicRepository
    @Mock
    private LogRepository log; // Changed to LogRepository
    private MusicModel musicModel;
    private LogModel logModel; // Added LogModel for logging purposes
    @BeforeEach
    public void setUp() {
        MockitoAnnotations.openMocks(this);
        musicModel = new MusicModel();
        musicModel.setNumberOfComents(5); // Initial comment count
        logModel = new LogModel(); // Initialize LogModel
    }
    @Test
    @Tag("valid")
    public void validCommentOnExistingMusic() {
        when(musicRepo.findById(1)).thenReturn(musicModel);
        
        String result = appController.CommentMusicById(1);
        
        assertEquals("Música Alterada!", result);
        assertEquals(6, musicModel.getNumberOfComents());
        verify(musicRepo).save(musicModel);
        verify(log).save(any(LogModel.class));
    }
    @Test
    @Tag("invalid")
    public void commentOnNonExistingMusic() {
        when(musicRepo.findById(2)).thenReturn(null);
        
        Exception exception = assertThrows(NullPointerException.class, () -> {
            appController.CommentMusicById(2);
        });
        assertNotNull(exception);
    }
    @Test
    @Tag("boundary")
    public void commentOnMusicWithMaximumComments() {
        musicModel.setNumberOfComents(100); // Assuming 100 is the max limit
        when(musicRepo.findById(3)).thenReturn(musicModel);
        
        String result = appController.CommentMusicById(3);
        
        assertEquals("Música Alterada!", result);
        assertEquals(101, musicModel.getNumberOfComents()); // Assuming we allow one more comment
        verify(musicRepo).save(musicModel);
        verify(log).save(any(LogModel.class));
    }
    @Test
    @Tag("integration")
    public void logEntryCreationOnComment() {
        when(musicRepo.findById(4)).thenReturn(musicModel);
        
        appController.CommentMusicById(4);
        
        verify(log).save(argThat(logModel -> 
            logModel.getAction().equals("app/comment/{id}") && 
            logModel.getSource().equals("App")
        ));
    }
    @Test
    @Tag("invalid")
    public void commentMusicWithInvalidIdFormat() {
        int invalidId = -1; 
        
        Exception exception = assertThrows(NullPointerException.class, () -> {
            appController.CommentMusicById(invalidId);
        });
        assertNotNull(exception);
    }
}