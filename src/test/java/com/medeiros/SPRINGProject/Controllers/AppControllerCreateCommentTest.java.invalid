@ExtendWith(MockitoExtension.class)
public class AppControllerCreateCommentTest {
    @Mock
    private CommentsRepository commentsRepo; // Corrected class name
    @Mock
    private LogRepository log; // Corrected class name
    @InjectMocks
    private AppController appController;
    @Test
    @Tag("valid")
    public void testCreateCommentSuccessfully() {
        String commentText = "Test Comment";
        int id = 1;
        CommentsModel comment = new CommentsModel(commentText, id);
        LogModel logData = new LogModel("app/createComment/{id}", "App", new Date()); // Corrected Date usage
        when(commentsRepo.save(any(CommentsModel.class))).thenReturn(comment);
        when(log.save(any(LogModel.class))).thenReturn(logData);
        String result = appController.createComment(id, commentText);
        assertEquals(commentText, result);
        verify(commentsRepo, times(1)).save(comment);
        verify(log, times(1)).save(logData);
    }
    @Test
    @Tag("invalid")
    public void testCreateCommentWithInvalidId() {
        String commentText = "Test Comment";
        int invalidId = -1;
        assertThrows(IllegalArgumentException.class, () -> {
            appController.createComment(invalidId, commentText);
        });
    }
    @Test
    @Tag("invalid")
    public void testCreateCommentWithNullComment() {
        int id = 1;
        assertThrows(IllegalArgumentException.class, () -> {
            appController.createComment(id, null);
        });
    }
    @Test
    @Tag("integration")
    public void testLogCreationOnCommentCreation() {
        String commentText = "Test Comment";
        int id = 1;
        CommentsModel comment = new CommentsModel(commentText, id);
        LogModel logData = new LogModel("app/createComment/{id}", "App", new Date()); // Corrected Date usage
        when(commentsRepo.save(any(CommentsModel.class))).thenReturn(comment);
        when(log.save(any(LogModel.class))).thenReturn(logData);
        appController.createComment(id, commentText);
        verify(log, times(1)).save(logData);
    }
}