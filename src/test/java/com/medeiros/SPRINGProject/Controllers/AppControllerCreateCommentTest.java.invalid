    @Test
    @Tag("valid")
    public void testCreateCommentReturnsCommentWhenValidInput() {
        int id = 1;
        String inputComment = "A valid user comment.";
        doNothing().when(commentsRepo).save(any(CommentsModel.class));
        doNothing().when(log).save(any(LogModel.class));
        // As LogModel.getTimeNow is not static, stub its implementation using Spy
        doReturn("2024-01-01T12:34:56").when(date).getTimeNow();
        String result = appController.createComment(id, inputComment);
        assertEquals((String) inputComment, (String) result);
        verify(commentsRepo, times(1)).save(commentCaptor.capture());
        CommentsModel savedComment = commentCaptor.getValue();
        assertEquals((String) inputComment, (String) savedComment.getComment());
        assertEquals((int) id, (int) savedComment.id); // Use .id field directly
        verify(log, times(1)).save(logCaptor.capture());
        LogModel savedLog = logCaptor.getValue();
        // You may need to check constructor values, as getEndpoint/getSource/getDate are not defined
        assertEquals("app/createComment/{id}", ((LogModel)savedLog).endpoint); // use field directly
        assertEquals("App", ((LogModel)savedLog).source);
        assertEquals("2024-01-01T12:34:56", ((LogModel)savedLog).date);
    }
