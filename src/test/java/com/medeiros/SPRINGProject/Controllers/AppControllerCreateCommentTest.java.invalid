    @Test
    @Tag("integration")
    public void testCreateCommentAllowsMultipleForSameId() {
        int id = 202;
        String comment1 = "First comment!";
        String comment2 = "Second comment!";
        String comment3 = "Third comment, same music!";
        String nowTimestamp = "2024-05-01T19:00:00";
        doReturn(nowTimestamp).when(date).getTimeNow();
        doNothing().when(commentsRepo).save(any(CommentsModel.class));
        doNothing().when(log).save(any(LogModel.class));
        String res1 = appController.createComment(id, comment1);
        String res2 = appController.createComment(id, comment2);
        String res3 = appController.createComment(id, comment3);
        assertEquals((String) comment1, (String) res1);
        assertEquals((String) comment2, (String) res2);
        assertEquals((String) comment3, (String) res3);
        verify(commentsRepo, times(3)).save(commentCaptor.capture());
        assertEquals((String) comment1, (String) commentCaptor.getAllValues().get(0).getComment());
        assertEquals((int) id, (int) commentCaptor.getAllValues().get(0).id);
        assertEquals((String) comment2, (String) commentCaptor.getAllValues().get(1).getComment());
        assertEquals((int) id, (int) commentCaptor.getAllValues().get(1).id);
        assertEquals((String) comment3, (String) commentCaptor.getAllValues().get(2).getComment());
        assertEquals((int) id, (int) commentCaptor.getAllValues().get(2).id);
        verify(log, times(3)).save(any(LogModel.class));
    }
