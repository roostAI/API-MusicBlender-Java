@ExtendWith(MockitoExtension.class)
public class AppControllerCreateCommentTest {
    @InjectMocks
    AppController appController;
    @Mock
    CommentsRepository commentsRepo;
    @Mock
    LogRepository log;
    @Test
    @Tag("valid")
    public void testCreateCommentSuccessfully() {
        String commentText = "This is a test comment";
        int id = 1;
        CommentsModel comment = new CommentsModel(commentText, id);
        when(commentsRepo.save(any(CommentsModel.class))).thenReturn(comment);
        when(log.save(any(LogModel.class))).thenReturn(new LogModel("app/createComment/{id}", "App", System.currentTimeMillis()));
        String result = appController.createComment(id, commentText);
        assertEquals(commentText, result);
    }
    @Test
    @Tag("invalid")
    public void testCreateCommentWithNegativeId() {
        String commentText = "This is a test comment";
        int id = -1;
        assertThrows(IllegalArgumentException.class, () -> appController.createComment(id, commentText));
    }
    @Test
    @Tag("invalid")
    public void testCreateCommentWithEmptyText() {
        String commentText = "";
        int id = 1;
        assertThrows(IllegalArgumentException.class, () -> appController.createComment(id, commentText));
    }
}