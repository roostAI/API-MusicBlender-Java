    public void testCreateCommentLogsCorrectEndpointAndTimestamp() {
        int id = 33;
        String comment = "Testing log values";
        String nowTimestamp = "2024-04-13T23:45:00";
        doReturn(nowTimestamp).when(date).getTimeNow();
        doNothing().when(commentsRepo).save(any(CommentsModel.class));
        doNothing().when(log).save(any(LogModel.class));
        String result = appController.createComment(id, comment);
        assertEquals((String) comment, (String) result);
