    @BeforeEach
    void setUp() {
        // Common setup if needed
    }
    @Test
    @Tag("valid")
    void createCommentSuccess() {
        // Arrange
        int testId = 1;
        String testComment = "Test Comment";
        LocalDateTime now = LocalDateTime.now();
        
        when(CommentsRepo.save(any(CommentsModel.class))).thenReturn(new CommentsModel(testComment, testId));
        when(Log.save(any(LogModel.class))).thenReturn(new LogModel("app/createComment/{id}", "App", now));
        // Act
        String result = appController.createComment(testId, testComment);
        // Assert
        verify(CommentsRepo, times(1)).save(any(CommentsModel.class));
        verify(Log, times(1)).save(any(LogModel.class));
        assertEquals(testComment, result);
    }
