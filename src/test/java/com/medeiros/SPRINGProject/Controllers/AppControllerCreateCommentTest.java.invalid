        verify(Log, times(1)).save(any(LogModel.class));
        
        // Verify CommentsModel creation
        verify(CommentsRepo).save(argThat(comment -> 
            ((CommentsModel) comment).getComment().equals(validComment) && 
            ((CommentsModel) comment).getMusicId() == validId
        ));
        
        // Verify LogModel creation
        verify(Log).save(argThat(logData -> 
            ((LogModel) logData).getEndpoint().equals("app/createComment/{id}") &&
            ((LogModel) logData).getSource().equals("App") &&
            ((LogModel) logData).getTimestamp().equals("2023-12-01 10:00:00")
        ));
    }
    
