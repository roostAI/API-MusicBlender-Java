    @Test
    @Tag("integration")
    public void testCreateCommentWithConcurrentRequests() {
        int musicId = 740;
        String commentTextA = "Concurrent A";
        String commentTextB = "Concurrent B";
        doNothing().when(commentsRepo).save(any(CommentsModel.class));
        doNothing().when(log).save(any(LogModel.class));
        doReturn("2024-06-01T17:00:00").when(date).getTimeNow();
        Runnable taskA = () -> {
            String result = appController.createComment(musicId, commentTextA);
            assertEquals((String)commentTextA, (String)result);
        };
        Runnable taskB = () -> {
            String result = appController.createComment(musicId, commentTextB);
            assertEquals((String)commentTextB, (String)result);
        };
        Thread threadA = new Thread(taskA);
        Thread threadB = new Thread(taskB);
        threadA.start();
        threadB.start();
        try {
            threadA.join();
            threadB.join();
        } catch (InterruptedException e) {
            fail("Thread join interrupted");
        }
        verify(commentsRepo, times(2)).save(any(CommentsModel.class));
        verify(log, times(2)).save(any(LogModel.class));
        // Comment: Concurrency issues should be handled in business logic for production use.
    }
