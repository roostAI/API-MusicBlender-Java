public class AppControllerGetCommentsByMusicIdTest {
    @Mock
    private CommentsRepository commentsRepo; // Corrected the class name
    @Mock
    private LogRepository log; // Corrected the class name
    @InjectMocks
    private AppController appController;
    @BeforeEach
    public void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void retrieveCommentsForValidMusicId() {
        int validMusicId = 1; // Assuming 1 is a valid music ID
        List<CommentsModel> expectedComments = Arrays.asList(new CommentsModel("Great song!", validMusicId));
        when(commentsRepo.findByMusicId(validMusicId)).thenReturn(expectedComments);
        String result = appController.getCommentsByMusicId(validMusicId);
        assertEquals(expectedComments.toString(), result);
        verify(commentsRepo, times(1)).findByMusicId(validMusicId);
    }
    @Test
    @Tag("invalid")
    public void handleNonExistentMusicId() {
        int nonExistentMusicId = 999; // Assuming 999 is a non-existent music ID
        when(commentsRepo.findByMusicId(nonExistentMusicId)).thenReturn(null);
        String result = appController.getCommentsByMusicId(nonExistentMusicId);
        assertEquals("No comments found", result);
        verify(commentsRepo, times(1)).findByMusicId(nonExistentMusicId);
    }
    @Test
    @Tag("invalid")
    public void handleNegativeMusicId() {
        int negativeMusicId = -1;
        when(commentsRepo.findByMusicId(negativeMusicId)).thenReturn(null);
        String result = appController.getCommentsByMusicId(negativeMusicId);
        assertEquals("Invalid Music ID", result);
        verify(commentsRepo, times(1)).findByMusicId(negativeMusicId);
    }
    @Test
    @Tag("boundary")
    public void handleZeroMusicId() {
        int zeroMusicId = 0;
        when(commentsRepo.findByMusicId(zeroMusicId)).thenReturn(null);
        String result = appController.getCommentsByMusicId(zeroMusicId);
        assertEquals("Invalid Music ID", result);
        verify(commentsRepo, times(1)).findByMusicId(zeroMusicId);
    }
    @Test
    @Tag("integration")
    public void verifyLoggingOfCommentRetrieval() {
        int validMusicId = 1; // Assuming 1 is a valid music ID
        List<CommentsModel> expectedComments = Arrays.asList(new CommentsModel("Great song!", validMusicId));
        when(commentsRepo.findByMusicId(validMusicId)).thenReturn(expectedComments);
        appController.getCommentsByMusicId(validMusicId);
        verify(log, times(1)).save(any(LogModel.class));
    }
}