@ExtendWith(MockitoExtension.class)
public class AppControllerGetCommentsByMusicIdTest {
    @Mock
    private CommentsRepository commentsRepository;
    @InjectMocks
    private AppController appController;
    @BeforeEach
    public void setUp() {
        CommentsModel comment = new CommentsModel("Test Comment", 1);
        when(commentsRepository.findById(1)).thenReturn(Optional.of(comment));
        when(commentsRepository.findById(-1)).thenReturn(Optional.empty());
    }
    @Test
    @Tag("valid")
    public void testGetCommentsByMusicId() {
        String expectedComment = "Test Comment";
        String actualComment = appController.getCommentsByMusicId(1);
