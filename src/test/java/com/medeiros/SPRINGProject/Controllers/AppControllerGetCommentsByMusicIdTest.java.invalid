package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.CommentsModel;
import com.medeiros.SPRINGProject.Models.CommentsRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import java.util.Collections;
import java.util.List;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.Mockito.when;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.*;
import com.medeiros.SPRINGProject.algorithm.algorithmBlender;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Map;

public class AppControllerGetCommentsByMusicIdTest {
    @Mock
    private CommentsRepository CommentsRepo;
    @InjectMocks
    private AppController appController;
    @BeforeEach
    public void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void validMusicIdWithExistingComments() {
        int musicId = 1; // Assuming 1 is a valid music ID with existing comments
        List<CommentsModel> comments = List.of(new CommentsModel("Great song!", musicId));
        when(CommentsRepo.findByMusicId(musicId)).thenReturn(comments);
        String result = appController.getCommentsByMusicId(musicId);
        assertEquals("Great song!", result);
    }
    @Test
    @Tag("valid")
    public void validMusicIdWithNoComments() {
        int musicId = 2; // Assuming 2 is a valid music ID with no comments
        when(CommentsRepo.findByMusicId(musicId)).thenReturn(Collections.emptyList());
        String result = appController.getCommentsByMusicId(musicId);
        assertEquals("No comments available", result);
    }
    @Test
    @Tag("invalid")
    public void invalidMusicId() {
        int musicId = 9999; // Assuming 9999 is an invalid music ID
        when(CommentsRepo.findByMusicId(musicId)).thenReturn(Collections.emptyList());
        String result = appController.getCommentsByMusicId(musicId);
        assertEquals("Invalid music ID", result);
    }
    @Test
    @Tag("boundary")
    public void zeroAsMusicId() {
        int musicId = 0;
        when(CommentsRepo.findByMusicId(musicId)).thenReturn(Collections.emptyList());
        String result = appController.getCommentsByMusicId(musicId);
        assertEquals("No comments available", result);
    }
    @Test
    @Tag("boundary")
    public void negativeMusicId() {
        int musicId = -1;
        when(CommentsRepo.findByMusicId(musicId)).thenReturn(Collections.emptyList());
        String result = appController.getCommentsByMusicId(musicId);
        assertEquals("Invalid music ID", result);
    }
}