public class AppControllerGetCommentsByMusicIdTest {
    @InjectMocks
    private AppController appController;
    @Mock
    private MusicRepository musicRepo;
    @Mock
    private CommentsRepository commentsRepo;
    @Mock
    private LogRepository log;
    @BeforeEach
    public void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void validMusicIdReturnsCorrectResponse() {
        // Arrange
        int validMusicId = 1; // TODO: Change to a valid MusicId
        when(commentsRepo.findByMusicId(validMusicId)).thenReturn("Expected Comments");
        // Act
        String result = appController.getCommentsByMusicId(validMusicId);
        // Assert
        assertEquals("Expected Comments", result);
    }
    @Test
    @Tag("invalid")
    public void nonExistentMusicIdReturnsError() {
        // Arrange
        int nonExistentMusicId = 9999; // TODO: Change to a non-existent MusicId
        when(commentsRepo.findByMusicId(nonExistentMusicId)).thenReturn(null);
        // Act
        String result = appController.getCommentsByMusicId(nonExistentMusicId);
        // Assert
        assertEquals("Error", result);
    }
    @Test
    @Tag("boundary")
    public void negativeMusicIdReturnsError() {
        // Arrange
        int negativeMusicId = -1;
        when(commentsRepo.findByMusicId(negativeMusicId)).thenReturn(null);
        // Act
        String result = appController.getCommentsByMusicId(negativeMusicId);
        // Assert
        assertEquals("Error", result);
    }
    @Test
    @Tag("boundary")
    public void zeroMusicIdReturnsError() {
        // Arrange
        int zeroMusicId = 0;
        when(commentsRepo.findByMusicId(zeroMusicId)).thenReturn(null);
        // Act
        String result = appController.getCommentsByMusicId(zeroMusicId);
        // Assert
        assertEquals("Error", result);
    }
}