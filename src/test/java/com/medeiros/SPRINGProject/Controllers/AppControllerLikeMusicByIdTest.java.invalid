    @Test
    @Tag("integration")
    public void testLikeMusicByIdConcurrentIncrement() throws InterruptedException {
        int testId = 106;
        MusicModel mockMusic = mock(MusicModel.class);
        final int[] likes = {12};
        when(musicRepo.findById((int)testId)).thenReturn(mockMusic);
        when(mockMusic.getNumberOfLikes()).thenAnswer(invocation -> likes[0]);
        doAnswer(invocation -> {
            int newLikes = ((MusicModel)invocation.getArgument(0)).getNumberOfLikes();
            likes[0] = newLikes;
            return null;
        }).when(musicRepo).save((MusicModel)mockMusic);
        doReturn("2024-06-10T10:00:00Z").when(Date).getTimeNow();
        int threads = 5;
        CountDownLatch latch = new CountDownLatch(threads);
        Runnable likeTask = () -> {
            appController.LikeMusicById(testId);
            latch.countDown();
        };
        for (int i = 0; i < threads; i++) {
            new Thread(likeTask).start();
        }
        latch.await(1, TimeUnit.SECONDS);
        assertEquals((int)(12 + threads), (int)likes[0]);
        verify(musicRepo, times(threads)).save(mockMusic);
    }
