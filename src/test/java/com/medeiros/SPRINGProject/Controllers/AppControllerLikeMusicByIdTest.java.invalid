package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.MusicModel;
import com.medeiros.SPRINGProject.Models.LogModel;
import com.medeiros.SPRINGProject.algorithm.algorithmBlender;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.*;
import java.util.Date;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Map;

public class AppControllerLikeMusicByIdTest {
    @Mock
    private MusicRepository musicRepo;
    @Mock
    private LogRepository logRepo;
    @InjectMocks
    private AppController appController;
    @BeforeEach
    public void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void likeMusicSuccessfully() {
        int musicId = 1; // TODO: Change to a valid music ID
        MusicModel mockMusic = mock(MusicModel.class);
        when(musicRepo.findById(musicId)).thenReturn(mockMusic);
        when(mockMusic.getNumberOfLikes()).thenReturn(5);
        String result = appController.LikeMusicById(musicId);
        verify(mockMusic).setNumberOfLikes(6);
        verify(musicRepo).save(mockMusic);
        verify(logRepo).save(any(LogModel.class));
        assertEquals("Música Alterada!", result);
    }
    @Test
    @Tag("invalid")
    public void handleNonExistentMusicId() {
        int nonExistentId = 999; // TODO: Change to a non-existent music ID
        when(musicRepo.findById(nonExistentId)).thenReturn(null);
        Exception exception = assertThrows(RuntimeException.class, () -> {
            appController.LikeMusicById(nonExistentId);
        });
        assertTrue(exception.getMessage().contains("Music item not found"));
    }
    @Test
    @Tag("integration")
    public void verifyLoggingFunctionality() {
        int musicId = 1; // TODO: Change to a valid music ID
        MusicModel mockMusic = mock(MusicModel.class);
        when(musicRepo.findById(musicId)).thenReturn(mockMusic);
        when(mockMusic.getNumberOfLikes()).thenReturn(5);
        appController.LikeMusicById(musicId);
        verify(logRepo).save(argThat(log -> 
            log.getUrl().equals("app/like/{id}") &&
            log.getApplicationName().equals("App") &&
            log.getTimestamp() != null
        ));
    }
    @Test
    @Tag("boundary")
    public void incrementLikesFromZero() {
        int musicId = 1; // TODO: Change to a valid music ID
        MusicModel mockMusic = mock(MusicModel.class);
        when(musicRepo.findById(musicId)).thenReturn(mockMusic);
        when(mockMusic.getNumberOfLikes()).thenReturn(0);
        String result = appController.LikeMusicById(musicId);
        verify(mockMusic).setNumberOfLikes(1);
        verify(musicRepo).save(mockMusic);
        assertEquals("Música Alterada!", result);
    }
    @Test
    @Tag("invalid")
    public void handleNullMusicModel() {
        int musicId = 1; // TODO: Change to a valid music ID
        when(musicRepo.findById(musicId)).thenReturn(null);
        Exception exception = assertThrows(RuntimeException.class, () -> {
            appController.LikeMusicById(musicId);
        });
        assertTrue(exception.getMessage().contains("Music item not found"));
    }
}