package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.*;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.algorithm.algorithmBlender;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Map;

@ExtendWith(MockitoExtension.class)
public class AppControllerLikeMusicByIdTest {
    @InjectMocks
    private AppController appController;
    @Mock
    private MusicRepository musicRepo;
    @Mock
    private LogRepository Log;
    @Mock
    private LogModel Date;
    @Test
    @Tag("valid")
    public void testIncreaseInNumberOfLikes() {
        MusicModel music = new MusicModel();
        music.setNumberOfLikes(5);
        when(musicRepo.findById(anyInt())).thenReturn(java.util.Optional.of(music));
        appController.LikeMusicById(1);
        assertEquals(6, music.getNumberOfLikes());
    }
    @Test
    @Tag("valid")
    public void testReturnMessage() {
        MusicModel music = new MusicModel();
        when(musicRepo.findById(anyInt())).thenReturn(java.util.Optional.of(music));
        String message = appController.LikeMusicById(1);
        assertEquals("Música Alterada!", message);
    }
    @Test
    @Tag("valid")
    public void testLoggingData() {
        MusicModel music = new MusicModel();
        when(musicRepo.findById(anyInt())).thenReturn(java.util.Optional.of(music));
        LogModel logData = new LogModel("app/like/{id}", "App", Date.getTimeNow());
        doNothing().when(Log).save(logData);
        appController.LikeMusicById(1);
        verify(Log, times(1)).save(logData);
    }
}