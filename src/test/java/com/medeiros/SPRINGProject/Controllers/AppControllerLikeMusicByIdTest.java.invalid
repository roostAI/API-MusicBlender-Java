    @Test
    @Tag("valid")
    public void testLikeMusicByIdIncrementsLikesForValidMusicId() {
        int testId = 101;
        int originalLikes = 10;
        MusicModel musicMock = mock(MusicModel.class);
        when(musicRepo.findById(eq(testId))).thenReturn(musicMock);
        when(musicMock.getNumberOfLikes()).thenReturn(originalLikes);
        // Proper mock for Date.getTimeNow() with a string return
        when(Date.getTimeNow()).thenReturn("2024-06-08T12:00:00");
        String expectedResponse = "Música Alterada!";
        String result = appController.LikeMusicById(testId);
        verify(musicMock).setNumberOfLikes(eq(originalLikes + 1));
        verify(musicRepo).save(eq(musicMock));
        ArgumentCaptor<LogModel> logCaptor = ArgumentCaptor.forClass(LogModel.class);
        verify(Log).save(logCaptor.capture());
        LogModel logData = logCaptor.getValue();
        // Only validate the LogModel constructor arguments directly since getPath, getSource, getDate are not guaranteed fields/methods
        assertEquals("app/like/{id}", (String)logData.path);
        assertEquals("App", (String)logData.source);
        assertNotNull((String)logData.date);
        assertEquals(expectedResponse, (String)result);
    }
