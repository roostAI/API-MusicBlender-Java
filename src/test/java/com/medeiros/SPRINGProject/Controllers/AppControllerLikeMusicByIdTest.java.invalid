import java.util.Date;

@ExtendWith(MockitoExtension.class)
class AppControllerLikeMusicByIdTest {
    @Mock
    private MusicRepository musicRepo;
    @Mock
    private LogRepository Log;
    @InjectMocks
    private AppController appController;
    private MusicModel testMusic;
    private LogModel testLog;
    @BeforeEach
    void setUp() {
        testMusic = new MusicModel();
        testMusic.setId(1);
        testMusic.setNumberOfLikes(5);
        
        testLog = new LogModel("app/like/{id}", "App", new Date()); // Using java.util.Date
    }
    @Test
    @Tag("valid")
    void successfulLikeOperationWithValidId() {
        // Arrange
        when(musicRepo.findById(1)).thenReturn(testMusic);
        
        // Act
        String result = appController.LikeMusicById(1);
        // Assert
        assertEquals(6, testMusic.getNumberOfLikes());
        assertEquals("Música Alterada!", result);
        verify(musicRepo).save(testMusic);
        verify(Log).save(any(LogModel.class));
    }
    @Test
    @Tag("invalid") 
    void likeOperationWithNonExistentId() {
        // Arrange
        when(musicRepo.findById(999)).thenReturn(null);
        
        // Act & Assert
        assertThrows(NullPointerException.class, () -> {
            appController.LikeMusicById(999);
        });
        verify(musicRepo, never()).save(any(MusicModel.class));
    }
    @Test
    @Tag("boundary")
    void likeOperationWithMaxLikes() {
        // Arrange
        testMusic.setNumberOfLikes(Integer.MAX_VALUE);
        when(musicRepo.findById(1)).thenReturn(testMusic);
        
        // Act & Assert
        assertThrows(ArithmeticException.class, () -> {
            appController.LikeMusicById(1);
        });
    }
    @Test
    @Tag("integration")
    void likeOperationVerifyLogCreation() {
        // Arrange
        when(musicRepo.findById(1)).thenReturn(testMusic);
        
        // Act
        appController.LikeMusicById(1);
        // Assert
        verify(Log).save(argThat(log -> {
            // Assuming LogModel has these getter methods
            return log.getEndpoint() != null &&
                   log.getOrigin() != null &&
                   log.getDate() != null;
        }));
    }
}