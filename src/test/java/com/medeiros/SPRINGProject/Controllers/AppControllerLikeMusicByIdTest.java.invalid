    @Test
    @Tag("valid")
    void likeMusicByIdWithValidId() {
        // Arrange
        int musicId = 1;
        int initialLikes = 5;
        String expectedTimestamp = "2023-12-01 10:00:00";
        
        MusicModel mockMusic = new MusicModel();
        mockMusic.setNumberOfLikes(initialLikes);
        
        when(musicRepo.findById(musicId)).thenReturn(mockMusic);
        when(Date.getTimeNow()).thenReturn(expectedTimestamp);
        
        // Act
        String result = appController.LikeMusicById(musicId);
        
        // Assert
        assertEquals("Música Alterada!", result);
        assertEquals(initialLikes + 1, mockMusic.getNumberOfLikes());
        verify(musicRepo, times(1)).save(mockMusic);
        verify(Log, times(1)).save(any(LogModel.class));
    }
