    // Scenario 5
    @Test
    @Tag("integration")
    public void testLikeMusicByIdCreatesLogEntry() {
        int id = 4;
        MusicModel music = mock(MusicModel.class);
        when(musicRepo.findById(id)).thenReturn(music);
        when(music.getNumberOfLikes()).thenReturn(1);
        doNothing().when(music).setNumberOfLikes(2);
        Object timestamp = Long.valueOf(123456789L); // Use Object for compatibility with getTimeNow mocking
        when(Date.getTimeNow()).thenReturn(timestamp);
        ArgumentCaptor<LogModel> logCaptor = ArgumentCaptor.forClass(LogModel.class);
        doNothing().when(Log).save(logCaptor.capture());
        doNothing().when(musicRepo).save(music);
        appController.LikeMusicById(id);
        LogModel capturedLog = logCaptor.getValue();
        assertNotNull(capturedLog);
        // Since LogModel only provides constructor, direct field access required
        // As getEndpoint(), getSource(), getTime() are not available, we check the fields using reflection
        try {
            java.lang.reflect.Field epField = LogModel.class.getDeclaredField("endpoint");
            epField.setAccessible(true);
            java.lang.reflect.Field srcField = LogModel.class.getDeclaredField("source");
            srcField.setAccessible(true);
            java.lang.reflect.Field timeField = LogModel.class.getDeclaredField("time");
            timeField.setAccessible(true);
            assertEquals("app/like/{id}", (String) epField.get(capturedLog));
            assertEquals("App", (String) srcField.get(capturedLog));
            assertEquals((Long)timestamp, (Long) timeField.get(capturedLog));
        } catch (Exception e) {
            fail("LogModel does not have expected fields, please add: endpoint, source, time");
        }
