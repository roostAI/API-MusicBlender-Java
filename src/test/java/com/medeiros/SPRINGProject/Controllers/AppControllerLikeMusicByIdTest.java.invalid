    @Test
    @Tag("valid")
    public void testLikeMusicByIdIncrementsLikesWhenMusicExists() {
        int musicId = 25;
        MusicModel mockMusic = mock(MusicModel.class);
        when(musicRepo.findById((int)musicId)).thenReturn(mockMusic);
        when(mockMusic.getNumberOfLikes()).thenReturn(7);
        doNothing().when(musicRepo).save((MusicModel)mockMusic);
        // Date.getTimeNow() returns a String, so mock with doReturn instead of thenReturn
        doReturn("2024-06-10T10:00:00Z").when(Date).getTimeNow();
        String result = appController.LikeMusicById(musicId);
        verify(mockMusic).setNumberOfLikes(8);
        verify(musicRepo).save(mockMusic);
        ArgumentCaptor<LogModel> logCaptor = ArgumentCaptor.forClass(LogModel.class);
        verify(Log).save(logCaptor.capture());
        LogModel logModel = logCaptor.getValue();
        // Access constructor values to check
        assertEquals((String)"app/like/{id}", (String)logModel.path); // assuming public fields, adjust if needed
        assertEquals((String)"App", (String)logModel.user);
        assertEquals((String)"2024-06-10T10:00:00Z", (String)logModel.timestamp);
        assertEquals((String)"Música Alterada!", (String)result);
    }
