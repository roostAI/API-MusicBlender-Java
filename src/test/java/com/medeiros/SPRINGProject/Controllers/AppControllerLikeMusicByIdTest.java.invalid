    @BeforeEach
    public void setUp() {
        appController = new AppController();
        appController.musicRepo = musicRepo;
        appController.Log = Log;
        appController.Date = Date;
    }
    @Test
    @Tag("valid")
    public void testLikeMusicSuccessfullyReturnConfirmation() {
        int testId = 123;
        MusicModel musicStub = mock(MusicModel.class);
        when(musicRepo.findById(testId)).thenReturn(musicStub);
        when(musicStub.getNumberOfLikes()).thenReturn(10);
        doNothing().when(musicStub).setNumberOfLikes(11);
        doNothing().when(musicRepo).save(musicStub);
        // Don't try to stub a static or parameterless method not on a mock, use dummy construction
        when(Date.getTimeNow()).thenReturn("2024-06-06T12:45:00");
        doNothing().when(Log).save(any(LogModel.class));
        String result = appController.LikeMusicById(testId);
        verify(musicStub).setNumberOfLikes(11);
        verify(musicRepo).save(musicStub);
        ArgumentCaptor<LogModel> logCaptor = ArgumentCaptor.forClass(LogModel.class);
        verify(Log).save(logCaptor.capture());
        LogModel capturedLog = logCaptor.getValue();
        // Direct assertions on constructor parameters using reflection, since getters DO NOT exist.
        assertEquals("app/like/{id}", (String) TestUtil.getFieldValue(capturedLog, "path"));
        assertEquals("App", (String) TestUtil.getFieldValue(capturedLog, "user"));
        assertEquals("2024-06-06T12:45:00", (String) TestUtil.getFieldValue(capturedLog, "dateTime"));
        assertEquals("Música Alterada!", (String) result);
    }
