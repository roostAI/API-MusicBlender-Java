package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.*;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.algorithm.algorithmBlender;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Map;
import java.util.Date;

class AppControllerLikeMusicByIdTest {
    @InjectMocks
    AppController appController;
    @Mock
    MusicRepository musicRepo;
    @Mock
    LogRepository logRepo;
    Date date = new Date();
    @BeforeEach
    void setUp() {
        MockitoAnnotations.initMocks(this);
    }
    @Test
    @Tag("valid")
    void testIncrementOfLikes() {
        MusicModel music = new MusicModel();
        music.setNumberOfLikes(5);
        when(musicRepo.findById(1)).thenReturn(music);
        appController.LikeMusicById(1);
        assertEquals(6, music.getNumberOfLikes());
    }
    @Test
    @Tag("integration")
    void testLogSaveInvocation() {
        MusicModel music = new MusicModel();
        music.setNumberOfLikes(5);
        when(musicRepo.findById(1)).thenReturn(music);
        LogModel log = new LogModel("app/like/{id}", "App", date.getTime());
        appController.LikeMusicById(1);
        verify(logRepo, times(1)).save(log);
    }
    @Test
    @Tag("valid")
    void testReturnMessage() {
        MusicModel music = new MusicModel();
        music.setNumberOfLikes(5);
        when(musicRepo.findById(1)).thenReturn(music);
        String result = appController.LikeMusicById(1);
        assertEquals("Música Alterada!", result);
    }
}