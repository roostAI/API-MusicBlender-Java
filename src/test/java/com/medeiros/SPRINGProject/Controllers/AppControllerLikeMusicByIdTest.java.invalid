            // Assert
            assertEquals("Música Alterada!", response);
            verify(musicRepo, times(1)).findById(musicId);
            verify(musicRepo, times(1)).save(musicModelCaptor.capture());
            mockedLog.verify(() -> Log.save(any(LogModel.class)), times(1));
            MusicModel capturedMusic = musicModelCaptor.getValue();
            assertEquals(initialLikes + 1, capturedMusic.getNumberOfLikes());
        }
    }
