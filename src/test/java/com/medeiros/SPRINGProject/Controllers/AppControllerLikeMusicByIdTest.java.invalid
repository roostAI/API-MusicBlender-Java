package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.*;
import com.medeiros.SPRINGProject.algorithm.algorithmBlender;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Map;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.*;
import java.util.Optional;
import org.junit.jupiter.api.*;

public class AppControllerLikeMusicByIdTest {
    @Mock
    private MusicRepository musicRepo;
    @Mock
    private LogRepository Log;
    @InjectMocks
    private AppController appController;
    @BeforeEach
    public void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void likeMusicByValidId() {
        int id = 1;
        MusicModel music = new MusicModel();
        music.setNumberOfLikes(5);
        when(musicRepo.findById(id)).thenReturn(Optional.of(music));
        when(musicRepo.save(music)).thenReturn(music);
        doNothing().when(Log).save(any(LogModel.class));
        String result = appController.LikeMusicById(id);
        assertEquals("Música Alterada!", result);
        assertEquals(6, music.getNumberOfLikes());
        verify(Log, times(1)).save(any(LogModel.class));
    }
    @Test
    @Tag("invalid")
    public void likeMusicByInvalidId() {
        int id = 999;
        when(musicRepo.findById(id)).thenReturn(Optional.empty());
        String result = appController.LikeMusicById(id);
        assertNull(result);
    }
    @Test
    @Tag("boundary")
    public void likeMusicByMaxIntegerId() {
        int id = Integer.MAX_VALUE;
        MusicModel music = new MusicModel();
        music.setNumberOfLikes(5);
        when(musicRepo.findById(id)).thenReturn(Optional.of(music));
        when(musicRepo.save(music)).thenReturn(music);
        doNothing().when(Log).save(any(LogModel.class));
        String result = appController.LikeMusicById(id);
        assertEquals("Música Alterada!", result);
        assertEquals(6, music.getNumberOfLikes());
        verify(Log, times(1)).save(any(LogModel.class));
    }
    @Test
    @Tag("boundary")
    public void likeMusicByMinIntegerId() {
        int id = Integer.MIN_VALUE;
        MusicModel music = new MusicModel();
        music.setNumberOfLikes(5);
        when(musicRepo.findById(id)).thenReturn(Optional.of(music));
        when(musicRepo.save(music)).thenReturn(music);
        doNothing().when(Log).save(any(LogModel.class));
        String result = appController.LikeMusicById(id);
        assertEquals("Música Alterada!", result);
        assertEquals(6, music.getNumberOfLikes());
        verify(Log, times(1)).save(any(LogModel.class));
    }
    @Test
    @Tag("invalid")
    public void likeMusicByNegativeId() {
        int id = -1;
        when(musicRepo.findById(id)).thenReturn(Optional.empty());
        String result = appController.LikeMusicById(id);
        assertNull(result);
    }
    @Test
    @Tag("boundary")
    public void likeMusicByZeroId() {
        int id = 0;
        MusicModel music = new MusicModel();
        music.setNumberOfLikes(5);
        when(musicRepo.findById(id)).thenReturn(Optional.of(music));
        when(musicRepo.save(music)).thenReturn(music);
        doNothing().when(Log).save(any(LogModel.class));
        String result = appController.LikeMusicById(id);
        assertEquals("Música Alterada!", result);
        assertEquals(6, music.getNumberOfLikes());
        verify(Log, times(1)).save(any(LogModel.class));
    }
    @Test
    @Tag("integration")
    public void concurrentLikes() throws InterruptedException {
        int id = 1;
        MusicModel music = new MusicModel();
        music.setNumberOfLikes(5);
        when(musicRepo.findById(id)).thenReturn(Optional.of(music));
        when(musicRepo.save(music)).thenReturn(music);
        doNothing().when(Log).save(any(LogModel.class));
        Runnable task = () -> appController.LikeMusicById(id);
        Thread thread1 = new Thread(task);
        Thread thread2 = new Thread(task);
        thread1.start();
        thread2.start();
        thread1.join();
        thread2.join();
        assertEquals(7, music.getNumberOfLikes());
        verify(Log, times(2)).save(any(LogModel.class));
    }
    @Test
    @Tag("integration")
    public void likeMusicWithSaveFailure() {
        int id = 1;
        MusicModel music = new MusicModel();
        music.setNumberOfLikes(5);
        when(musicRepo.findById(id)).thenReturn(Optional.of(music));
        when(musicRepo.save(music)).thenThrow(new RuntimeException("Save failed"));
        assertThrows(RuntimeException.class, () -> appController.LikeMusicById(id));
        verify(Log, never()).save(any(LogModel.class));
    }
    @Test
    @Tag("integration")
    public void likeMusicWithLogSaveFailure() {
        int id = 1;
        MusicModel music = new MusicModel();
        music.setNumberOfLikes(5);
        when(musicRepo.findById(id)).thenReturn(Optional.of(music));
        when(musicRepo.save(music)).thenReturn(music);
        doThrow(new RuntimeException("Log save failed")).when(Log).save(any(LogModel.class));
        assertThrows(RuntimeException.class, () -> appController.LikeMusicById(id));
        assertEquals(6, music.getNumberOfLikes());
    }
}