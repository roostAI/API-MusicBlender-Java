    @Test
    @Tag("integration")
    public void testConcurrentLikeMusicIncrementsProperly() {
        int testId = 79;
        MusicModel musicStub = mock(MusicModel.class);
        when(musicRepo.findById(testId)).thenReturn(musicStub);
        when(musicStub.getNumberOfLikes()).thenReturn(20);
        doNothing().when(musicStub).setNumberOfLikes(anyInt());
        doNothing().when(musicRepo).save(any(MusicModel.class));
        when(Date.getTimeNow()).thenReturn("2024-06-06T12:00:00");
        doNothing().when(Log).save(any(LogModel.class));
        int initialLikes = 20;
        int concurrentCalls = 3;
        for (int i = 0; i < concurrentCalls; i++) {
            when(musicStub.getNumberOfLikes()).thenReturn(initialLikes + i);
            appController.LikeMusicById(testId);
            verify(musicStub).setNumberOfLikes(initialLikes + i + 1);
        }
        verify(musicRepo, times(concurrentCalls)).save(musicStub);
    }
