    public void testLikeMusicByIdDoesNotAffectCommentsRepository() {
        int id = 20;
        doThrow(new RuntimeException("Should not call CommentsRepo")).when(CommentsRepo).save(any());
        MusicModel music = mock(MusicModel.class);
        when(musicRepo.findById(id)).thenReturn(music);
        when(music.getNumberOfLikes()).thenReturn(1);
        doNothing().when(music).setNumberOfLikes(2);
        when(Date.getTimeNow()).thenReturn((Object)System.currentTimeMillis());
        doNothing().when(musicRepo).save(music);
        doNothing().when(Log).save(any(LogModel.class));
        String result = appController.LikeMusicById(id);
        assertEquals("Música Alterada!", result);
        verify(CommentsRepo, never()).save(any());
    }
    // Scenario 20
    @Test
    @Tag("valid")
    public void testLikeMusicByIdDateInstanceIsStateless() {
        int idA = 21;
        int idB = 22;
        MusicModel musicA = mock(MusicModel.class);
        MusicModel musicB = mock(MusicModel.class);
        when(musicRepo.findById(idA)).thenReturn(musicA);
        when(musicA.getNumberOfLikes()).thenReturn(10);
        doNothing().when(musicA).setNumberOfLikes(11);
        when(musicRepo.findById(idB)).thenReturn(musicB);
        when(musicB.getNumberOfLikes()).thenReturn(20);
        doNothing().when(musicB).setNumberOfLikes(21);
        when(Date.getTimeNow()).thenReturn((Object)123L, (Object)456L);
        doNothing().when(Log).save(any(LogModel.class));
        doNothing().when(musicRepo).save(any(MusicModel.class));
        appController.LikeMusicById(idA);
        appController.LikeMusicById(idB);
        // LogModel Date mustn't retain state between the two calls (stateless time provider)
        // There should not be any retained log info in Date
        // As Date is a LogModel, it must not accumulate logData
        // No assertions needed except that LikeMusicById works correctly on both calls
        assertTrue(true); // Method executed as expected.
    }
}