package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.MusicModel;
import com.medeiros.SPRINGProject.algorithm.algorithmBlender;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.Mockito.*;
import com.medeiros.SPRINGProject.Models.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

public class AppControllerShowMusicsTest {
    @InjectMocks
    private AppController appController;
    @Mock
    private MusicRepository musicRepo; // Changed from MusicRepo to MusicRepository
    @Mock
    private algorithmBlender ab;
    @BeforeEach
    public void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void showMusicsReturnsNonNullMap() {
        when(musicRepo.findAll()).thenReturn(new ArrayList<MusicModel>());
        when(ab.algorithmCalc(any())).thenReturn(new HashMap<>());
        Map<String, Integer> result = appController.showMusics();
        assertNotNull(result);
    }
    @Test
    @Tag("valid")
    public void showMusicsReturnsExpectedSizeMap() {
        List<MusicModel> musicList = Arrays.asList(new MusicModel(), new MusicModel());
        when(musicRepo.findAll()).thenReturn(musicList);
        Map<String, Integer> expectedMap = new HashMap<>();
        expectedMap.put("Music1", 1);
        expectedMap.put("Music2", 2);
        when(ab.algorithmCalc(any())).thenReturn(expectedMap);
        Map<String, Integer> result = appController.showMusics();
        assertEquals((Integer) 2, result.size()); // Type casting for assertion
    }
    @Test
    @Tag("valid")
    public void showMusicsHandlesEmptyRepository() {
        when(musicRepo.findAll()).thenReturn(new ArrayList<>());
        when(ab.algorithmCalc(any())).thenReturn(new HashMap<>());
        Map<String, Integer> result = appController.showMusics();
        assertEquals((Integer) 0, result.size()); // Type casting for assertion
    }
    @Test
    @Tag("integration")
    public void showMusicsCallsAlgorithmCalcWithCorrectParameters() {
        List<MusicModel> musicList = Arrays.asList(new MusicModel(), new MusicModel());
        when(musicRepo.findAll()).thenReturn(musicList);
        when(ab.algorithmCalc(any())).thenReturn(new HashMap<>());
        appController.showMusics();
        verify(ab).algorithmCalc(musicList);
    }
    @Test
    @Tag("valid")
    public void showMusicsReturnsMapWithCorrectValues() {
        List<MusicModel> musicList = Arrays.asList(new MusicModel("Song1", 1), new MusicModel("Song2", 2)); // Assuming MusicModel has a constructor
        when(musicRepo.findAll()).thenReturn(musicList);
        Map<String, Integer> expectedMap = new HashMap<>();
        expectedMap.put("Song1", 1);
        expectedMap.put("Song2", 2);
        when(ab.algorithmCalc(any())).thenReturn(expectedMap);
        Map<String, Integer> result = appController.showMusics();
        assertEquals(expectedMap, result);
    }
}