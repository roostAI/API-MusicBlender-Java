import java.util.ArrayList;
import java.util.Collections;
import java.util.HashMap;
import java.util.Map;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

@SpringBootTest
@ExtendWith(MockitoExtension.class)
class AppControllerShowMusicsTest {
    @Mock
    private MusicRepository musicRepo;
    @Mock
    private algorithmBlender ab;
    @InjectMocks
    private AppController appController;
    // Add mock MusicModel for testing
    private MusicModel createMusicModel(String name, int count) {
        MusicModel model = new MusicModel();
        model.setName(name); 
        model.setCount(count);
        return model;
    }
    @BeforeEach
    void setUp() {
        // Common setup if needed
    }
    @Test
    @Tag("valid")
    void retrieveEmptyMusicList() {
        // Arrange
        when(musicRepo.findAll()).thenReturn(Collections.emptyList());
        when(ab.algorithmCalc(any())).thenReturn(new HashMap<>());
        // Act
        Map<String, Integer> result = appController.showMusics();
        // Assert
        assertNotNull(result);
        assertTrue(result.isEmpty());
        verify(musicRepo).findAll();
        verify(ab).algorithmCalc(any());
    }
    @Test
    @Tag("valid") 
    void retrieveSingleMusicEntry() {
        // Arrange
        ArrayList<MusicModel> musicList = new ArrayList<>();
        musicList.add(createMusicModel("Test Song", 1));
        
        Map<String, Integer> expectedMap = new HashMap<>();
        expectedMap.put("Test Song", 1);
        when(musicRepo.findAll()).thenReturn(musicList);
        when(ab.algorithmCalc(musicList)).thenReturn(expectedMap);
        // Act
        Map<String, Integer> result = appController.showMusics();
        // Assert
        assertNotNull(result);
        assertEquals(1, result.size());
        assertEquals(1, result.get("Test Song"));
        verify(musicRepo).findAll();
        verify(ab).algorithmCalc(musicList);
    }
    @Test
    @Tag("integration")
    void retrieveMultipleMusicEntries() {
        // Arrange
        ArrayList<MusicModel> musicList = new ArrayList<>();
        musicList.add(createMusicModel("Song 1", 1));
        musicList.add(createMusicModel("Song 2", 2));
        
        Map<String, Integer> expectedMap = new HashMap<>();
        expectedMap.put("Song 1", 1);
        expectedMap.put("Song 2", 2);
        when(musicRepo.findAll()).thenReturn(musicList);
        when(ab.algorithmCalc(musicList)).thenReturn(expectedMap);
        // Act
        Map<String, Integer> result = appController.showMusics();
        // Assert
        assertNotNull(result);
        assertEquals(2, result.size());
        assertEquals(1, result.get("Song 1"));
        assertEquals(2, result.get("Song 2"));
        verify(musicRepo).findAll();
        verify(ab).algorithmCalc(musicList);
    }
    @Test
    @Tag("invalid")
    void handleNullReturnFromRepository() {
        // Arrange
        when(musicRepo.findAll()).thenReturn(null);
        when(ab.algorithmCalc(null)).thenReturn(new HashMap<>());
        // Act
        Map<String, Integer> result = appController.showMusics();
        // Assert
        assertNotNull(result);
        assertTrue(result.isEmpty());
        verify(musicRepo).findAll();
        verify(ab).algorithmCalc(null);
    }
}