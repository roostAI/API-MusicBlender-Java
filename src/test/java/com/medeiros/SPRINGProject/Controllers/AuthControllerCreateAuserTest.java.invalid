package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.*;
import com.medeiros.SPRINGProject.Security.JwtUtil;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.web.bind.annotation.*;
import java.util.Objects;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;

@SpringBootTest
public class AuthControllerCreateAuserTest {
    @Autowired
    private AuthController authController;
    @MockBean
    private UserAccRepository userAccRepo;
    @MockBean
    private LogRepository log;
    @Test
    @Tag("valid")
    public void testSuccessfulUserRegistration() {
        String email = "test@gmail.com";
        String password = "password123";
        String confirmPassword = "password123";
        String username = "testUser";
        when(userAccRepo.save(any(User_Credentials.class))).thenReturn(new User_Credentials(email, password, username));
        when(log.save(any(LogModel.class))).thenReturn(new LogModel("createUser01", "User", Date.getTimeNow()));
        String result = authController.createAuser(email, password, confirmPassword, username);
        assertEquals("Sucesso", result);
    }
    @Test
    @Tag("invalid")
    public void testMismatchingPasswordAndConfirmPassword() {
        String email = "test@gmail.com";
        String password = "password123";
        String confirmPassword = "wrongPassword123";
        String username = "testUser";
        String result = authController.createAuser(email, password, confirmPassword, username);
        assertEquals("Senhas não batem!", result);
    }
    @Test
    @Tag("boundary")
    public void testRegistrationWithExistingEmail() {
        String email = "test@gmail.com";
        String password = "password123";
        String confirmPassword = "password123";
        String username = "testUser";
        when(userAccRepo.findUserByEmail(email)).thenReturn(new User_Credentials(email, password, username));
        String result = authController.createAuser(email, password, confirmPassword, username);
        assertNotEquals("Sucesso", result);
    }
}