@SpringBootTest
public class AuthControllerCreateAuserTest {
    @InjectMocks
    private AuthController authController;
    @Mock
    private UserAccRepository userAccRepo; // Corrected the class name
    @Mock
    private LogRepository log; // Corrected the class name
    @Test
    @Tag("valid")
    public void testSuccessfulUserRegistration() {
        String email = "test@test.com";
        String password = "password";
        String confirmPassword = "password";
        String username = "testUser";
        when(userAccRepo.save(Mockito.any(User_Credentials.class))).thenReturn(new User_Credentials(email, password, username));
        when(log.save(Mockito.any(LogModel.class))).thenReturn(new LogModel("createUser01", "User", LogModel.getTimeNow())); // Corrected the class name
        String result = authController.createAuser(email, password, confirmPassword, username);
        assertEquals("Sucesso", result);
    }
    @Test
    @Tag("invalid")
    public void testUnsuccessfulUserRegistrationDueToPasswordMismatch() {
        String email = "test@test.com";
        String password = "password";
        String confirmPassword = "differentPassword";
        String username = "testUser";
        String result = authController.createAuser(email, password, confirmPassword, username);
        assertEquals("Senhas não batem!", result);
    }
    @Test
    @Tag("boundary")
    public void testUnsuccessfulUserRegistrationDueToDatabaseSaveFailure() {
        String email = "test@test.com";
        String password = "password";
        String confirmPassword = "password";
        String username = "testUser";
        when(userAccRepo.save(Mockito.any(User_Credentials.class))).thenThrow(new RuntimeException());
        String result = authController.createAuser(email, password, confirmPassword, username);
        assertNotEquals("Sucesso", result);
    }
