package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.LogModel;
import com.medeiros.SPRINGProject.Models.User_Credentials;
import com.medeiros.SPRINGProject.Repository.LogRepository;
import com.medeiros.SPRINGProject.Repository.UserAccRepository;
import com.medeiros.SPRINGProject.Security.JwtUtil;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.ArgumentCaptor;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Objects;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.*;
import com.medeiros.SPRINGProject.Models.*;

@ExtendWith(MockitoExtension.class)
class AuthControllerCreateAuserTest {
    @Mock
    private UserAccRepository UserAccRepo;
    @Mock
    private LogRepository Log;
    @Mock
    private LogModel Date; // Mocked as it's a field in the controller
    @InjectMocks
    private AuthController authController;
    @Test
    void testCreateAuser_Success() {
        // Arrange
        String email = "test@example.com";
        String password = "password123";
        String username = "testuser";
        // Act
        String result = authController.createAuser(email, password, password, username);
        // Assert
        assertEquals("Sucesso", result);
        ArgumentCaptor<User_Credentials> userCaptor = ArgumentCaptor.forClass(User_Credentials.class);
        verify(UserAccRepo, times(1)).save(userCaptor.capture());
        User_Credentials capturedUser = userCaptor.getValue();
        assertEquals(email, capturedUser.getEmail());
        assertEquals(password, capturedUser.getPassword());
        assertEquals(username, capturedUser.getUsername());
        verify(Log, times(1)).save(any(LogModel.class));
    }
    @Test
    void testCreateAuser_PasswordMismatch() {
        // Arrange
        String email = "test@example.com";
        String password = "password123";
        String confirmPassword = "password456";
        String username = "testuser";
        // Act
        String result = authController.createAuser(email, password, confirmPassword, username);
        // Assert
        assertEquals("Senhas não batem!", result);
        verify(UserAccRepo, never()).save(any(User_Credentials.class));
        verify(Log, never()).save(any(LogModel.class));
    }
}