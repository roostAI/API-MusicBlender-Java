    @BeforeEach
    void setUp() {
        MockitoAnnotations.initMocks(this);
        authController = new AuthController();
        injectMocks(authController, jwtToken, userAccRepo, userInfoRepo, log, mockDate);
    }
    private void injectMocks(AuthController controller,
                            JwtUtil jwtUtil,
                            UserAccRepository userAccRep,
                            UserInfoRepository userInfoRep,
                            LogRepository logRepo,
                            LogModel logDate) {
        try {
            java.lang.reflect.Field jwtTokenField = AuthController.class.getDeclaredField("JwtToken");
            jwtTokenField.setAccessible(true);
            jwtTokenField.set(controller, jwtUtil);
            java.lang.reflect.Field userAccRepoField = AuthController.class.getDeclaredField("UserAccRepo");
            userAccRepoField.setAccessible(true);
            userAccRepoField.set(controller, userAccRep);
            java.lang.reflect.Field userInfoRepoField = AuthController.class.getDeclaredField("UserInfoRepo");
            userInfoRepoField.setAccessible(true);
            userInfoRepoField.set(controller, userInfoRep);
            java.lang.reflect.Field logField = AuthController.class.getDeclaredField("Log");
            logField.setAccessible(true);
            logField.set(controller, logRepo);
            java.lang.reflect.Field dateField = AuthController.class.getDeclaredField("Date");
            dateField.setAccessible(true);
            dateField.set(controller, logDate);
        } catch (Exception e) {
            throw new RuntimeException("Injection failed", e);
        }
    }
    @Test
    @Tag("invalid")
    public void testPasswordMismatchReturnsErrorMessage() {
        String email = "test@mail.com";
        String password = "pass123";
        String confirmPassword = "diffpass";
        String username = "user";
        String result = authController.createAuser(email, password, confirmPassword, username);
        assertEquals((String) "Senhas não batem!", (String) result);
    }
    @Test
    @Tag("valid")
    public void testSuccessfulUserRegistrationReturnsSuccessMessage() {
        String email = "user@example.com";
        String password = "securePassword";
        String confirmPassword = "securePassword";
        String username = "username";
        // Suggestion: LogModel.getTimeNow should be a public method for mocking
        when(((LogModel)mockDate).getTimeNow()).thenReturn("2024-01-01T10:00:00Z");
        String result = authController.createAuser(email, password, confirmPassword, username);
        assertEquals((String) "Sucesso", (String) result);
    }
    @Test
    @Tag("integration")
    public void testUserCredentialsSavedToUserAccRepo() {
        String email = "saveuser@mail.com";
        String password = "pwd";
        String confirmPassword = "pwd";
        String username = "saveuser";
        when(((LogModel)mockDate).getTimeNow()).thenReturn("2024-01-02T12:00:00Z");
        authController.createAuser(email, password, confirmPassword, username);
        ArgumentCaptor<User_Credentials> userCredCaptor = ArgumentCaptor.forClass(User_Credentials.class);
        verify(userAccRepo, times(1)).save(userCredCaptor.capture());
        User_Credentials savedCred = userCredCaptor.getValue();
        assertEquals((String) email, (String) savedCred.getEmail());
        assertEquals((String) password, (String) savedCred.getPassword());
        assertEquals((String) username, (String) savedCred.getUsername());
    }
    @Test
    @Tag("integration")
    public void testLogEntrySavedWithCorrectLogModel() {
        String email = "loguser@mail.com";
        String password = "logpwd";
        String confirmPassword = "logpwd";
        String username = "loguser";
        String logTimestamp = "2024-01-03T09:00:00Z";
        when(((LogModel)mockDate).getTimeNow()).thenReturn(logTimestamp);
        authController.createAuser(email, password, confirmPassword, username);
        ArgumentCaptor<LogModel> logModelCaptor = ArgumentCaptor.forClass(LogModel.class);
        verify(log, times(1)).save(logModelCaptor.capture());
        LogModel logSaved = logModelCaptor.getValue();
        // Suggestion: LogModel class must have getAction(), getType(), getTimestamp() methods for these assertions to work. If those methods are missing, suggest adding them.
        // Comment: If LogModel does not have these getter methods, please add public getters for action, type and timestamp in LogModel class.
