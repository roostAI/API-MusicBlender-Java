        ArgumentCaptor<LogModel> logCaptor = ArgumentCaptor.forClass(LogModel.class);
        verify(userAccRepoMock, times(1)).save(userCaptor.capture());
        verify(logRepoMock, times(1)).save(logCaptor.capture());
