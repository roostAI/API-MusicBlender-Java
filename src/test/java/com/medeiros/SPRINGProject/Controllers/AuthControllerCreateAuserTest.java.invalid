        try {
            java.lang.reflect.Field actionField = LogModel.class.getDeclaredField("action");
            actionField.setAccessible(true);
            java.lang.reflect.Field typeField = LogModel.class.getDeclaredField("type");
            typeField.setAccessible(true);
            java.lang.reflect.Field timestampField = LogModel.class.getDeclaredField("timestamp");
            timestampField.setAccessible(true);
            assertEquals((String) "createUser01", (String) actionField.get(logSaved));
            assertEquals((String) "User", (String) typeField.get(logSaved));
            assertNotNull((String) timestampField.get(logSaved));
            assertEquals((String) logTimestamp, (String) timestampField.get(logSaved));
        } catch (NoSuchFieldException | IllegalAccessException e) {
            fail("LogModel does not expose fields for validation.");
        }
    }
