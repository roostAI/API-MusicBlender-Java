package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.User_Credentials;
import com.medeiros.SPRINGProject.Models.UserAccRepository;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.Mockito.when;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.*;
import com.medeiros.SPRINGProject.Security.JwtUtil;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Objects;

public class AuthControllerLoginUserTest {
    @Test
    @Tag("valid")
    public void testSuccessfulLogin() {
        UserAccRepository mockRepo = Mockito.mock(UserAccRepository.class);
        User_Credentials mockUser = new User_Credentials("test@test.com", "password", "username");
        when(mockRepo.findUserByEmail("test@test.com")).thenReturn(mockUser);
        AuthController controller = new AuthController(mockRepo);
        String result = controller.loginUser("test@test.com", "password");
        assertEquals("Logado", result);
    }
    @Test
    @Tag("invalid")
    public void testIncorrectPassword() {
        UserAccRepository mockRepo = Mockito.mock(UserAccRepository.class);
        User_Credentials mockUser = new User_Credentials("test@test.com", "password", "username");
        when(mockRepo.findUserByEmail("test@test.com")).thenReturn(mockUser);
        AuthController controller = new AuthController(mockRepo);
        String result = controller.loginUser("test@test.com", "wrongpassword");
        assertEquals("Senha incorreta", result);
    }
    @Test
    @Tag("invalid")
    public void testNonexistentEmail() {
        UserAccRepository mockRepo = Mockito.mock(UserAccRepository.class);
        when(mockRepo.findUserByEmail("nonexistent@test.com")).thenReturn(null);
        AuthController controller = new AuthController(mockRepo);
        String result = controller.loginUser("nonexistent@test.com", "password");
        assertEquals("Email não encontrado!", result);
    }
    @Test
    @Tag("boundary")
    public void testNullEmail() {
        UserAccRepository mockRepo = Mockito.mock(UserAccRepository.class);
        AuthController controller = new AuthController(mockRepo);
        String result = controller.loginUser(null, "password");
        assertEquals("Email não encontrado!", result);
    }
    @Test
    @Tag("boundary")
    public void testNullPassword() {
        UserAccRepository mockRepo = Mockito.mock(UserAccRepository.class);
        User_Credentials mockUser = new User_Credentials("test@test.com", "password", "username");
        when(mockRepo.findUserByEmail("test@test.com")).thenReturn(mockUser);
        AuthController controller = new AuthController(mockRepo);
        String result = controller.loginUser("test@test.com", null);
        assertEquals("Senha incorreta", result);
    }
}