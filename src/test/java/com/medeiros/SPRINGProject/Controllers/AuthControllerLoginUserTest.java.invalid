package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.User_Credentials;
import com.medeiros.SPRINGProject.Models.UserAccRepository;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.Mockito.when;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.*;
import com.medeiros.SPRINGProject.Security.JwtUtil;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Objects;

public class AuthControllerLoginUserTest {
    @Test
    @Tag("valid")
    public void testValidLogin() {
        UserAccRepository userAccRepo = Mockito.mock(UserAccRepository.class);
        User_Credentials user = new User_Credentials("test@test.com", "password", "username");
        when(userAccRepo.findUserByEmail("test@test.com")).thenReturn(user);
        AuthController authController = new AuthController(userAccRepo);
        String result = authController.loginUser("test@test.com", "password");
        assertEquals("Logado", result);
    }
    @Test
    @Tag("invalid")
    public void testLoginWithWrongPassword() {
        UserAccRepository userAccRepo = Mockito.mock(UserAccRepository.class);
        User_Credentials user = new User_Credentials("test@test.com", "password", "username");
        when(userAccRepo.findUserByEmail("test@test.com")).thenReturn(user);
        AuthController authController = new AuthController(userAccRepo);
        String result = authController.loginUser("test@test.com", "wrongpassword");
        assertEquals("Senha incorreta", result);
    }
    @Test
    @Tag("invalid")
    public void testLoginWithNonexistentEmail() {
        UserAccRepository userAccRepo = Mockito.mock(UserAccRepository.class);
        when(userAccRepo.findUserByEmail("test@test.com")).thenReturn(null);
        AuthController authController = new AuthController(userAccRepo);
        String result = authController.loginUser("test@test.com", "password");
        assertEquals("Email não encontrado!", result);
    }
}