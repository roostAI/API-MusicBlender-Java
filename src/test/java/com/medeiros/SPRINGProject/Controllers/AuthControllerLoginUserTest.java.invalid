package com.medeiros.SPRINGProject.Controllers;
import com.medeiros.SPRINGProject.Models.User_Credentials;
import com.medeiros.SPRINGProject.Repo.UserAccRepo;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.Mockito.when;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.*;
import com.medeiros.SPRINGProject.Security.JwtUtil;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.util.Objects;

// TODO: Adjust the import path for UserAccRepo if it's different in your project structure
@ExtendWith(MockitoExtension.class)
public class AuthControllerLoginUserTest {
    @Mock
    private UserAccRepo UserAccRepo;
    @InjectMocks
    private AuthController authController;
    @Test
    @Tag("valid")
    public void testLoginUserWithValidCredentials() {
        String email = "test@example.com";
        String password = "password123";
        User_Credentials mockUser = new User_Credentials(email, password, "testuser");
        when(UserAccRepo.findUserByEmail(email)).thenReturn(mockUser);
        String result = authController.loginUser(email, password);
        assertEquals("Logado", result);
    }
    @Test
    @Tag("invalid")
    public void testLoginUserWithIncorrectPassword() {
        String email = "test@example.com";
        String correctPassword = "correctPassword";
        String wrongPassword = "wrongPassword";
        User_Credentials mockUser = new User_Credentials(email, correctPassword, "testuser");
        when(UserAccRepo.findUserByEmail(email)).thenReturn(mockUser);
        String result = authController.loginUser(email, wrongPassword);
        assertEquals("Senha incorreta", result);
    }
    @Test
    @Tag("invalid")
    public void testLoginUserWithNonExistentEmail() {
        String email = "unknown@example.com";
        String password = "anyPassword";
        when(UserAccRepo.findUserByEmail(email)).thenReturn(null);
        String result = authController.loginUser(email, password);
        assertEquals("Email não encontrado!", result);
    }
    @Test
    @Tag("boundary")
    public void testLoginUserWithNullEmail() {
        String password = "anyPassword";
        when(UserAccRepo.findUserByEmail(null)).thenReturn(null);
        String result = authController.loginUser(null, password);
        assertEquals("Email não encontrado!", result);
    }
    @Test
    @Tag("boundary")
    public void testLoginUserWithNullPassword() {
        String email = "test@example.com";
        String storedPassword = "password123";
        User_Credentials mockUser = new User_Credentials(email, storedPassword, "testuser");
        when(UserAccRepo.findUserByEmail(email)).thenReturn(mockUser);
        String result = authController.loginUser(email, null);
        assertEquals("Senha incorreta", result);
    }
    @Test
    @Tag("boundary")
    public void testLoginUserWithEmptyEmail() {
        String email = "";
        String password = "anyPassword";
        when(UserAccRepo.findUserByEmail(email)).thenReturn(null);
        String result = authController.loginUser(email, password);
        assertEquals("Email não encontrado!", result);
    }
    @Test
    @Tag("boundary")
    public void testLoginUserWithEmptyPassword() {
        String email = "test@example.com";
        String storedPassword = "password123";
        String emptyPassword = "";
        User_Credentials mockUser = new User_Credentials(email, storedPassword, "testuser");
        when(UserAccRepo.findUserByEmail(email)).thenReturn(mockUser);
        String result = authController.loginUser(email, emptyPassword);
        assertEquals("Senha incorreta", result);
    }
    @Test
    @Tag("invalid")
    public void testLoginUserWithCaseSensitiveEmailMismatch() {
        String wrongCaseEmail = "User@example.com";
        String password = "password123";
        when(UserAccRepo.findUserByEmail(wrongCaseEmail)).thenReturn(null);
        String result = authController.loginUser(wrongCaseEmail, password);
        assertEquals("Email não encontrado!", result);
    }
}