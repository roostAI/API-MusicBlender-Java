public class AuthControllerLoginUserTest {
    @Test
    @Tag("valid")
    public void testSuccessfulLogin() {
        UserAccRepository mockRepo = Mockito.mock(UserAccRepository.class);
        User_Credentials mockUser = Mockito.mock(User_Credentials.class);
        String validEmail = "test@example.com";
        String validPassword = "password";
        when(mockRepo.findUserByEmail(validEmail)).thenReturn(mockUser);
        when(mockUser.getPassword()).thenReturn(validPassword);
        AuthController controller = new AuthController(mockRepo, null, null, null, null);
        assertEquals("Logado", controller.loginUser(validEmail, validPassword));
    }
    @Test
    @Tag("invalid")
    public void testUnsuccessfulLoginInvalidEmail() {
        UserAccRepository mockRepo = Mockito.mock(UserAccRepository.class);
        String invalidEmail = "invalid@example.com";
        when(mockRepo.findUserByEmail(invalidEmail)).thenReturn(null);
        AuthController controller = new AuthController(mockRepo, null, null, null, null);
        assertEquals("Email não encontrado!", controller.loginUser(invalidEmail, "password"));
    }
    @Test
    @Tag("invalid")
    public void testUnsuccessfulLoginIncorrectPassword() {
        UserAccRepository mockRepo = Mockito.mock(UserAccRepository.class);
        User_Credentials mockUser = Mockito.mock(User_Credentials.class);
        String validEmail = "test@example.com";
        String incorrectPassword = "incorrectPassword";
        when(mockRepo.findUserByEmail(validEmail)).thenReturn(mockUser);
        when(mockUser.getPassword()).thenReturn("password");
        AuthController controller = new AuthController(mockRepo, null, null, null, null);
        assertEquals("Senha incorreta", controller.loginUser(validEmail, incorrectPassword));
    }
    @Test
    @Tag("boundary")
    public void testUnsuccessfulLoginNullEmail() {
        UserAccRepository mockRepo = Mockito.mock(UserAccRepository.class);
        AuthController controller = new AuthController(mockRepo, null, null, null, null);
        assertEquals("Email não encontrado!", controller.loginUser(null, "password"));
    }
