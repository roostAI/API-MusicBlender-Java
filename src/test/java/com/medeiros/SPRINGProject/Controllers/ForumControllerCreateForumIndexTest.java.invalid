package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.ForumIndexModel;
import com.medeiros.SPRINGProject.Models.ForumIndexRepository;
import org.junit.Before;
import org.junit.Test;
import org.junit.experimental.categories.Category;
import org.junit.runner.RunWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import org.mockito.junit.MockitoJUnitRunner;
import static org.mockito.Mockito.*;
import static org.junit.Assert.*;
import com.medeiros.SPRINGProject.Models.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

@RunWith(MockitoJUnitRunner.class)
public class ForumControllerCreateForumIndexTest {
    @Mock
    private ForumIndexRepository forumIndexRepo;
    
    @InjectMocks
    private ForumController forumController;
    
    @Before
    public void setUp() {
        MockitoAnnotations.initMocks(this);
    }
    
    @Test
    @Category(Categories.valid.class)
    public void createForumIndexSuccessfully() {
        String nameForum = "Tech Forum";
        String forumDescription = "A forum about technology discussions";
        int userId = 1;
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        verify(forumIndexRepo, times(1)).save(any(ForumIndexModel.class));
        assertEquals("Forum criado", result);
    }
    
    @Test
    @Category(Categories.invalid.class)
    public void handleNullForumName() {
        String forumDescription = "A forum about technology discussions";
        int userId = 1;
        String result = forumController.createForumIndex(null, forumDescription, userId);
        verify(forumIndexRepo, never()).save(any(ForumIndexModel.class));
        assertNull(result);
    }
    
    @Test
    @Category(Categories.boundary.class)
    public void handleEmptyForumDescription() {
        String nameForum = "Tech Forum";
        String forumDescription = "";
        int userId = 1;
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        verify(forumIndexRepo, times(1)).save(any(ForumIndexModel.class));
        assertEquals("Forum criado", result);
    }
    
    @Test
    @Category(Categories.invalid.class)
    public void handleNegativeUserId() {
        String nameForum = "Tech Forum";
        String forumDescription = "A forum about technology discussions";
        int userId = -1;
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        verify(forumIndexRepo, never()).save(any(ForumIndexModel.class));
        assertNull(result);
    }
    
    @Test
    @Category(Categories.valid.class)
    public void verifyForumIndexModelCreation() {
        String nameForum = "Tech Forum";
        String forumDescription = "A forum about technology discussions";
        int userId = 1;
        forumController.createForumIndex(nameForum, forumDescription, userId);
        verify(forumIndexRepo, times(1)).save(argThat(forumIndexModel -> {
            ForumIndexModel model = (ForumIndexModel) forumIndexModel;
            return model.getName().equals(nameForum) &&
                   model.getUserId() == userId &&
                   model.getDescription().equals(forumDescription);
        }));
    }
}