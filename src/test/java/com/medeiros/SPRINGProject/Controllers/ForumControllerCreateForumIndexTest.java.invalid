        doNothing().when(ForumIndexRepo).save(any(ForumIndexModel.class));
        String actualResult = forumController.createForumIndex(nameForum, forumDescription, userId);
        verify(ForumIndexRepo).save(captor.capture());
        ForumIndexModel savedModel = captor.getValue();
        assertEquals(nameForum, (String) savedModel.getNameForum());
        assertEquals(userId, (int) savedModel.getOwnerId());
        assertEquals(forumDescription, (String) savedModel.getForumDescription());
        assertEquals(userId, (int) savedModel.getUserId());
        assertEquals("Forum criado", (String) actualResult);
    }
