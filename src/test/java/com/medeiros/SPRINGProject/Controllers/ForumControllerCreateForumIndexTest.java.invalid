    @Test
    @Tag("valid")
    public void testCreateForumWithValidInputs() {
        String nameForum = "Spring Boot Help";
        String forumDescription = "A forum for Spring Boot discussions";
        int userId = 42;
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        ArgumentCaptor<ForumIndexModel> captor = ArgumentCaptor.forClass(ForumIndexModel.class);
        verify(ForumIndexRepo, times(1)).save(captor.capture());
        ForumIndexModel saved = (ForumIndexModel) captor.getValue();
        assertEquals("Forum criado", (String) result);
        assertEquals((String) nameForum, (String) saved.getName());
        assertEquals((int) userId, (int) saved.getUserId());
        assertEquals((String) forumDescription, (String) saved.getForumDescription());
        // Note: Using .getName(), .getUserId(), .getForumDescription() based on constructor parameters
    }
