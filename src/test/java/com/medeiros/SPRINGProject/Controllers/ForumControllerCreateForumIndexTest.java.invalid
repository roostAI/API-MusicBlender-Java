    // Scenario 1: Creating a Forum Index with Valid Data
    @Test
    @Tag("valid")
    public void testCreateForumIndexWithValidInput() {
        String nameForum = "General Discussion";
        String forumDescription = "All topics";
        int userId = 123;
        String result = controller.createForumIndex(nameForum, forumDescription, userId);
        ArgumentCaptor<ForumIndexModel> captor = ArgumentCaptor.forClass(ForumIndexModel.class);
        verify(ForumIndexRepo, times(1)).save(captor.capture());
        ForumIndexModel saved = captor.getValue();
        assertEquals("Forum criado", (String) result);
        assertEquals((String) nameForum, (String) saved.getName());
        assertEquals((int) userId, (int) saved.getUserId());
        assertEquals((String) forumDescription, (String) saved.getForumDescription());
        assertEquals((int) userId, (int) saved.getAdmin());
    }
