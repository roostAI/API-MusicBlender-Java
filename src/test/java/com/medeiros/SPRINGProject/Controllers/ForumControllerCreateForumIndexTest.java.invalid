    @Test
    @Tag("valid")
    public void testForumCreatedWithValidParameters() {
        String nameForum = "Test Forum";
        String forumDescription = "A valid description";
        int userId = 1;
        ArgumentCaptor<ForumIndexModel> captor = ArgumentCaptor.forClass(ForumIndexModel.class);
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        assertEquals((String) "Forum criado", (String) result);
        verify(ForumIndexRepo, times(1)).save(captor.capture());
        ForumIndexModel savedModel = (ForumIndexModel) captor.getValue();
        assertEquals((String) nameForum, (String) savedModel.getNameForum());
        assertEquals((String) forumDescription, (String) savedModel.getForumDescription());
        assertEquals((int) userId, (int) savedModel.getOwner());
        assertEquals((int) userId, (int) savedModel.getCreator());
    }
