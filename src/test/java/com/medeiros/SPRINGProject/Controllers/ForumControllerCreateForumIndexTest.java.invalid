@ExtendWith(MockitoExtension.class)
public class ForumControllerCreateForumIndexTest {
    @Mock
    private ForumIndexRepository forumIndexRepo;
    @InjectMocks
    private ForumController forumController;
    @BeforeEach
    public void setUp() {
        // Setup code if needed
    }
    @Test
    @Tag("valid")
    public void successfulCreationOfForumIndex() {
        // Arrange
        String nameForum = "Test Forum";
        String forumDescription = "This is a test forum description.";
        int userId = 1;
        // Act
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        // Assert
        assertEquals("Forum criado", result);
        verify(forumIndexRepo, times(1)).save(any(ForumIndexModel.class));
    }
    @Test
    @Tag("invalid")
    public void handleNullForumName() {
        // Arrange
        String nameForum = null;
        String forumDescription = "This is a test forum description.";
        int userId = 1;
        // Act & Assert
        assertThrows(IllegalArgumentException.class, () -> {
            forumController.createForumIndex(nameForum, forumDescription, userId);
        });
    }
    @Test
    @Tag("boundary")
    public void handleEmptyForumDescription() {
        // Arrange
        String nameForum = "Test Forum";
        String forumDescription = "";
        int userId = 1;
        // Act
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        // Assert
        assertEquals("Forum criado", result);
        verify(forumIndexRepo, times(1)).save(any(ForumIndexModel.class));
    }
    @Test
    @Tag("invalid")
    public void handleInvalidUserId() {
        // Arrange
        String nameForum = "Test Forum";
        String forumDescription = "This is a test forum description.";
        int userId = -1; // Invalid userId
        // Act & Assert
        assertThrows(IllegalArgumentException.class, () -> {
            forumController.createForumIndex(nameForum, forumDescription, userId);
        });
    }
    @Test
    @Tag("invalid")
    public void handleDuplicateForumName() {
        // Arrange
        String nameForum = "Duplicate Forum";
        String forumDescription = "This is a test forum description.";
        int userId = 1;
