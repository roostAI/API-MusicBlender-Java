import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

@ExtendWith(MockitoExtension.class)
class ForumControllerCreateForumIndexTest {
    @Mock
    private ForumIndexRepo ForumIndexRepo;
    @InjectMocks
    private ForumController forumController;
    @Test
    @Tag("valid")
    void createForumIndexWithValidInputs() {
        // Arrange
        String nameForum = "Java Discussion";
        String forumDescription = "A place to discuss all things Java";
        int userId = 101;
        // Act
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        // Assert
        assertEquals("Forum criado", result);
        verify(ForumIndexRepo).save(any(ForumIndexModel.class));
    }
    @Test
    @Tag("boundary")
    void createForumIndexWithEmptyName() {
        // Arrange
        String nameForum = "";
        String forumDescription = "Valid Description";
        int userId = 102;
        ArgumentCaptor<ForumIndexModel> forumCaptor = ArgumentCaptor.forClass(ForumIndexModel.class);
        // Act
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        // Assert
        assertEquals("Forum criado", result);
        verify(ForumIndexRepo).save(forumCaptor.capture());
        ForumIndexModel capturedForum = forumCaptor.getValue();
        assertEquals("", capturedForum.nameForum);
    }
    @Test
    @Tag("boundary")
    void createForumIndexWithEmptyDescription() {
        // Arrange
        String nameForum = "Valid Name";
        String forumDescription = "";
        int userId = 103;
        ArgumentCaptor<ForumIndexModel> forumCaptor = ArgumentCaptor.forClass(ForumIndexModel.class);
        // Act
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        // Assert
        assertEquals("Forum criado", result);
        verify(ForumIndexRepo).save(forumCaptor.capture());
        ForumIndexModel capturedForum = forumCaptor.getValue();
        assertEquals("", capturedForum.forumDescription);
    }
    @Test
    @Tag("boundary")
    void createForumIndexWithZeroUserId() {
        // Arrange
        String nameForum = "System Forum";
        String forumDescription = "For system use";
        int userId = 0;
        ArgumentCaptor<ForumIndexModel> forumCaptor = ArgumentCaptor.forClass(ForumIndexModel.class);
        // Act
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        // Assert
        assertEquals("Forum criado", result);
        verify(ForumIndexRepo).save(forumCaptor.capture());
        ForumIndexModel capturedForum = forumCaptor.getValue();
        assertEquals(0, capturedForum.creatorId);
        assertEquals(0, capturedForum.lastPostUserId);
    }
    @Test
    @Tag("invalid")
    void createForumIndexWithNegativeUserId() {
        // Arrange
        String nameForum = "Negative Test";
        String forumDescription = "Testing negative ID";
        int userId = -1;
        ArgumentCaptor<ForumIndexModel> forumCaptor = ArgumentCaptor.forClass(ForumIndexModel.class);
        // Act
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        // Assert
        assertEquals("Forum criado", result);
        verify(ForumIndexRepo).save(forumCaptor.capture());
        ForumIndexModel capturedForum = forumCaptor.getValue();
        assertEquals(-1, capturedForum.creatorId);
        assertEquals(-1, capturedForum.lastPostUserId);
    }
    @Test
    @Tag("integration")
    void createForumIndexVerifiesCorrectDataIsPassedToRepository() {
        // Arrange
        String nameForum = "Specific Name";
        String forumDescription = "Specific Description";
        int userId = 999;
        ArgumentCaptor<ForumIndexModel> forumCaptor = ArgumentCaptor.forClass(ForumIndexModel.class);
        // Act
        forumController.createForumIndex(nameForum, forumDescription, userId);
        // Assert
        verify(ForumIndexRepo).save(forumCaptor.capture());
        ForumIndexModel capturedForum = forumCaptor.getValue();
        assertEquals("Specific Name", capturedForum.nameForum);
        assertEquals("Specific Description", capturedForum.forumDescription);
        assertEquals(999, capturedForum.creatorId);
