    @Test
    @Tag("boundary")
    public void testForumCreatedWithExtraLongStrings() {
        StringBuilder sbForum = new StringBuilder();
        StringBuilder sbDesc = new StringBuilder();
        for (int i = 0; i < 10000; i++) {
            sbForum.append('a');
            sbDesc.append('b');
        }
        String nameForum = sbForum.toString(); // Extra-long name
        String forumDescription = sbDesc.toString(); // Extra-long description
        int userId = 8;
        ArgumentCaptor<ForumIndexModel> captor = ArgumentCaptor.forClass(ForumIndexModel.class);
        String result = forumController.createForumIndex(nameForum, forumDescription, userId);
        assertEquals((String) "Forum criado", (String) result);
        verify(ForumIndexRepo, times(1)).save(captor.capture());
        ForumIndexModel savedModel = (ForumIndexModel) captor.getValue();
        assertEquals((String) nameForum, (String) savedModel.getNameForum());
        assertEquals((String) forumDescription, (String) savedModel.getForumDescription());
        assertEquals((int) userId, (int) savedModel.getOwner());
        assertEquals((int) userId, (int) savedModel.getCreator());
    }
    @Test
    @Tag("integration")
    public void testMultipleForumIndexesCreatedInSuccession() {
        String[] forumNames = { "Forum A", "Forum B", "Forum C" };
        String[] forumDescriptions = { "Description A", "Description B", "Description C" };
        int[] userIds = { 10, 11, 12 };
        ArgumentCaptor<ForumIndexModel> captor = ArgumentCaptor.forClass(ForumIndexModel.class);
        for (int i = 0; i < forumNames.length; i++) {
            String result = forumController.createForumIndex(forumNames[i], forumDescriptions[i], userIds[i]);
            assertEquals((String) "Forum criado", (String) result);
        }
        verify(ForumIndexRepo, times(forumNames.length)).save(captor.capture());
        java.util.List<ForumIndexModel> allModels = captor.getAllValues();
        for (int i = 0; i < forumNames.length; i++) {
            ForumIndexModel savedModel = (ForumIndexModel) allModels.get(i);
            assertEquals((String) forumNames[i], (String) savedModel.getNameForum());
            assertEquals((String) forumDescriptions[i], (String) savedModel.getForumDescription());
            assertEquals((int) userIds[i], (int) savedModel.getOwner());
            assertEquals((int) userIds[i], (int) savedModel.getCreator());
        }
    }
