package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.ForumChatModel;
import com.medeiros.SPRINGProject.Models.ChatRepository;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.beans.factory.annotation.Autowired;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertThrows;
import com.medeiros.SPRINGProject.Models.*;
import org.springframework.web.bind.annotation.*;

@SpringBootTest
public class ForumControllerNewMessageTest {
    @MockBean
    private ChatRepository chatRepository;
    @Autowired
    private ForumController forumController;
    
    @Test
    @Tag("valid")
    public void testNewMessageSaveFunctionality() {
        String mockMessage = "Test message";
        int mockUserId = 1;
        int mockForumId = 1;
        Mockito.when(chatRepository.save(Mockito.any(ForumChatModel.class))).thenReturn(new ForumChatModel(mockMessage, mockUserId, mockForumId));
        String returnedMessage = forumController.newMessage(mockMessage, mockUserId, mockForumId);
        assertEquals(mockMessage, returnedMessage);
    }
    
    @Test
    @Tag("invalid")
    public void testNewMessageWithNullMessage() {
        String nullMessage = null;
        int mockUserId = 1;
        int mockForumId = 1;
        Mockito.when(chatRepository.save(Mockito.any(ForumChatModel.class))).thenReturn(null);
        String returnedMessage = forumController.newMessage(nullMessage, mockUserId, mockForumId);
        assertEquals(null, returnedMessage);
    }
    
    @Test
    @Tag("invalid")
    public void testNewMessageWithInvalidUserId() {
        String mockMessage = "Test message";
        int invalidUserId = -1;
        int mockForumId = 1;
        Mockito.when(chatRepository.save(Mockito.any(ForumChatModel.class))).thenThrow(new IllegalArgumentException());
        assertThrows(IllegalArgumentException.class, () -> forumController.newMessage(mockMessage, invalidUserId, mockForumId));
    }
    
    @Test
    @Tag("invalid")
    public void testNewMessageWithInvalidForumId() {
        String mockMessage = "Test message";
        int mockUserId = 1;
        int invalidForumId = -1;
        Mockito.when(chatRepository.save(Mockito.any(ForumChatModel.class))).thenThrow(new IllegalArgumentException());
        assertThrows(IllegalArgumentException.class, () -> forumController.newMessage(mockMessage, mockUserId, invalidForumId));
    }
}