    @Tag("valid")
    @Test
    public void testValidMessageIsSavedAndReturned() {
        String message = "Hello Forum!";
        int userId = 42;
        int forumId = 7;
        ForumChatModel expectedModel = new ForumChatModel(message, userId, forumId);
        doNothing().when(chatRepository).save(any(ForumChatModel.class));
        String result = forumController.newMessage(message, userId, forumId);
        ArgumentCaptor<ForumChatModel> captor = ArgumentCaptor.forClass(ForumChatModel.class);
        verify(chatRepository, times(1)).save(captor.capture());
        ForumChatModel actualModel = captor.getValue();
        assertEquals((String)expectedModel.getMessage(), (String)actualModel.getMessage());
        assertEquals((int)expectedModel.getUserId(), (int)actualModel.getUserId());
        assertEquals((int)expectedModel.getForumId(), (int)actualModel.getForumId());
        assertEquals((String)message, (String)result);
    }
