package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.ForumChatModel;
import com.medeiros.SPRINGProject.Repositories.ChatRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.web.bind.annotation.*;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Autowired;
import com.medeiros.SPRINGProject.Models.*;

 // Added missing import
@ExtendWith(MockitoExtension.class)
class ForumControllerNewMessageTest {
    @Mock
    private ChatRepository chatRepository;
    @InjectMocks 
    private ForumController forumController;
    private static final String TEST_MESSAGE = "Test message";
    private static final int TEST_USER_ID = 1;
    private static final int TEST_FORUM_ID = 1;
    @BeforeEach
    void setUp() {
        when(chatRepository.save(any(ForumChatModel.class))).thenReturn(new ForumChatModel(TEST_MESSAGE, TEST_USER_ID, TEST_FORUM_ID));
    }
    @Test
    @Tag("valid")
    void successfulMessageCreation() {
        String result = forumController.newMessage(TEST_MESSAGE, TEST_USER_ID, TEST_FORUM_ID);
        assertEquals(TEST_MESSAGE, result);
        verify(chatRepository, times(1)).save(any(ForumChatModel.class));
    }
    @Test
    @Tag("invalid")
    void newMessageWithEmptyMessage() {
        assertThrows(IllegalArgumentException.class, () -> 
            forumController.newMessage("", TEST_USER_ID, TEST_FORUM_ID)
        );
    }
    @Test
    @Tag("boundary")
    void newMessageWithMaxLengthMessage() {
        String maxLengthMessage = "a".repeat(255);
        String result = forumController.newMessage(maxLengthMessage, TEST_USER_ID, TEST_FORUM_ID);
        assertEquals(maxLengthMessage, result);
        verify(chatRepository, times(1)).save(any(ForumChatModel.class));
    }
    @Test
    @Tag("invalid")
    void newMessageWithInvalidUserId() {
        assertThrows(IllegalArgumentException.class, () ->
            forumController.newMessage(TEST_MESSAGE, -1, TEST_FORUM_ID)
        );
    }
    @Test
    @Tag("invalid") 
    void newMessageWithInvalidForumId() {
        assertThrows(IllegalArgumentException.class, () ->
            forumController.newMessage(TEST_MESSAGE, TEST_USER_ID, -1)
        );
    }
    @Test
    @Tag("integration")
    void newMessagePersistenceVerification() {
        ForumChatModel expectedModel = new ForumChatModel(TEST_MESSAGE, TEST_USER_ID, TEST_FORUM_ID);
        
        forumController.newMessage(TEST_MESSAGE, TEST_USER_ID, TEST_FORUM_ID);
        
        verify(chatRepository).save(argThat(actualModel -> {
            ForumChatModel model = (ForumChatModel) actualModel; // Added cast
            return model.getMessage().equals(expectedModel.getMessage()) &&
                   model.getUserId() == expectedModel.getUserId() &&
                   model.getForumId() == expectedModel.getForumId();
        }));
    }
}