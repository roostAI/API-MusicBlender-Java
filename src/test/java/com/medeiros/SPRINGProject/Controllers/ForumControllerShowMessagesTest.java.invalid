package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.*;
import com.medeiros.SPRINGProject.Repositories.ChatRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.boot.test.context.SpringBootTest;
import java.util.ArrayList;
import java.util.List;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

 // Added missing import
@SpringBootTest
@ExtendWith(MockitoExtension.class)
class ForumControllerShowMessagesTest {
    @Mock
    private ChatRepository chatRepository;
    @InjectMocks 
    private ForumController forumController;
    @BeforeEach
    void setUp() {
        // Initialize test data if needed
    }
    @Test
    @Tag("valid")
    void retrieveExistingMessages() {
        // Arrange
        List<ForumChatModel> expectedMessages = new ArrayList<>();
        expectedMessages.add(new ForumChatModel("Message 1", 1, 1));
        expectedMessages.add(new ForumChatModel("Message 2", 2, 1));
        when(chatRepository.findAll()).thenReturn(expectedMessages);
        // Act
        Iterable<ForumChatModel> actualMessages = forumController.showMessages();
        // Assert
        assertIterableEquals(expectedMessages, actualMessages);
        verify(chatRepository, times(1)).findAll();
    }
    @Test
    @Tag("valid") 
    void retrieveEmptyMessageList() {
        // Arrange
        List<ForumChatModel> emptyList = new ArrayList<>();
        when(chatRepository.findAll()).thenReturn(emptyList);
        // Act
        Iterable<ForumChatModel> result = forumController.showMessages();
        // Assert
        assertNotNull(result);
        assertFalse(result.iterator().hasNext());
        verify(chatRepository, times(1)).findAll();
    }
    @Test
    @Tag("invalid")
    void handleRepositoryException() {
        // Arrange
        when(chatRepository.findAll()).thenThrow(new RuntimeException("Database error"));
        // Act & Assert
        assertThrows(RuntimeException.class, () -> forumController.showMessages());
        verify(chatRepository, times(1)).findAll();
    }
    @Test
    @Tag("valid")
    void preserveMessageOrder() {
        // Arrange
        List<ForumChatModel> orderedMessages = new ArrayList<>();
        orderedMessages.add(new ForumChatModel("First", 1, 1));
        orderedMessages.add(new ForumChatModel("Second", 2, 1));
        orderedMessages.add(new ForumChatModel("Third", 3, 1));
        when(chatRepository.findAll()).thenReturn(orderedMessages);
        // Act
        Iterable<ForumChatModel> result = forumController.showMessages();
        // Assert
        List<ForumChatModel> resultList = new ArrayList<>();
        result.forEach(resultList::add);
        assertEquals(orderedMessages.size(), resultList.size());
        for(int i = 0; i < orderedMessages.size(); i++) {
            assertEquals(orderedMessages.get(i).getMessage(), resultList.get(i).getMessage());
        }
        verify(chatRepository, times(1)).findAll();
    }
}