package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.LogModel;
import com.medeiros.SPRINGProject.Models.LogRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.boot.test.context.SpringBootTest;
import java.util.Arrays;
import java.util.List;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

@SpringBootTest
@ExtendWith(MockitoExtension.class)
class LogControllerShowAllLogTest {
    @Mock
    private LogRepository Log;
    @InjectMocks
    private LogController logController;
    private List<LogModel> sampleLogs;
    @BeforeEach
    void setUp() {
        // Create log entries using constructor instead of setters
        LogModel log1 = new LogModel(1L, "Test Log 1");
        LogModel log2 = new LogModel(2L, "Test Log 2");
        sampleLogs = Arrays.asList(log1, log2);
    }
    @Test
    @Tag("valid")
    void retrieveExistingLogs() {
        // Arrange
        when(Log.findAll()).thenReturn(sampleLogs);
        // Act
        Iterable<LogModel> result = logController.showAllLog();
        // Assert
        assertNotNull(result);
        List<LogModel> resultList = (List<LogModel>) result;
        assertEquals(2, resultList.size());
        
        // Using direct object comparison instead of getter methods
        assertEquals(sampleLogs.get(0), resultList.get(0));
        assertEquals(sampleLogs.get(1), resultList.get(1));
        
        verify(Log, times(1)).findAll();
    }
    @Test
    @Tag("boundary")
    void retrieveEmptyLogList() {
        // Arrange
        when(Log.findAll()).thenReturn(Arrays.asList());
        // Act
        Iterable<LogModel> result = logController.showAllLog();
        // Assert
        assertNotNull(result);
        assertFalse(result.iterator().hasNext());
        verify(Log, times(1)).findAll();
    }
    @Test
    @Tag("invalid")
    void handleRepositoryException() {
        // Arrange
        when(Log.findAll()).thenThrow(new RuntimeException("Database error"));
        // Act & Assert
        assertThrows(RuntimeException.class, () -> {
            logController.showAllLog();
        });
        verify(Log, times(1)).findAll();
    }
}