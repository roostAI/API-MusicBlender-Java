package com.medeiros.SPRINGProject.Controllers;
import com.medeiros.SPRINGProject.Models.ProductModel;
import com.medeiros.SPRINGProject.Models.ProductModelRepository;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import java.util.ArrayList;
import java.util.List;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.LogModel;
import com.medeiros.SPRINGProject.Models.LogRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

@SpringBootTest
public class MarketControllerShowAllProductsTest {
    @MockBean
    private ProductModelRepository productModelRepository;
    @Test
    @Tag("valid")
    public void testShowAllProductsReturnsAllProducts() {
        MarketController controller = new MarketController();
        List<ProductModel> expectedProducts = new ArrayList<>();
        expectedProducts.add(new ProductModel("description", 100.0, 1, 1, "listProduct"));
        when(productModelRepository.findAll()).thenReturn(expectedProducts);
        Iterable<ProductModel> actualProducts = controller.showAllProducts();
        verify(productModelRepository, times(1)).findAll();
        assertEquals(expectedProducts, actualProducts);
    }
    @Test
    @Tag("boundary")
    public void testShowAllProductsHandlesEmptyRepository() {
        MarketController controller = new MarketController();
        when(productModelRepository.findAll()).thenReturn(new ArrayList<>());
        Iterable<ProductModel> actualProducts = controller.showAllProducts();
        verify(productModelRepository, times(1)).findAll();
        assertTrue(!actualProducts.iterator().hasNext());
    }
    @Test
    @Tag("boundary")
    public void testShowAllProductsHandlesNullReturn() {
        MarketController controller = new MarketController();
        when(productModelRepository.findAll()).thenReturn(null);
        Iterable<ProductModel> actualProducts = controller.showAllProducts();
        verify(productModelRepository, times(1)).findAll();
        assertNull(actualProducts);
    }
    @Test
    @Tag("invalid")
    public void testShowAllProductsHandlesExceptions() {
        MarketController controller = new MarketController();
        when(productModelRepository.findAll()).thenThrow(new RuntimeException());
        assertThrows(RuntimeException.class, () -> controller.showAllProducts());
        verify(productModelRepository, times(1)).findAll();
    }
}