package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.LogModel;
import com.medeiros.SPRINGProject.Models.LogRepository;
import com.medeiros.SPRINGProject.Models.ProductModel;
import com.medeiros.SPRINGProject.Models.ProductModelRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import java.util.ArrayList;
import java.util.List;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;
import java.util.concurrent.TimeUnit;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;

public class MarketControllerShowAllProductsTest {
    @Mock
    private ProductModelRepository ProductRepository;
    @InjectMocks
    private MarketController marketController;
    @BeforeEach
    public void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void showAllProductsReturnsAllProducts() {
        List<ProductModel> products = new ArrayList<>();
        products.add(new ProductModel(1, "Product1", 10.0, 1, 1, "List1"));
        products.add(new ProductModel(2, "Product2", 20.0, 2, 2, "List2"));
        when(ProductRepository.findAll()).thenReturn(products);
        Iterable<ProductModel> result = marketController.showAllProducts();
        assertEquals(products, (List<ProductModel>) result);
    }
    @Test
    @Tag("valid")
    public void showAllProductsHandlesEmptyRepository() {
        when(ProductRepository.findAll()).thenReturn(new ArrayList<>());
        Iterable<ProductModel> result = marketController.showAllProducts();
        assertTrue(((List<ProductModel>) result).isEmpty());
    }
    @Test
    @Tag("valid")
    public void showAllProductsReturnsProductsInCorrectOrder() {
        List<ProductModel> products = new ArrayList<>();
        products.add(new ProductModel(1, "Product1", 10.0, 1, 1, "List1"));
        products.add(new ProductModel(2, "Product2", 20.0, 2, 2, "List2"));
        when(ProductRepository.findAll()).thenReturn(products);
        Iterable<ProductModel> result = marketController.showAllProducts();
        assertEquals(products, (List<ProductModel>) result);
    }
    @Test
    @Tag("invalid")
    public void showAllProductsHandlesNullRepository() {
        when(ProductRepository.findAll()).thenReturn(null);
        Iterable<ProductModel> result = marketController.showAllProducts();
        assertNull(result);
    }
    @Test
    @Tag("valid")
    public void showAllProductsAfterDeletingProducts() {
        List<ProductModel> products = new ArrayList<>();
        products.add(new ProductModel(1, "Product1", 10.0, 1, 1, "List1"));
        products.add(new ProductModel(2, "Product2", 20.0, 2, 2, "List2"));
        when(ProductRepository.findAll()).thenReturn(products);
        marketController.deleteProduct(1);
        Iterable<ProductModel> result = marketController.showAllProducts();
        assertEquals(1, ((List<ProductModel>) result).size());
    }
    @Test
    @Tag("valid")
    public void showAllProductsAfterUpdatingProducts() {
        List<ProductModel> products = new ArrayList<>();
        products.add(new ProductModel(1, "Product1", 10.0, 1, 1, "List1"));
        products.add(new ProductModel(2, "Product2", 20.0, 2, 2, "List2"));
        when(ProductRepository.findAll()).thenReturn(products);
        marketController.createProduct(3, "UpdatedProduct", 30.0, 3, 3, "List3");
        Iterable<ProductModel> result = marketController.showAllProducts();
        assertEquals(3, ((List<ProductModel>) result).size());
    }
    @Test
    @Tag("integration")
    public void showAllProductsHandlesConcurrentAccess() throws InterruptedException {
        List<ProductModel> products = new ArrayList<>();
        products.add(new ProductModel(1, "Product1", 10.0, 1, 1, "List1"));
        products.add(new ProductModel(2, "Product2", 20.0, 2, 2, "List2"));
        when(ProductRepository.findAll()).thenReturn(products);
        ExecutorService executor = Executors.newFixedThreadPool(10);
        for (int i = 0; i < 10; i++) {
            executor.submit(() -> {
                Iterable<ProductModel> result = marketController.showAllProducts();
                assertEquals(products, (List<ProductModel>) result);
            });
        }
        executor.shutdown();
        executor.awaitTermination(1, TimeUnit.MINUTES);
    }
    @Test
    @Tag("valid")
    public void showAllProductsReturnsProductsWithCorrectFields() {
        List<ProductModel> products = new ArrayList<>();
        products.add(new ProductModel(1, "Product1", 10.0, 1, 1, "List1"));
        products.add(new ProductModel(2, "Product2", 20.0, 2, 2, "List2"));
        when(ProductRepository.findAll()).thenReturn(products);
        Iterable<ProductModel> result = marketController.showAllProducts();
        for (ProductModel product : result) {
            assertNotNull(product.getDescription());
            assertTrue(product.getPrice() > 0);
            assertTrue(product.getMusicId() > 0);
            assertTrue(product.getUserId() > 0);
            assertNotNull(product.getListProduct());
        }
    }
    @Test
    @Tag("valid")
    public void showAllProductsReturnsProductsWithCorrectTypes() {
        List<ProductModel> products = new ArrayList<>();
        products.add(new ProductModel(1, "Product1", 10.0, 1, 1, "List1"));
        products.add(new ProductModel(2, "Product2", 20.0, 2, 2, "List2"));
        when(ProductRepository.findAll()).thenReturn(products);
        Iterable<ProductModel> result = marketController.showAllProducts();
        for (ProductModel product : result) {
            assertTrue(product.getDescription() instanceof String);
            assertTrue(product.getPrice() instanceof Double);
            assertTrue(product.getMusicId() instanceof Integer);
            assertTrue(product.getUserId() instanceof Integer);
            assertTrue(product.getListProduct() instanceof String);
        }
    }
    @Test
    @Tag("boundary")
    public void showAllProductsHandlesLargeNumberOfProducts() {
        List<ProductModel> products = new ArrayList<>();
        for (int i = 0; i < 10000; i++) {
            products.add(new ProductModel(i, "Product" + i, 10.0 * i, i, i, "List" + i));
        }
        when(ProductRepository.findAll()).thenReturn(products);
        long startTime = System.currentTimeMillis();
        Iterable<ProductModel> result = marketController.showAllProducts();
        long endTime = System.currentTimeMillis();
        assertEquals(products, (List<ProductModel>) result);
        assertTrue(endTime - startTime < 5000); // TODO: Adjust the acceptable time frame as needed
    }
}