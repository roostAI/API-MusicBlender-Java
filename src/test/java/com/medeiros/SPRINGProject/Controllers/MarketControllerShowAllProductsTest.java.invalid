    @Nested
    @Tag("valid")
    class ValidTests {
        @Test
        @Tag("valid")
        public void testShowAllProductsReturnsAllItems() {
            ProductModel product1 = new ProductModel("description1", 10.0, 1, 100, "listA");
            ProductModel product2 = new ProductModel("description2", 20.0, 2, 101, "listB");
            ProductModel product3 = new ProductModel("description3", 30.0, 3, 102, "listC");
            List<ProductModel> mockProducts = Arrays.asList(product1, product2, product3);
            when(productRepository.findAll()).thenReturn((Iterable<ProductModel>) mockProducts);
            Iterable<ProductModel> actualProducts = marketController.showAllProducts();
            List<ProductModel> actualList = new ArrayList<>();
            actualProducts.forEach(actualList::add);
            assertEquals((int)mockProducts.size(), (int)actualList.size(), "Should retrieve all products from repository");
            assertTrue(actualList.contains(product1), "Should contain product1");
            assertTrue(actualList.contains(product2), "Should contain product2");
            assertTrue(actualList.contains(product3), "Should contain product3");
        }
        @Test
        @Tag("boundary")
        public void testShowAllProductsReturnsEmptyListWhenNoProductsExist() {
            List<ProductModel> emptyList = Collections.emptyList();
            when(productRepository.findAll()).thenReturn((Iterable<ProductModel>) emptyList);
            Iterable<ProductModel> actualProducts = marketController.showAllProducts();
            List<ProductModel> actualList = new ArrayList<>();
            actualProducts.forEach(actualList::add);
            assertTrue(((List<ProductModel>)actualList).isEmpty(), "Should return empty list when repository has no products");
        }
        @Test
        @Tag("boundary")
        public void testShowAllProductsHandlesVariousProductModels() {
            ProductModel edgeProduct1 = new ProductModel("", 0.0, Integer.MIN_VALUE, Integer.MAX_VALUE, "!@#$%^&*");
            ProductModel edgeProduct2 = new ProductModel(" ", Double.MAX_VALUE, 99999, 0, "edgeCase");
            ProductModel edgeProduct3 = new ProductModel("description", Double.MIN_VALUE, -1, -1, ""); // boundary values
            List<ProductModel> products = Arrays.asList(edgeProduct1, edgeProduct2, edgeProduct3);
            when(productRepository.findAll()).thenReturn((Iterable<ProductModel>) products);
            Iterable<ProductModel> actualProducts = marketController.showAllProducts();
            List<ProductModel> actualList = new ArrayList<>();
            actualProducts.forEach(actualList::add);
            assertEquals((int)products.size(), (int)actualList.size(), "All edge products should be returned");
            assertTrue(actualList.contains(edgeProduct1), "Contains product with empty description and boundary values");
            assertTrue(actualList.contains(edgeProduct2), "Contains product with max price and unusual values");
            assertTrue(actualList.contains(edgeProduct3), "Contains product with min values");
        }
        @Test
        @Tag("valid")
        public void testShowAllProductsReturnsIterableOfProductModel() {
            ProductModel product = new ProductModel("desc", 1.5, 1, 2, "listX");
            List<ProductModel> products = Collections.singletonList(product);
            when(productRepository.findAll()).thenReturn((Iterable<ProductModel>) products);
            Iterable<ProductModel> result = marketController.showAllProducts();
            assertTrue((result instanceof Iterable), "Returned object is an Iterable");
            assertNotNull(result, "Result should not be null");
            Iterator<?> iter = result.iterator();
            assertTrue(iter.hasNext(), "Iterable should contain product");
            assertTrue((iter.next() instanceof ProductModel), "Iterable contains ProductModel objects");
        }
        @Test
        @Tag("valid")
        public void testShowAllProductsIsIdempotent() {
            ProductModel productA = new ProductModel("descA", 11.0, 42, 31, "listZ");
            ProductModel productB = new ProductModel("descB", 22.0, 43, 32, "listZ");
            List<ProductModel> products = Arrays.asList(productA, productB);
            when(productRepository.findAll()).thenReturn((Iterable<ProductModel>) products);
            Iterable<ProductModel> result1 = marketController.showAllProducts();
            Iterable<ProductModel> result2 = marketController.showAllProducts();
            List<ProductModel> list1 = new ArrayList<>();
            List<ProductModel> list2 = new ArrayList<>();
            result1.forEach(list1::add);
            result2.forEach(list2::add);
            assertEquals(list1, list2, "Repeated calls should return identical collections");
        }
    }
