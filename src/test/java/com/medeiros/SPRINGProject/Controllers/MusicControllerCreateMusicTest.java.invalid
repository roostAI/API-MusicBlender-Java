package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.MusicModel;
import com.medeiros.SPRINGProject.Models.MusicRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.LogModel;
import com.medeiros.SPRINGProject.Models.LogRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

@ExtendWith(MockitoExtension.class)
class MusicControllerCreateMusicTest {
    @Mock
    private MusicRepository MusicRepo;
    @InjectMocks
    private MusicController musicController;
    private MusicModel expectedMusic;
    
    @BeforeEach
    void setUp() {
        expectedMusic = new MusicModel(1, "Test Song", "Test Music Content", "Test Description");
    }
    @Test
    @Tag("valid")
    void createMusicWithValidParameters() {
        // Arrange
        when(MusicRepo.save(any(MusicModel.class))).thenReturn(expectedMusic);
        // Act
        String result = musicController.createMusic(
            "Test Description",
            "Test Song",
            "Test Music Content",
            1
        );
        // Assert
        verify(MusicRepo, times(1)).save(any(MusicModel.class));
        assertEquals("Operação Feita", result);
    }
    @Test
    @Tag("boundary")
    void createMusicWithEmptyStrings() {
        // Act
        String result = musicController.createMusic("", "", "", 1);
        // Assert
        verify(MusicRepo, times(1)).save(any(MusicModel.class));
        assertEquals("Operação Feita", result);
    }
    @Test
    @Tag("boundary") 
    void createMusicWithZeroUserId() {
        // Act
        String result = musicController.createMusic(
            "Test Description",
            "Test Song",
            "Test Music Content",
            0
        );
        // Assert
        verify(MusicRepo, times(1)).save(any(MusicModel.class));
        assertEquals("Operação Feita", result);
    }
    @Test
    @Tag("integration")
    void createMusicVerifyModelCreation() {
        // Arrange
        when(MusicRepo.save(any(MusicModel.class))).thenAnswer(i -> i.getArguments()[0]);
        // Act
        musicController.createMusic(
            "Test Description",
            "Test Song", 
            "Test Music Content",
            1
        );
        // Assert
        verify(MusicRepo).save(argThat(music -> 
            music.getUserId() == 1 &&  // Changed getUserid() to getUserId()
            music.getMusicName().equals("Test Song") &&
            music.getMusic().equals("Test Music Content") &&
            music.getMusicDescription().equals("Test Description")
        ));
    }
}