        ArgumentCaptor<MusicModel> captor = ArgumentCaptor.forClass(MusicModel.class);
        verify(mockMusicRepo).save(captor.capture());
        MusicModel saved = captor.getValue();
        // There is no public 'Userid' field. Use constructor args/getters if present.
