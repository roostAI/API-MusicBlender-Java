    // Scenario 13
    @Test
    @Tag("integration")
    public void testHandleMultipleConcurrentCalls() throws Exception {
        int threads = 5;
        ExecutorService executor = Executors.newFixedThreadPool(threads);
        CountDownLatch startLatch = new CountDownLatch(1);
        CountDownLatch doneLatch = new CountDownLatch(threads);
        doNothing().when(mockMusicRepo).save(any(MusicModel.class));
        String musicDesc = "Concurrent";
        for (int t = 0; t < threads; t++) {
            final int userId = 1100 + t;
            executor.submit(() -> {
                try {
                    startLatch.await();
                    String result = controller.createMusic(musicDesc, "ConcurrentName" + userId, "ConcurrentMusic" + userId, userId);
                    assertEquals("Operação Feita", result);
                } catch (Exception e) {
                    fail("Exception in concurrent execution: " + e.getMessage());
                } finally {
                    doneLatch.countDown();
                }
            });
        }
        startLatch.countDown(); // release all threads
        doneLatch.await(); // wait for completion
        verify(mockMusicRepo, times(threads)).save(any(MusicModel.class));
        executor.shutdown();
    }
