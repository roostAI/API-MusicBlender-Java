package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.LogModel;
import com.medeiros.SPRINGProject.Models.LogRepository;
import com.medeiros.SPRINGProject.Models.MusicModel;
import com.medeiros.SPRINGProject.Models.MusicRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import org.springframework.beans.factory.annotation.Autowired;
import java.util.Optional;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import org.springframework.web.bind.annotation.*;

class MusicControllerDeleteMusicTest {
    @Mock
    private MusicRepository MusicRepo;
    @Mock
    private LogRepository LogRepo;
    @InjectMocks
    private MusicController musicController;
    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    void deleteMusicValidId() {
        int musicId = 1;
        MusicModel musicModel = new MusicModel();
        when(MusicRepo.findById(musicId)).thenReturn(Optional.of(musicModel));
        String result = musicController.deleteMusic(musicId);
        assertEquals("Deletado", result);
        verify(MusicRepo, times(1)).deleteById(musicId);
    }
    @Test
    @Tag("invalid")
    void deleteMusicNonExistentId() {
        int musicId = 2;
        when(MusicRepo.findById(musicId)).thenReturn(Optional.empty());
        String result = musicController.deleteMusic(musicId);
        assertEquals("Deletado", result);
        verify(MusicRepo, times(1)).deleteById(musicId);
    }
    @Test
    @Tag("integration")
    void deleteMusicLogsDeletion() {
        int musicId = 3;
        MusicModel musicModel = new MusicModel();
        when(MusicRepo.findById(musicId)).thenReturn(Optional.of(musicModel));
        String result = musicController.deleteMusic(musicId);
        assertEquals("Deletado", result);
        verify(LogRepo, times(1)).save(any(LogModel.class));
    }
    @Test
    @Tag("invalid")
    void deleteMusicNullId() {
        String result = musicController.deleteMusic(0);
        assertEquals("Deletado", result);
        verify(MusicRepo, never()).deleteById(anyInt());
    }
    @Test
    @Tag("valid")
    void deleteMusicDoesNotAffectOtherEntries() {
        int musicId = 4;
        int otherMusicId = 5;
        MusicModel musicModel = new MusicModel();
        when(MusicRepo.findById(musicId)).thenReturn(Optional.of(musicModel));
        when(MusicRepo.findById(otherMusicId)).thenReturn(Optional.of(musicModel));
        String result = musicController.deleteMusic(musicId);
        assertEquals("Deletado", result);
        verify(MusicRepo, times(1)).deleteById(musicId);
        verify(MusicRepo, never()).deleteById(otherMusicId);
    }
    @Test
    @Tag("boundary")
    void deleteMusicLastEntry() {
        int musicId = 6;
        MusicModel musicModel = new MusicModel();
        when(MusicRepo.findById(musicId)).thenReturn(Optional.of(musicModel));
        String result = musicController.deleteMusic(musicId);
        assertEquals("Deletado", result);
        verify(MusicRepo, times(1)).deleteById(musicId);
    }
    @Test
    @Tag("integration")
    void deleteMusicConcurrentRequests() throws InterruptedException {
        int musicId = 7;
        MusicModel musicModel = new MusicModel();
        when(MusicRepo.findById(musicId)).thenReturn(Optional.of(musicModel));
        Runnable deleteTask = () -> musicController.deleteMusic(musicId);
        Thread thread1 = new Thread(deleteTask);
        Thread thread2 = new Thread(deleteTask);
        thread1.start();
        thread2.start();
        thread1.join();
        thread2.join();
        verify(MusicRepo, times(2)).deleteById(musicId);
    }
}