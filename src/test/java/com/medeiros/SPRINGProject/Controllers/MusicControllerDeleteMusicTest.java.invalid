@ExtendWith(MockitoExtension.class)
public class MusicControllerDeleteMusicTest {
    @Mock
    private MusicRepository MusicRepo;
    @InjectMocks
    private MusicController musicController;
    @Test
    @Tag("valid")
    public void testDeleteMusicWithValidId() {
        // Arrange
        int id = 1;
        MusicModel music = new MusicModel();
        music.setMusicName("MusicName");
        music.setMusic("Music");
        music.setMusicDescription("MusicDescription");
        when(MusicRepo.findById(id)).thenReturn(Optional.of(music));
        // Act
        String result = musicController.deleteMusic(id);
        // Assert
        verify(MusicRepo, times(1)).deleteById(id);
        assertEquals("Deletado", result);
    }
}