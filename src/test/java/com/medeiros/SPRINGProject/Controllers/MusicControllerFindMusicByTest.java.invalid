package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.MusicModel;
import com.medeiros.SPRINGProject.Models.MusicRepository;
import org.junit.jupiter.api.AfterEach;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.junit.jupiter.api.Assertions.assertNull;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.LogModel;
import com.medeiros.SPRINGProject.Models.LogRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

public class MusicControllerFindMusicByTest {
    private MusicRepository MusicRepo;
    private MusicController MusicController;
    
    @BeforeEach
    public void setUp() {
        MusicRepo = Mockito.mock(MusicRepository.class);
        MusicController = new MusicController();
        MusicController.setMusicRepo(MusicRepo); // This is assuming there is a setter method in MusicController for MusicRepository
    }
    
    @AfterEach
    public void tearDown() {
        MusicRepo = null;
        MusicController = null;
    }
    
    @Test
    @Tag("valid")
    public void testFindMusicById() {
        MusicModel expected = new MusicModel(1, "Test Music", "Test Music File", "Test Description");
        Mockito.when(MusicRepo.findById(1)).thenReturn(expected);
        MusicModel actual = MusicController.findMusicBy(1);
        assertEquals(expected, actual);
    }
    
    @Test
    @Tag("invalid")
    public void testFindMusicByNonExistingId() {
        Mockito.when(MusicRepo.findById(999)).thenReturn(null);
        MusicModel actual = MusicController.findMusicBy(999);
        assertNull(actual);
    }
    
    @Test
    @Tag("boundary")
    public void testFindMusicByNegativeId() {
        Exception exception = assertThrows(IllegalArgumentException.class, () -> {
            MusicController.findMusicBy(-1);
        });
        assertEquals("Id must be a positive integer", exception.getMessage());
    }
}