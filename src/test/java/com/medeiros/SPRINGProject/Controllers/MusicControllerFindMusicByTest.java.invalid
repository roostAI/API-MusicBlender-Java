    @Test
    @Tag("valid")
    public void testRepositoryReturnsIncompleteMusicModel() {
        int id = 44;
        MusicModel incompleteMusic = new MusicModel();
        incompleteMusic.id = id;
        incompleteMusic.MusicName = null;
        incompleteMusic.Music = "data";
        incompleteMusic.MusicDescription = null;
        Mockito.when(mockMusicRepository.findById(id)).thenReturn(incompleteMusic);
        MusicModel actualMusic = (MusicModel) musicController.findMusicBy(id);
        Assertions.assertEquals(incompleteMusic, actualMusic);
