    @Test
    @Tag("integration")
    public void testFindMusicByConsistentResultsForMultipleIds() {
        int id1 = 1, id2 = 2, id3 = 3;
        MusicModel music1 = new MusicModel(id1, "Song1", "Music1", "Desc1");
        MusicModel music2 = new MusicModel(id2, "Song2", "Music2", "Desc2");
        MusicModel music3 = new MusicModel(id3, "Song3", "Music3", "Desc3");
        when(mockMusicRepo.findById(id1)).thenReturn(music1);
        when(mockMusicRepo.findById(id2)).thenReturn(music2);
