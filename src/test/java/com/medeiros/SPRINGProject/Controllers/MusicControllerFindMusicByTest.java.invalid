    // ---------- Scenario 1: Retrieval of an existing music record by a valid ID ----------
    @Test
    @Tag("valid")
    public void testRetrieveExistingMusicById() {
        int validId = 1;
        MusicModel expectedMusic = new MusicModel(validId, "TestName", "TestMusic", "TestDesc");
        when(MusicRepo.findById(validId)).thenReturn(expectedMusic);
        MusicModel actualMusic = musicController.findMusicBy(validId);
        assertEquals((MusicModel)expectedMusic, (MusicModel)actualMusic, "The returned MusicModel should be equal to the expected MusicModel for existing ID.");
    }
    // ---------- Scenario 2: Handling of a non-existent music record by ID ----------
    @Test
