        when(MusicRepo.findById(nonExistentId)).thenReturn(null);
        MusicModel result = musicController.findMusicBy(nonExistentId);
        assertNull(result, "Should return null for a non-existent music record ID");
    }
    // ---------- Scenario 3: Verification with boundary ID value (e.g., zero) ----------
