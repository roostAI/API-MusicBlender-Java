package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.LogModel;
import com.medeiros.SPRINGProject.Models.LogRepository;
import com.medeiros.SPRINGProject.Models.MusicModel;
import com.medeiros.SPRINGProject.Models.MusicRepository;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Assertions;
import org.mockito.Mockito;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

public class MusicControllerFindMusicByTest {
    @Mock
    private LogRepository mockLogRepository;
    @Mock
    private MusicRepository mockMusicRepository;
    @InjectMocks
    private MusicController musicController;
    private LogModel logModel = new LogModel();
    @BeforeEach
    public void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void testValidIdReturnsExistingMusicModel() {
        int validId = 10;
        MusicModel expectedMusic = new MusicModel();
        expectedMusic.id = validId;
        expectedMusic.MusicName = "SongName";
        expectedMusic.Music = "SongData";
        expectedMusic.MusicDescription = "SongDescription";
        Mockito.when(mockMusicRepository.findById(validId)).thenReturn(expectedMusic);
        MusicModel actualMusic = (MusicModel) musicController.findMusicBy(validId);
        Assertions.assertEquals(expectedMusic, actualMusic);
    }
    @Test
    @Tag("invalid")
    public void testNonExistentIdReturnsNull() {
        int nonExistentId = 999;
        Mockito.when(mockMusicRepository.findById(nonExistentId)).thenReturn(null);
        MusicModel actualMusic = (MusicModel) musicController.findMusicBy(nonExistentId);
        Assertions.assertNull(actualMusic);
    }
    @Test
    @Tag("invalid")
    public void testNegativeIdReturnsNull() {
        int negativeId = -5;
        Mockito.when(mockMusicRepository.findById(negativeId)).thenReturn(null);
        MusicModel actualMusic = (MusicModel) musicController.findMusicBy(negativeId);
        Assertions.assertNull(actualMusic);
    }
    @Test
    @Tag("boundary")
    public void testZeroIdReturnsNull() {
        int zeroId = 0;
        Mockito.when(mockMusicRepository.findById(zeroId)).thenReturn(null);
        MusicModel actualMusic = (MusicModel) musicController.findMusicBy(zeroId);
        Assertions.assertNull(actualMusic);
    }
    @Test
    @Tag("integration")
    public void testRepositoryThrowsException() {
        int testId = 123;
        Mockito.when(mockMusicRepository.findById(testId)).thenThrow(new RuntimeException("Repo failure"));
        Assertions.assertThrows(RuntimeException.class, () -> {
            musicController.findMusicBy(testId);
        });
    }
    @Test
    @Tag("boundary")
    public void testLargeIdValueReturnsNull() {
        int largeId = Integer.MAX_VALUE;
        Mockito.when(mockMusicRepository.findById(largeId)).thenReturn(null);
        MusicModel actualMusic = (MusicModel) musicController.findMusicBy(largeId);
        Assertions.assertNull(actualMusic);
    }
    @Test
    @Tag("integration")
    public void testMusicRepositoryIsNullThrowsException() {
        int id = 5;
        MusicController controllerWithNullRepo = new MusicController();
        controllerWithNullRepo.Log = mockLogRepository;
        controllerWithNullRepo.MusicRepo = null; // Simulate DI failure
        Assertions.assertThrows(NullPointerException.class, () -> {
            controllerWithNullRepo.findMusicBy(id);
        });
    }
    @Test
    @Tag("valid")
    public void testMultipleCallsWithDifferentIds() {
        int id1 = 1;
        int id2 = 2;
        int id3 = 3;
        MusicModel music1 = new MusicModel();
        music1.id = id1;
        music1.MusicName = "Name1";
        music1.Music = "Music1";
        music1.MusicDescription = "Desc1";
        MusicModel music2 = new MusicModel();
        music2.id = id2;
        music2.MusicName = "Name2";
        music2.Music = "Music2";
        music2.MusicDescription = "Desc2";
        MusicModel music3 = new MusicModel();
        music3.id = id3;
        music3.MusicName = "Name3";
        music3.Music = "Music3";
        music3.MusicDescription = "Desc3";
        Mockito.when(mockMusicRepository.findById(id1)).thenReturn(music1);
        Mockito.when(mockMusicRepository.findById(id2)).thenReturn(music2);
        Mockito.when(mockMusicRepository.findById(id3)).thenReturn(music3);
        MusicModel result1 = (MusicModel) musicController.findMusicBy(id1);
        MusicModel result2 = (MusicModel) musicController.findMusicBy(id2);
        MusicModel result3 = (MusicModel) musicController.findMusicBy(id3);
        Assertions.assertEquals(music1, result1);
        Assertions.assertEquals(music2, result2);
        Assertions.assertEquals(music3, result3);
    }
    @Test
    @Tag("boundary")
    public void testIdIsNegativeOneReturnsNull() {
