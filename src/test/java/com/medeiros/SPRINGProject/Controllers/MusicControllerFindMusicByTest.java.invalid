    @Test
    @Tag("valid")
    public void testFindMusicByReturnsMusicModelForExistingId() {
        int validId = 5;
        MusicModel expectedMusic = new MusicModel(validId, "TestSong", "TestMusic", "TestDescription");
        when(mockMusicRepo.findById(validId)).thenReturn(expectedMusic);
        MusicModel actualMusic = (MusicModel) musicController.findMusicBy(validId);
        assertEquals(expectedMusic, actualMusic, "Returned MusicModel should match the expected instance");
        verify(mockMusicRepo, times(1)).findById(validId);
    }
