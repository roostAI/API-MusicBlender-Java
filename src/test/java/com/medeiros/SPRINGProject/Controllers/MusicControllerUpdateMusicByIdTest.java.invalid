package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.MusicModel;
import com.medeiros.SPRINGProject.Models.MusicRepository;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.Mockito;
import org.springframework.boot.test.context.SpringBootTest;
import java.util.Optional;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.when;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.LogModel;
import com.medeiros.SPRINGProject.Models.LogRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

@SpringBootTest
public class MusicControllerUpdateMusicByIdTest {
    @InjectMocks
    MusicController musicController;
    @Mock
    MusicRepository musicRepo;
    @Test
    @Tag("valid")
    public void testUpdateMusicWithValidIdAndParameters() {
        // Arrange
        MusicModel existingMusic = new MusicModel(1, "Old Name", "Old Music", "Old Description");
        MusicModel updatedMusic = new MusicModel(1, "New Name", "New Music", "New Description");
        when(musicRepo.findById(1)).thenReturn(Optional.of(existingMusic));
        when(musicRepo.save(any(MusicModel.class))).thenAnswer(i -> i.getArguments()[0]);
        // Act
        String result = musicController.updateMusicById(1, "New Name", "New Description", "New Music");
        // Assert
        assertEquals("Música Alterada!", result);
        assertEquals(updatedMusic.getMusicName(), existingMusic.getMusicName());
        assertEquals(updatedMusic.getMusicDescription(), existingMusic.getMusicDescription());
        assertEquals(updatedMusic.getMusic(), existingMusic.getMusic());
    }
}