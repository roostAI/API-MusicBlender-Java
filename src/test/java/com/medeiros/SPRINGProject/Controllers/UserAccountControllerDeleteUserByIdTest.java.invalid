@ExtendWith(MockitoExtension.class)
@SpringBootTest
public class UserAccountControllerDeleteUserByIdTest {
    @Mock
    private UserAccountController userAccountController;
    @Mock
    private UserAccRepository userAccRepository;
    @Test
    @Tag("valid")
    public void deleteUserByIdTest() {
        User_Credentials user = new User_Credentials(); //assuming User_Credentials class has a default constructor
        user.setId("1");
        user.setEmail("test@test.com");
        user.setPassword("password");
        user.setUsername("testUser");
        when(userAccRepository.findById(1)).thenReturn(Optional.of(user));
        userAccountController.deleteUserById("1");
        verify(userAccRepository, times(1)).deleteById(1);
        assertThrows(ResponseStatusException.class, () -> userAccountController.findUserById("1"));
    }
    @Test
    @Tag("invalid")
    public void deleteNonExistentUserTest() {
        when(userAccRepository.findById(1)).thenReturn(Optional.empty());
        assertThrows(ResponseStatusException.class, () -> userAccountController.deleteUserById("1"));
    }
    @Test
    @Tag("invalid")
    public void deleteUserWithInvalidIdTest() {
        assertThrows(NumberFormatException.class, () -> userAccountController.deleteUserById("invalid_id"));
    }
}