    }
    @Test
    @Tag("valid")
    public void testSuccessfulDeletionByValidId() {
        String validId = "1";
        when(UserAccRepo.findById(1)).thenReturn(Optional.of(new User_Credentials()));
        String result = userAccountController.deleteUserById(validId);
        verify(UserAccRepo, times(1)).deleteById(1);
        assertEquals("Conta Deletada", result);
    }
    @Test
    @Tag("invalid")
    public void testDeletionWithNonExistentId() {
        String nonExistentId = "999";
        when(UserAccRepo.findById(999)).thenReturn(Optional.empty());
        String result = userAccountController.deleteUserById(nonExistentId);
        verify(UserAccRepo, never()).deleteById(999);
        assertEquals("Conta Deletada", result);
    }
    @Test
    @Tag("invalid")
    public void testDeletionWithInvalidIdFormat() {
        String invalidId = "abc";
        assertThrows(NumberFormatException.class, () -> {
            userAccountController.deleteUserById(invalidId);
        });
    }
