@ExtendWith(MockitoExtension.class)
class UserAccountControllerDeleteUserByIdTest {
    @Mock
    private UserAccountRepository UserAccRepo;
    @InjectMocks
    private UserAccountController userAccountController;
    @Test
    @Tag("valid")
    void deleteUserWithValidId() {
        // Arrange
        String validId = "123";
        doNothing().when(UserAccRepo).deleteById(123);
        // Act
        String result = userAccountController.deleteUserById(validId);
        // Assert
        assertEquals("Conta Deletada", result);
        verify(UserAccRepo, times(1)).deleteById(123);
    }
    @Test
    @Tag("invalid")
    void deleteUserWithInvalidIdFormat() {
        // Arrange
        String invalidId = "abc";
        // Act & Assert
        assertThrows(NumberFormatException.class, () -> 
            userAccountController.deleteUserById(invalidId)
        );
        verify(UserAccRepo, never()).deleteById(anyInt());
    }
    @Test
    @Tag("boundary")
    void deleteUserWithMaxIntId() {
        // Arrange
        String maxId = String.valueOf(Integer.MAX_VALUE);
        doNothing().when(UserAccRepo).deleteById(Integer.MAX_VALUE);
        // Act
        String result = userAccountController.deleteUserById(maxId);
        // Assert
        assertEquals("Conta Deletada", result);
        verify(UserAccRepo, times(1)).deleteById(Integer.MAX_VALUE);
    }
    @Test
    @Tag("invalid")
    void deleteUserWithNullId() {
        // Act & Assert
        assertThrows(NullPointerException.class, () -> 
            userAccountController.deleteUserById(null)
        );
        verify(UserAccRepo, never()).deleteById(anyInt());
    }
    @Test
    @Tag("invalid") 
    void deleteUserWithEmptyId() {
        // Arrange
        String emptyId = "";
        // Act & Assert
        assertThrows(NumberFormatException.class, () -> 
            userAccountController.deleteUserById(emptyId)
        );
        verify(UserAccRepo, never()).deleteById(anyInt());
    }
    @Test
    @Tag("integration")
    void deleteUserWhenRepositoryThrowsException() {
        // Arrange
        String validId = "123";
        doThrow(new RuntimeException("Database error")).when(UserAccRepo).deleteById(123);
        // Act & Assert
        assertThrows(RuntimeException.class, () -> 
            userAccountController.deleteUserById(validId)
        );
        verify(UserAccRepo, times(1)).deleteById(123);
    }
}