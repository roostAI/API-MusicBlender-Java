    @Test
    @Tag("valid")
    void findUserByValidId() {
        String userId = "1";
        User_Credentials user = new User_Credentials();
        when(UserAccRepo.findById(1)).thenReturn(Optional.of(user));
        User_Credentials result = userAccountController.findUserById(userId);
        assertNotNull(result);
        assertEquals(user, result);
        verify(UserAccRepo, times(1)).findById(1);
    }
