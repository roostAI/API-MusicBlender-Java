package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.User_Credentials;
import com.medeiros.SPRINGProject.Models.UserAccountRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import com.medeiros.SPRINGProject.Models.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.Objects;
import java.util.Optional;

@ExtendWith(MockitoExtension.class)
public class UserAccountControllerFindUserByIdTest {
    @Mock
    private UserAccountRepository UserAccRepo;
    @InjectMocks
    private UserAccountController userAccountController;
    private User_Credentials userCredentials;
    
    @BeforeEach
    public void setUp() {
        userCredentials = new User_Credentials();
        userCredentials.setId(1);
        userCredentials.setEmail("test@test.com");
        userCredentials.setPassword("password");
        userCredentials.setUsername("testUser");
    }
    
    @Test
    @Tag("valid")
    public void testFindUserByValidId() {
        when(UserAccRepo.findById(1)).thenReturn(Optional.of(userCredentials));
        User_Credentials result = userAccountController.findUserById("1");
        assertNotNull(result);
        assertEquals(userCredentials, result);
    }
    
    @Test
    @Tag("invalid")
    public void testFindUserByInvalidId() {
        when(UserAccRepo.findById(anyInt())).thenReturn(Optional.empty());
        User_Credentials result = userAccountController.findUserById("999");
        assertNull(result);
    }
    
    @Test
    @Tag("boundary")
    public void testFindUserByNullId() {
        assertThrows(NumberFormatException.class, () -> {
            userAccountController.findUserById(null);
        });
    }
}