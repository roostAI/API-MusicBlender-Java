package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.User_Credentials;
import com.medeiros.SPRINGProject.Models.UserAccRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import com.medeiros.SPRINGProject.Models.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.Objects;
import java.util.Optional;

@ExtendWith(MockitoExtension.class)
public class UserAccountControllerFindUserByIdTest {
    @Mock
    private UserAccRepository userAccRepo;
    @InjectMocks
    private UserAccountController userAccountController;
    @BeforeEach
    public void setUp() {
        // Setup code if needed
    }
    @Test
    @Tag("valid")
    public void findUserByIdWithValidId() {
        // Arrange
        int validId = 1; // Assuming 1 is a valid ID
        User_Credentials expectedUser = new User_Credentials(); // Assuming constructor exists
        when(userAccRepo.findById(validId)).thenReturn(Optional.of(expectedUser));
        // Act
        User_Credentials actualUser = userAccountController.findUserById(String.valueOf(validId));
        // Assert
        assertNotNull(actualUser);
        assertEquals(expectedUser, actualUser);
    }
    @Test
    @Tag("invalid")
    public void findUserByIdWithInvalidId() {
        // Arrange
        String invalidId = "abc";
        // Act & Assert
        assertThrows(NumberFormatException.class, () -> {
            userAccountController.findUserById(invalidId);
        });
    }
    @Test
    @Tag("boundary")
    public void findUserByIdWithNonExistentId() {
        // Arrange
        int nonExistentId = 9999; // Assuming 9999 is a non-existent ID
        when(userAccRepo.findById(nonExistentId)).thenReturn(Optional.empty());
        // Act
        User_Credentials actualUser = userAccountController.findUserById(String.valueOf(nonExistentId));
        // Assert
        assertNull(actualUser);
    }
    @Test
    @Tag("invalid")
    public void findUserByIdWithEmptyId() {
        // Arrange
        String emptyId = "";
        // Act & Assert
        assertThrows(NumberFormatException.class, () -> {
            userAccountController.findUserById(emptyId);
        });
    }
}