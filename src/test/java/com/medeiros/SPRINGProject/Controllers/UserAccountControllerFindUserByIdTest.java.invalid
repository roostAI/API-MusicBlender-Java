    @Test
    @Tag("valid")
    void findUserByIdWithValidIdReturnsUser() {
        // Arrange
        String inputId = "123";
        int expectedIntId = 123;
        User_Credentials expectedUser = new User_Credentials();
        expectedUser.setId(expectedIntId);
        expectedUser.setUsername("testUser");
        expectedUser.setEmail("test@example.com");
        
        when(UserAccRepo.findById(expectedIntId)).thenReturn(expectedUser);
        // Act
        User_Credentials result = userAccountController.findUserById(inputId);
        // Assert
        assertNotNull(result);
        assertEquals(expectedUser, result);
        assertEquals(expectedIntId, result.getId());
        verify(UserAccRepo, times(1)).findById(expectedIntId);
    }
    @Test
    @Tag("invalid")
    void findUserByIdWithInvalidIdThrowsNumberFormatException() {
        // Arrange
        String invalidId = "invalid_id";
        // Act & Assert
        assertThrows(NumberFormatException.class, () -> {
            userAccountController.findUserById(invalidId);
        });
        
        verifyNoInteractions(UserAccRepo);
    }
