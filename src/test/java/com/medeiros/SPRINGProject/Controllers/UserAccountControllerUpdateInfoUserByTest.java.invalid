    @Test
    @Tag("valid")
    public void testUpdateUserInfoWithValidParameters() {
        int userId = 123;
        String photoURL = "http://example.com/photo.jpg";
        String favoritesMusics = "Jazz,Pop";
        String gender = "Non-Binary";
        String phone = "555-1234";
        String instaURL = "http://instagram.com/dummy";
        String twitterURL = "http://twitter.com/dummy";
        String favoritesThings = "Coffee,Books";
        User_Info expectedUserInfo = new User_Info(userId, photoURL, favoritesMusics, gender, phone, instaURL, twitterURL, favoritesThings);
        doNothing().when(userInfoRepo).save(any(User_Info.class));
        String result = userAccountController.updateInfoUserBy(userId, photoURL, favoritesMusics, gender, phone, instaURL, twitterURL, favoritesThings);
        assertEquals((String) "ATUALIZADO", (String) result);
        ArgumentCaptor<User_Info> captor = ArgumentCaptor.forClass(User_Info.class);
        verify(userInfoRepo, times(1)).save(captor.capture());
        User_Info actualUserInfo = captor.getValue();
        // Since User_Info does not have getUserId & others, only check object fields by equals instead of getter methods
        assertEquals((int) expectedUserInfo.userId, (int) actualUserInfo.userId);
        assertEquals((String) expectedUserInfo.photoURL, (String) actualUserInfo.photoURL);
        assertEquals((String) expectedUserInfo.favoritesMusics, (String) actualUserInfo.favoritesMusics);
        assertEquals((String) expectedUserInfo.gender, (String) actualUserInfo.gender);
        assertEquals((String) expectedUserInfo.phone, (String) actualUserInfo.phone);
        assertEquals((String) expectedUserInfo.instaURL, (String) actualUserInfo.instaURL);
        assertEquals((String) expectedUserInfo.twitterURL, (String) actualUserInfo.twitterURL);
        assertEquals((String) expectedUserInfo.favoritesThings, (String) actualUserInfo.favoritesThings);
    }
