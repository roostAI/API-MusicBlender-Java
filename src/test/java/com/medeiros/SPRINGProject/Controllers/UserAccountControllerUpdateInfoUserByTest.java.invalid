    // --------- Scenario 9: Update user info concurrently for same userId ---------
    @Test
    @Tag("integration")
    public void testUpdateUserInfoWithConcurrentRequests() throws InterruptedException {
        int userId = 888;
        String[] photoURLs = { "photo1", "photo2", "photo3" };
        String remains = "val";
        doNothing().when(userInfoRepo).save(any(User_Info.class));
        Runnable task1 = () -> userAccountController.updateInfoUserBy(userId, photoURLs[0], remains, remains, remains, remains, remains, remains);
        Runnable task2 = () -> userAccountController.updateInfoUserBy(userId, photoURLs[1], remains, remains, remains, remains, remains, remains);
        Runnable task3 = () -> userAccountController.updateInfoUserBy(userId, photoURLs[2], remains, remains, remains, remains, remains, remains);
        Thread t1 = new Thread(task1);
        Thread t2 = new Thread(task2);
        Thread t3 = new Thread(task3);
        t1.start();
        t2.start();
        t3.start();
        t1.join();
        t2.join();
        t3.join();
        verify(userInfoRepo, times(3)).save(any(User_Info.class));
    }
