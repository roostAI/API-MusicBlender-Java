        String invalidId = "abc"; // Invalid ID format
        userAccountController.updateUserById(invalidId, "email@example.com", "password", "username");
    }
    
    @Test
    @Category(Categories.valid.class)
    public void nullEmailParameter() {
        int validId = 1; // TODO: Change to a valid ID
        User_Credentials user = new User_Credentials();
        when(userAccRepo.findById(validId)).thenReturn(Optional.of(user));
        String result = userAccountController.updateUserById(String.valueOf(validId), null, "newpassword", "newusername");
        assertEquals("Usuário Salvo", result);
        verify(userAccRepo).save(user);
        assertNull(user.getEmail());
        assertEquals("newpassword", user.getPassword());
        assertEquals("newusername", user.getUsername());
