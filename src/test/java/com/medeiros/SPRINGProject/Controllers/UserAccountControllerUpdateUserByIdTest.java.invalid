package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.User_Credentials;
import com.medeiros.SPRINGProject.Models.UserAccRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.*;
import com.medeiros.SPRINGProject.Models.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.Objects;
import java.util.Optional;

@ExtendWith(MockitoExtension.class)
public class UserAccountControllerUpdateUserByIdTest {
    @Mock
    private UserAccRepository userAccRepo;
    @InjectMocks
    private UserAccountController userAccountController;
    private User_Credentials existingUser;
    @BeforeEach
    public void setUp() {
        existingUser = new User_Credentials();
        existingUser.setEmail("oldEmail@example.com");
        existingUser.setPassword("oldPassword");
        existingUser.setUsername("oldUsername");
    }
    @Test
    @Tag("valid")
    public void updateUserSuccessfully() {
        // Arrange
        int validId = 1;
        String newEmail = "newEmail@example.com";
        String newPassword = "newPassword";
        String newUsername = "newUsername";
        when(userAccRepo.findById(validId)).thenReturn(Optional.of(existingUser));
        // Act
        String result = userAccountController.updateUserById(String.valueOf(validId), newEmail, newPassword, newUsername);
        // Assert
        verify(userAccRepo).save(existingUser);
        assertEquals("Usuário Salvo", result);
    }
    @Test
    @Tag("invalid")
    public void updateUserNotFound() {
        // Arrange
        int nonExistentId = 999;
        when(userAccRepo.findById(nonExistentId)).thenReturn(Optional.empty());
        // Act
        String result = userAccountController.updateUserById(String.valueOf(nonExistentId), "email", "password", "username");
        // Assert
        assertEquals("User não encontrado", result);
    }
    @Test
    @Tag("invalid")
    public void updateUserInvalidIdFormat() {
        // Arrange
        String invalidId = "invalidId";
        // Act & Assert
        assertThrows(NumberFormatException.class, () -> {
            userAccountController.updateUserById(invalidId, "email", "password", "username");
        });
    }
    @Test
    @Tag("boundary")
    public void updateUserWithEmptyFields() {
        // Arrange
        int validId = 1;
        when(userAccRepo.findById(validId)).thenReturn(Optional.of(existingUser));
        // Act
        String result = userAccountController.updateUserById(String.valueOf(validId), "", "", "");
        // Assert
        verify(userAccRepo).save(existingUser);
        assertEquals("Usuário Salvo", result);
    }
    @Test
    @Tag("boundary")
    public void updateUserWithNullFields() {
        // Arrange
        int validId = 1;
        when(userAccRepo.findById(validId)).thenReturn(Optional.of(existingUser));
        // Act
        String result = userAccountController.updateUserById(String.valueOf(validId), null, null, null);
        // Assert
        verify(userAccRepo).save(existingUser);
        assertEquals("Usuário Salvo", result);
    }
}