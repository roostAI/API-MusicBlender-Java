        int nonExistentId = 999; // TODO: Change to a non-existent ID
        when(userAccRepo.findById(nonExistentId)).thenReturn(Optional.empty());
        String result = userAccountController.updateUserById(String.valueOf(nonExistentId), "email@example.com", "password", "username");
        assertEquals("User não encontrado", result);
    }
    
    @Test(expected = NumberFormatException.class)
    @Category(Categories.invalid.class)
