    @Test
    @Tag("boundary")
    public void testUpdateUserWithInvalidParameters() {
        User_Credentials mockUser = new User_Credentials();
        mockUser.setId(1);
        mockUser.setEmail("oldEmail@test.com");
        mockUser.setPassword("oldPassword");
        mockUser.setUsername("oldUsername");
        when(userAccRepo.findById(1)).thenReturn(Optional.of(mockUser)); // Changed from mockUser to Optional.of(mockUser)
        String newEmail = "";
        String newPassword = "";
        String newUsername = "";
        String result = userAccountController.updateUserById("1", newEmail, newPassword, newUsername);
        assertEquals("Usuário Salvo", result);
        assertNotEquals(newEmail, mockUser.getEmail());
