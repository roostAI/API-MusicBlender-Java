import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.Objects;
import java.util.Optional;

@SpringBootTest
public class UserAccountControllerUpdateUserByIdTest {
    @InjectMocks
    UserAccountController userAccountController;
    @Mock
    UserAccRepository UserAccRepo; // Changed UserAccountRepository to UserAccRepository
    @Test
    @Tag("valid")
    public void testUpdateExistingUser() {
        String id = "1";
        String email = "newEmail@test.com";
        String password = "newPassword";
        String username = "newUsername";
        User_Credentials existingUser = new User_Credentials();
        existingUser.setId(1);
        existingUser.setEmail("oldEmail@test.com");
        existingUser.setPassword("oldPassword");
        existingUser.setUsername("oldUsername");
        when(UserAccRepo.findById(Integer.parseInt(id))).thenReturn(Optional.of(existingUser)); // Changed return type to Optional
        String result = userAccountController.updateUserById(id, email, password, username);
        assertEquals("Usuário Salvo", result);
    }
    @Test
    @Tag("invalid")
    public void testUpdateNonExistingUser() {
        String id = "2";
        String email = "newEmail@test.com";
        String password = "newPassword";
        String username = "newUsername";
        when(UserAccRepo.findById(Integer.parseInt(id))).thenReturn(Optional.empty()); // Changed return type to Optional
        String result = userAccountController.updateUserById(id, email, password, username);
        assertEquals("User não encontrado", result);
    }
}