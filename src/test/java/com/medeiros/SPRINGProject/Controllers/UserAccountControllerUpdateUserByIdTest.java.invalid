package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.User_Credentials;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import com.medeiros.SPRINGProject.Models.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.Objects;
import java.util.Optional;

@ExtendWith(MockitoExtension.class)
public class UserAccountControllerUpdateUserByIdTest {
    @Mock
    private UserAccRepository userAccRepo; // Corrected the class name
    @InjectMocks
    private UserAccountController userAccountController;
    private User_Credentials existingUser;
    @BeforeEach
    public void setUp() {
        existingUser = new User_Credentials();
        existingUser.setEmail("test@example.com");
        existingUser.setPassword("password123");
        existingUser.setUsername("testuser");
    }
    @Test
    @Tag("valid")
    public void updateUserSuccessfully() {
        // Arrange
        int validId = 1; // Assuming 1 is a valid ID
        when(userAccRepo.findById(validId)).thenReturn(Optional.of(existingUser)); // Corrected to return Optional
        // Act
        String result = userAccountController.updateUserById(String.valueOf(validId), "newemail@example.com", "newpassword", "newusername");
        // Assert
        assertEquals("Usuário Salvo", result);
        verify(userAccRepo).save(existingUser);
        assertEquals("newemail@example.com", existingUser.getEmail());
        assertEquals("newpassword", existingUser.getPassword());
        assertEquals("newusername", existingUser.getUsername());
    }
    @Test
    @Tag("invalid")
    public void userNotFound() {
        // Arrange
        int nonExistentId = 999; // Assuming 999 is a non-existent ID
        when(userAccRepo.findById(nonExistentId)).thenReturn(Optional.empty()); // Corrected to return Optional
        // Act
        String result = userAccountController.updateUserById(String.valueOf(nonExistentId), "email@example.com", "password", "username");
        // Assert
        assertEquals("User não encontrado", result);
    }
    @Test
    @Tag("invalid")
    public void invalidUserIdFormat() {
        // Arrange
        String invalidId = "abc";
        // Act & Assert
        assertThrows(NumberFormatException.class, () -> {
            userAccountController.updateUserById(invalidId, "email@example.com", "password", "username");
        });
    }
    @Test
    @Tag("boundary")
    public void nullEmailParameter() {
        // Arrange
        int validId = 1; // Assuming 1 is a valid ID
        when(userAccRepo.findById(validId)).thenReturn(Optional.of(existingUser)); // Corrected to return Optional
        // Act
        String result = userAccountController.updateUserById(String.valueOf(validId), null, "password", "username");
        // Assert
        assertEquals("Usuário Salvo", result);
        verify(userAccRepo).save(existingUser);
        assertNull(existingUser.getEmail());
    }
    @Test
    @Tag("boundary")
    public void emptyPasswordParameter() {
        // Arrange
        int validId = 1; // Assuming 1 is a valid ID
        when(userAccRepo.findById(validId)).thenReturn(Optional.of(existingUser)); // Corrected to return Optional
        // Act
        String result = userAccountController.updateUserById(String.valueOf(validId), "email@example.com", "", "username");
        // Assert
        assertEquals("Usuário Salvo", result);
        verify(userAccRepo).save(existingUser);
        assertEquals("", existingUser.getPassword());
    }
    @Test
    @Tag("boundary")
    public void nullUsernameParameter() {
        // Arrange
        int validId = 1; // Assuming 1 is a valid ID
        when(userAccRepo.findById(validId)).thenReturn(Optional.of(existingUser)); // Corrected to return Optional
        // Act
        String result = userAccountController.updateUserById(String.valueOf(validId), "email@example.com", "password", null);
        // Assert
        assertEquals("Usuário Salvo", result);
        verify(userAccRepo).save(existingUser);
        assertNull(existingUser.getUsername());
    }
}