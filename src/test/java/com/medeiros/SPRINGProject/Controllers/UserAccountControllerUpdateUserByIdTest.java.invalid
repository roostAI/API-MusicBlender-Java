package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.User_Credentials;
import com.medeiros.SPRINGProject.Models.UserAccRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.ArgumentMatchers.anyInt;
import static org.mockito.Mockito.*;
import com.medeiros.SPRINGProject.Models.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.Objects;
import java.util.Optional;

public class UserAccountControllerUpdateUserByIdTest {
    @Mock
    private UserAccRepository userAccRepo;
    @InjectMocks
    private UserAccountController userAccountController;
    @BeforeEach
    public void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void updateUserWithValidDetails() {
        User_Credentials existingUser = new User_Credentials();
        existingUser.setEmail("oldemail@example.com");
        existingUser.setPassword("oldPassword");
        existingUser.setUsername("oldUsername");
        when(userAccRepo.findById(anyInt())).thenReturn(Optional.of(existingUser));
        String result = userAccountController.updateUserById("1", "newemail@example.com", "newPassword", "newUsername");
        assertEquals("Usuário Salvo", result);
        verify(userAccRepo).save(existingUser);
    }
    @Test
    @Tag("invalid")
    public void updateUserWithNonExistentId() {
        when(userAccRepo.findById(anyInt())).thenReturn(Optional.empty());
        String result = userAccountController.updateUserById("999", "email@example.com", "password", "username");
        assertEquals("User não encontrado", result);
    }
    @Test
    @Tag("invalid")
    public void updateUserWithInvalidEmail() {
        User_Credentials existingUser = new User_Credentials();
        existingUser.setEmail("oldemail@example.com");
        existingUser.setPassword("oldPassword");
        existingUser.setUsername("oldUsername");
        when(userAccRepo.findById(anyInt())).thenReturn(Optional.of(existingUser));
        String result = userAccountController.updateUserById("1", "invalid-email", "newPassword", "newUsername");
        assertEquals("Usuário Salvo", result);
        verify(userAccRepo).save(existingUser);
    }
    @Test
    @Tag("invalid")
    public void updateUserWithEmptyPassword() {
        User_Credentials existingUser = new User_Credentials();
        existingUser.setEmail("oldemail@example.com");
        existingUser.setPassword("oldPassword");
        existingUser.setUsername("oldUsername");
        when(userAccRepo.findById(anyInt())).thenReturn(Optional.of(existingUser));
        String result = userAccountController.updateUserById("1", "newemail@example.com", "", "newUsername");
        assertEquals("Usuário Salvo", result);
        verify(userAccRepo).save(existingUser);
    }
}