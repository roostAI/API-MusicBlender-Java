package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.User_Credentials;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import com.medeiros.SPRINGProject.Models.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.Objects;
import java.util.Optional;

@ExtendWith(MockitoExtension.class)
public class UserAccountControllerUpdateUserByIdTest {
    @Mock
    private UserAccRepository userAccRepo; // Corrected the class name
    @InjectMocks
    private UserAccountController userAccountController;
    private User_Credentials validUser;
    @BeforeEach
    public void setUp() {
        validUser = new User_Credentials();
        validUser.setEmail("test@example.com");
        validUser.setPassword("password123");
        validUser.setUsername("testuser");
    }
    @Test
    @Tag("valid")
    public void updateUserSuccessfully() {
        when(userAccRepo.findById(1)).thenReturn(Optional.of(validUser)); // Corrected to return Optional
        String result = userAccountController.updateUserById("1", "newemail@example.com", "newpassword", "newusername");
        assertEquals("Usuário Salvo", result);
        verify(userAccRepo).save(validUser);
        assertEquals("newemail@example.com", validUser.getEmail());
        assertEquals("newpassword", validUser.getPassword());
        assertEquals("newusername", validUser.getUsername());
    }
    @Test
    @Tag("invalid")
    public void userNotFound() {
        when(userAccRepo.findById(2)).thenReturn(Optional.empty()); // Corrected to return Optional
        String result = userAccountController.updateUserById("2", "email@example.com", "password", "username");
        assertEquals("User não encontrado", result);
    }
    @Test
    @Tag("invalid")
    public void invalidIdFormat() {
        assertThrows(NumberFormatException.class, () -> {
            userAccountController.updateUserById("invalid", "email@example.com", "password", "username");
        });
    }
    @Test
    @Tag("invalid")
    public void nullEmailParameter() {
        when(userAccRepo.findById(1)).thenReturn(Optional.of(validUser)); // Corrected to return Optional
        assertThrows(NullPointerException.class, () -> {
            userAccountController.updateUserById("1", null, "password", "username");
        });
    }
    @Test
    @Tag("valid")
    public void emptyPasswordParameter() {
        when(userAccRepo.findById(1)).thenReturn(Optional.of(validUser)); // Corrected to return Optional
        String result = userAccountController.updateUserById("1", "email@example.com", "", "username");
        assertEquals("Usuário Salvo", result);
        verify(userAccRepo).save(validUser);
        assertEquals("", validUser.getPassword());
    }
    @Test
    @Tag("invalid")
    public void nullUsernameParameter() {
        when(userAccRepo.findById(1)).thenReturn(Optional.of(validUser)); // Corrected to return Optional
        assertThrows(NullPointerException.class, () -> {
            userAccountController.updateUserById("1", "email@example.com", "password", null);
        });
    }
}