package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.*;
import com.medeiros.SPRINGProject.Repositories.UserAccountRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.Objects;
import java.util.Optional;

 // Added missing import
@ExtendWith(MockitoExtension.class)
class UserAccountControllerUpdateUserByIdTest {
    @Mock
    private UserAccountRepository UserAccRepo;
    
    @InjectMocks
    private UserAccountController userAccountController;
    
    private User_Credentials testUser;
    
    @BeforeEach
    void setUp() {
        testUser = new User_Credentials();
        testUser.setId(1);
        testUser.setEmail("old@email.com");
        testUser.setPassword("oldpass"); 
        testUser.setUsername("olduser");
    }
    @Test
    @Tag("valid")
    void updateExistingUserWithValidData() {
        // Arrange
        when(UserAccRepo.findById(1)).thenReturn(testUser);
        
        // Act
        String result = userAccountController.updateUserById(
            "1", "new@email.com", "newpass", "newuser"
        );
        
        // Assert
        assertEquals("Usuário Salvo", result);
        verify(UserAccRepo).save(testUser);
        assertEquals("new@email.com", testUser.getEmail());
        assertEquals("newpass", testUser.getPassword());
        assertEquals("newuser", testUser.getUsername());
    }
    @Test
    @Tag("invalid") 
    void updateNonExistentUser() {
        // Arrange
        when(UserAccRepo.findById(999)).thenReturn(null);
        
        // Act
        String result = userAccountController.updateUserById(
            "999", "test@email.com", "testpass", "testuser"
        );
        
        // Assert
        assertEquals("User não encontrado", result);
        verify(UserAccRepo, never()).save(any());
    }
    @Test
    @Tag("invalid")
    void updateUserWithInvalidId() {
        // Act & Assert
        assertThrows(NumberFormatException.class, () -> 
            userAccountController.updateUserById(
                "invalid", "test@email.com", "testpass", "testuser"
            )
        );
        verify(UserAccRepo, never()).findById(anyInt());
        verify(UserAccRepo, never()).save(any());
    }
    @Test
    @Tag("boundary")
    void updateUserWithEmptyFields() {
        // Arrange
        when(UserAccRepo.findById(1)).thenReturn(testUser);
        
        // Act
        String result = userAccountController.updateUserById(
            "1", "", "", ""
        );
        
        // Assert
        assertEquals("Usuário Salvo", result);
        verify(UserAccRepo).save(testUser);
        assertEquals("", testUser.getEmail());
        assertEquals("", testUser.getPassword());
        assertEquals("", testUser.getUsername());
    }
    @Test
    @Tag("integration")
    void updateUserWithMaxLengthValues() {
        // Arrange
        when(UserAccRepo.findById(1)).thenReturn(testUser);
        String longString = "a".repeat(255);
        
        // Act
        String result = userAccountController.updateUserById(
            "1", longString, longString, longString
        );
        
        // Assert
        assertEquals("Usuário Salvo", result);
        verify(UserAccRepo).save(testUser);
        assertEquals(longString, testUser.getEmail());
        assertEquals(longString, testUser.getPassword());
        assertEquals(longString, testUser.getUsername());
    }
}