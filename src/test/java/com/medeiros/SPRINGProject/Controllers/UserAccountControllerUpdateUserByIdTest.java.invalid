public class UserAccountControllerUpdateUserByIdTest {
    @Mock
    private UserAccountRepository UserAccRepo;
    @InjectMocks
    private UserAccountController userAccountController;
    private User_Credentials mockUser;
    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
        mockUser = new User_Credentials();
        mockUser.setId(1);
        mockUser.setEmail("test@example.com");
        mockUser.setPassword("password123");
        mockUser.setUsername("testuser");
    }
    @Test
    @Tag("valid")
    void updateUserByIdWithValidParametersReturnsSuccessMessage() {
        // Arrange
        String id = "1";
        String email = "newemail@example.com";
        String password = "newpassword123";
        String username = "newusername";
        
        when(UserAccRepo.findById(1)).thenReturn(mockUser);
        
        // Act
        String result = userAccountController.updateUserById(id, email, password, username);
        
        // Assert
        assertEquals("Usuário Salvo", result);
        verify(UserAccRepo, times(1)).findById(1);
        verify(UserAccRepo, times(1)).save(mockUser);
        assertEquals(email, mockUser.getEmail());
        assertEquals(password, mockUser.getPassword());
        assertEquals(username, mockUser.getUsername());
    }
    @Test
    @Tag("invalid")
    void updateUserByIdWithNonExistentIdReturnsNotFoundMessage() {
        // Arrange
        String id = "999";
        String email = "test@example.com";
        String password = "password123";
        String username = "testuser";
        
        when(UserAccRepo.findById(999)).thenReturn(null);
        
        // Act
        String result = userAccountController.updateUserById(id, email, password, username);
        
        // Assert
        assertEquals("User não encontrado", result);
        verify(UserAccRepo, times(1)).findById(999);
        verify(UserAccRepo, never()).save(any(User_Credentials.class));
    }
    @Test
    @Tag("invalid")
    void updateUserByIdWithInvalidIdFormatThrowsNumberFormatException() {
        // Arrange
        String id = "abc";
        String email = "test@example.com";
        String password = "password123";
        String username = "testuser";
        
        // Act & Assert
        assertThrows(NumberFormatException.class, () -> {
            userAccountController.updateUserById(id, email, password, username);
        });
        
        verify(UserAccRepo, never()).findById(anyInt());
        verify(UserAccRepo, never()).save(any(User_Credentials.class));
    }
