    public void testUpdateExistingUserCredentialsSuccessfully() {
        int id = 1;
        String email = "new.email@example.com";
        String password = "newPassword123";
        String username = "newUsername";
        User_Credentials existingUser = mock(User_Credentials.class);
        when(userAccRepo.findById(id)).thenReturn(existingUser);
        String result = (String) userAccountController.updateUserById(String.valueOf(id), email, password, username);
        verify(existingUser).setEmail((String) email);
        verify(existingUser).setPassword((String) password);
        verify(existingUser).setUsername((String) username);
        verify(userAccRepo).save((User_Credentials) existingUser);
        assertEquals((String) "Usuário Salvo", (String) result);
    }
