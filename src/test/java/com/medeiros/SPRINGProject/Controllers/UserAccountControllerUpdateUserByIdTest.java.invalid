package com.medeiros.SPRINGProject.Controllers;import com.medeiros.SPRINGProject.Models.*;
import org.junit.jupiter.api.*;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.*;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.Objects;
import java.util.Optional;

@SpringBootTest
@ExtendWith(MockitoExtension.class)
class UserAccountControllerUpdateUserByIdTest {
    @Autowired
    UserAccountController userAccountController;
    @Mock
    UserAccRepository userAccRepo;
    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    void testUpdateUserWithValidInputs() {
        User_Credentials user = new User_Credentials();
        when(userAccRepo.findById(anyInt())).thenReturn(Optional.of(user));
        String response = userAccountController.updateUserById("1", "test@test.com", "password", "username");
        assertEquals("Usuário Salvo", response);
        verify(userAccRepo, times(1)).save(user);
    }
    @Test
    @Tag("invalid")
    void testUpdateUserWithNonExistentId() {
        when(userAccRepo.findById(anyInt())).thenReturn(Optional.empty());
        String response = userAccountController.updateUserById("100", "test@test.com", "password", "username");
        assertEquals("User não encontrado", response);
        verify(userAccRepo, times(0)).save(any(User_Credentials.class));
    }
    @Test
    @Tag("invalid")
    void testUpdateUserWithInvalidParameters() {
        assertThrows(NumberFormatException.class,
                ()-> userAccountController.updateUserById("invalid", "test@test.com", "password", "username"));
    }
    @Test
    @Tag("invalid")
    void testUpdateUserWithNullParameters() {
        assertThrows(IllegalArgumentException.class,
                ()-> userAccountController.updateUserById(null, null, null, null));
    }
}