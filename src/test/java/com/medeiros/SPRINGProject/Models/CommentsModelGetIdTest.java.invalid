package com.medeiros.SPRINGProject.Models;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;
import jakarta.persistence.*;
import org.springframework.web.bind.annotation.RestController;

public class CommentsModelGetIdTest {
    @Test
    @Tag("valid")
    public void testCorrectIdReturned() {
        // Arrange
        CommentsModel commentsModel = new CommentsModel();
        commentsModel.setId(123);
        // Act
        int id = commentsModel.getId();
        // Assert
        assertEquals(123, id, "The returned id should match the set id");
    }
    @Test
    @Tag("boundary")
    public void testDefaultIdReturned() {
        // Arrange
        CommentsModel commentsModel = new CommentsModel();
        // Act
        int id = commentsModel.getId();
        // Assert
        assertEquals(0, id, "The returned id should be the default id (0) when no id has been set");
    }
    @Test
    @Tag("valid")
    public void testIdNotAffectedByOtherFields() {
        // Arrange
        CommentsModel commentsModel = new CommentsModel();
        commentsModel.setId(123);
        commentsModel.setMusicID(456);
        commentsModel.setComment("Test Comment");
        commentsModel.setNumberOfLikes(789);
        commentsModel.setNumberOfComments(101112);
        commentsModel.setNumberOfLoves(131415);
        // Act
        int id = commentsModel.getId();
        // Assert
        assertEquals(123, id, "The returned id should not be affected by changes to other fields");
    }
}