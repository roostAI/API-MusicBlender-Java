package com.medeiros.SPRINGProject.Models;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;
import jakarta.persistence.*;
import org.springframework.web.bind.annotation.RestController;

public class CommentsModelGetMusicIdTest {
    @Test
    @Tag("valid")
    public void testGetMusicIDReturnsCorrectValue() {
        // Arrange
        CommentsModel commentsModel = new CommentsModel();
        int expectedMusicID = 123;
        commentsModel.setMusicID(expectedMusicID);
        // Act
        int actualMusicID = commentsModel.getMusicID();
        // Assert
        assertEquals(expectedMusicID, actualMusicID, "The returned MusicID should match the expected MusicID");
    }
    @Test
    @Tag("boundary")
    public void testGetMusicIDReturnsDefaultValue() {
        // Arrange
        CommentsModel commentsModel = new CommentsModel();
        int expectedMusicID = 0; // Default value for int in Java
        // Act
        int actualMusicID = commentsModel.getMusicID();
        // Assert
        assertEquals(expectedMusicID, actualMusicID, "The returned MusicID should match the default value when no MusicID has been set");
    }
}