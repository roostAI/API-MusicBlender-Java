import org.springframework.web.bind.annotation.RestController;

public class CommentsModelGetNumberOfCommentsTest {
    @Test
    @Tag("valid")
    public void testCorrectNumberOfCommentsReturned() {
        // Arrange
        CommentsModel comments = new CommentsModel();
        comments.setNumberOfComments(5);
        // Act
        int result = comments.getNumberOfComments();
        // Assert
        assertEquals(5, result, "The number of comments returned should be 5");
    }
    @Test
