package com.medeiros.SPRINGProject.Models;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;
import jakarta.persistence.*;
import org.springframework.web.bind.annotation.RestController;

public class CommentsModelGetNumberOfLikesTest {
    @Test
    @Tag("valid")
    public void testGetNumberOfLikes() {
        CommentsModel commentsModel = new CommentsModel();
        commentsModel.setNumberOfLikes(10);
        int actualNumberOfLikes = commentsModel.getNumberOfLikes();
        assertEquals(10, actualNumberOfLikes, "The number of likes should be 10");
    }
    @Test
    @Tag("boundary")
    public void testGetNumberOfLikesWhenNoLikesAreSet() {
        CommentsModel commentsModel = new CommentsModel();
        int actualNumberOfLikes = commentsModel.getNumberOfLikes();
        assertEquals(0, actualNumberOfLikes, "The number of likes should be 0 when no likes are set");
    }
    @Test
    @Tag("valid")
    public void testGetNumberOfLikesAfterUpdatingLikes() {
        CommentsModel commentsModel = new CommentsModel();
        commentsModel.setNumberOfLikes(5);
        commentsModel.setNumberOfLikes(15);
        int actualNumberOfLikes = commentsModel.getNumberOfLikes();
        assertEquals(15, actualNumberOfLikes, "The number of likes should be 15 after updating");
    }
}