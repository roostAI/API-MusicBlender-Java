package com.medeiros.SPRINGProject.Models;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;
import jakarta.persistence.*;
import org.springframework.web.bind.annotation.RestController;

public class CommentsModelGetNumberOfLovesTest {
    @Test
    @Tag("valid")
    public void checkGetNumberOfLoves() {
        // Arrange
        CommentsModel commentsModel = new CommentsModel();
        commentsModel.setNumberOfLoves(5);
        // Act
        int actualNumberOfLoves = commentsModel.getNumberOfLoves();
        // Assert
        assertEquals(5, actualNumberOfLoves, "getNumberOfLoves method did not return the correct number of loves");
    }
    @Test
    @Tag("boundary")
    public void checkGetNumberOfLovesWithoutSetting() {
        // Arrange
        CommentsModel commentsModel = new CommentsModel();
        // Act
        int actualNumberOfLoves = commentsModel.getNumberOfLoves();
        // Assert
        assertEquals(0, actualNumberOfLoves, "getNumberOfLoves method did not return zero when no loves were set");
    }
    @Test
    @Tag("valid")
    public void checkGetNumberOfLovesAfterMultipleSets() {
        // Arrange
        CommentsModel commentsModel = new CommentsModel();
        commentsModel.setNumberOfLoves(3);
        commentsModel.setNumberOfLoves(7);
        // Act
        int actualNumberOfLoves = commentsModel.getNumberOfLoves();
        // Assert
        assertEquals(7, actualNumberOfLoves, "getNumberOfLoves method did not return the last set number of loves");
    }
}