package com.medeiros.SPRINGProject.Models;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;
import jakarta.persistence.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestParam;

public class ForumIndexModelGetForumIdTest {
    @Test
    @Tag("valid")
    public void testGetForumIDReturnsCorrectValue() {
        // Arrange
        ForumIndexModel forumIndexModel = new ForumIndexModel();
        int expectedForumID = 123;
        forumIndexModel.setForumID(expectedForumID);
        // Act
        int actualForumID = forumIndexModel.getForumID();
        // Assert
        assertEquals(expectedForumID, actualForumID, "The returned ForumID should match the expected ForumID");
    }
    @Test
    @Tag("boundary")
    public void testGetForumIDReturnsDefaultValue() {
        // Arrange
        ForumIndexModel forumIndexModel = new ForumIndexModel();
        int expectedForumID = 0; // Default value for int in Java
        // Act
        int actualForumID = forumIndexModel.getForumID();
        // Assert
        assertEquals(expectedForumID, actualForumID, "The returned ForumID should match the default value when no ForumID has been set");
    }
}