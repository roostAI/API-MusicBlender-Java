package com.medeiros.SPRINGProject.Models;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import jakarta.persistence.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestParam;

public class ForumIndexModelGetForumNameTest {
    @Test
    @Tag("valid")
    public void testGetForumNameReturnsCorrectName() {
        // Arrange
        ForumIndexModel forumIndexModel = new ForumIndexModel();
        String expectedForumName = "Test Forum";
        forumIndexModel.setForumName(expectedForumName);
        // Act
        String actualForumName = forumIndexModel.getForumName();
        // Assert
        assertEquals(expectedForumName, actualForumName, "The returned forum name should match the expected forum name.");
    }
    @Test
    @Tag("invalid")
    public void testGetForumNameReturnsNullWhenNotSet() {
        // Arrange
        ForumIndexModel forumIndexModel = new ForumIndexModel();
        // Act
        String actualForumName = forumIndexModel.getForumName();
        // Assert
        assertNull(actualForumName, "The returned forum name should be null as it was not set.");
    }
    @Test
    @Tag("boundary")
    public void testGetForumNameReturnsLatestName() {
        // Arrange
        ForumIndexModel forumIndexModel = new ForumIndexModel();
        String initialForumName = "Initial Forum";
        String expectedForumName = "Updated Forum";
        forumIndexModel.setForumName(initialForumName);
        forumIndexModel.setForumName(expectedForumName);
        // Act
        String actualForumName = forumIndexModel.getForumName();
        // Assert
        assertEquals(expectedForumName, actualForumName, "The returned forum name should match the latest set forum name.");
    }
}