package com.medeiros.SPRINGProject.Models;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;
import jakarta.persistence.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestParam;

public class ForumIndexModelGetIdTest {
    @Test
    @Tag("valid")
    public void testGetIdReturnsCorrectId() {
        // Arrange
        ForumIndexModel forumIndexModel = new ForumIndexModel();
        forumIndexModel.setId(123);
        // Act
        int id = forumIndexModel.getId();
        // Assert
        assertEquals(123, id, "The returned id should match the set id.");
    }
    @Test
    @Tag("boundary")
    public void testGetIdReturnsZeroWhenIdNotSet() {
        // Arrange
        ForumIndexModel forumIndexModel = new ForumIndexModel();
        // Act
        int id = forumIndexModel.getId();
        // Assert
        assertEquals(0, id, "The returned id should be zero when id is not set.");
    }
    @Test
    @Tag("valid")
    public void testGetIdReturnsCorrectIdAfterChangingIt() {
        // Arrange
        ForumIndexModel forumIndexModel = new ForumIndexModel();
        forumIndexModel.setId(123);
        forumIndexModel.setId(456);
        // Act
        int id = forumIndexModel.getId();
        // Assert
        assertEquals(456, id, "The returned id should match the new set id.");
    }
}