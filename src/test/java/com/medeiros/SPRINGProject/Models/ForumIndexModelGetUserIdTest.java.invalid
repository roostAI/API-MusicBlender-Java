package com.medeiros.SPRINGProject.Models;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;
import jakarta.persistence.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestParam;

public class ForumIndexModelGetUserIdTest {
    @Test
    @Tag("valid")
    public void testGetUserIdReturnsCorrectId() {
        // Arrange
        ForumIndexModel forumIndexModel = new ForumIndexModel();
        int knownUserId = 123;
        forumIndexModel.setUserId(knownUserId);
        // Act
        int returnedUserId = forumIndexModel.getUserId();
        // Assert
        assertEquals(knownUserId, returnedUserId, "getUserId should return the correct user ID");
    }
    @Test
    @Tag("boundary")
    public void testGetUserIdReturnsDefaultValue() {
        // Arrange
        ForumIndexModel forumIndexModel = new ForumIndexModel();
        // Act
        int returnedUserId = forumIndexModel.getUserId();
        // Assert
        assertEquals(0, returnedUserId, "getUserId should return the default value when user ID is not set");
    }
    @Test
    @Tag("valid")
    public void testGetUserIdAfterMultipleSetUserIdInvocations() {
        // Arrange
        ForumIndexModel forumIndexModel = new ForumIndexModel();
        int firstUserId = 123;
        int secondUserId = 456;
        forumIndexModel.setUserId(firstUserId);
        forumIndexModel.setUserId(secondUserId);
        // Act
        int returnedUserId = forumIndexModel.getUserId();
        // Assert
        assertEquals(secondUserId, returnedUserId, "getUserId should return the last user ID that was set");
    }
}