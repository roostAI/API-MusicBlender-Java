package com.medeiros.SPRINGProject.Models;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;
import jakarta.persistence.Entity;
import jakarta.persistence.GeneratedValue;
import jakarta.persistence.GenerationType;
import jakarta.persistence.Id;
import java.time.LocalDateTime;

public class LogModelGetLogIdTest {
    @Test
    @Tag("valid")
    public void validateGetLogIdWhenLogIdIsSet() {
        // Arrange
        LogModel logModel = new LogModel();
        int expectedLogId = 10;
        logModel.setLogId(expectedLogId);
        // Act
        int actualLogId = logModel.getLogId();
        // Assert
        assertEquals(expectedLogId, actualLogId);
    }
    @Test
    @Tag("valid")
    public void validateGetLogIdWhenLogIdIsNotSet() {
        // Arrange
        LogModel logModel = new LogModel();
        int expectedLogId = 0;
        // Act
        int actualLogId = logModel.getLogId();
        // Assert
        assertEquals(expectedLogId, actualLogId);
    }
    @Test
    @Tag("valid")
    public void validateGetLogIdWithMultipleLogModelObjects() {
        // Arrange
        LogModel logModel1 = new LogModel();
        int expectedLogId1 = 15;
        logModel1.setLogId(expectedLogId1);
        LogModel logModel2 = new LogModel();
        int expectedLogId2 = 20;
        logModel2.setLogId(expectedLogId2);
        // Act
        int actualLogId1 = logModel1.getLogId();
        int actualLogId2 = logModel2.getLogId();
        // Assert
        assertEquals(expectedLogId1, actualLogId1);
        assertEquals(expectedLogId2, actualLogId2);
    }
}