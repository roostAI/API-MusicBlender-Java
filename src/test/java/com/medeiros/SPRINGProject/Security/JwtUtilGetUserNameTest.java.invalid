package com.medeiros.SPRINGProject.Security;
import com.medeiros.SPRINGProject.Models.User_Credentials;
import io.jsonwebtoken.Claims;
import io.jsonwebtoken.Jwts;
import io.jsonwebtoken.security.Keys;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.security.authentication.UsernamePasswordAuthenticationToken;
import java.nio.charset.StandardCharsets;
import java.util.Date;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNull;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.security.core.Authentication;
import org.springframework.stereotype.Component;
import java.security.Key;

@SpringBootTest
public class JwtUtilGetUserNameTest {
    @Autowired
    private JwtUtil jwtUtil;
    @Test
    @Tag("valid")
    public void testGetUserNameFromToken() {
        User_Credentials user = new User_Credentials();
        user.setUsername("testUser");
        UsernamePasswordAuthenticationToken authentication = new UsernamePasswordAuthenticationToken(user, null, null);
        String token = jwtUtil.newToken(authentication);
        String userName = jwtUtil.getUserName(token);
        assertEquals("testUser", userName);
    }
    @Test
    @Tag("invalid")
    public void testGetUserNameWithNullToken() {
        String userName = jwtUtil.getUserName(null);
        assertNull(userName);
    }
    @Test
    @Tag("invalid")
    public void testGetUserNameWithInvalidToken() {
        String userName = jwtUtil.getUserName("invalidToken");
        assertNull(userName);
    }
    @Test
    @Tag("boundary")
    public void testGetUserNameWithExpiredToken() {
        User_Credentials user = new User_Credentials();
        user.setUsername("testUser");
        UsernamePasswordAuthenticationToken authentication = new UsernamePasswordAuthenticationToken(user, null, null);
        // Set jwtExpirationMilliseg to a past time to make the token expired
        jwtUtil.setJwtExpirationMilliseg(-1000);
        String token = jwtUtil.newToken(authentication);
        String userName = jwtUtil.getUserName(token);
        assertNull(userName);
    }
}