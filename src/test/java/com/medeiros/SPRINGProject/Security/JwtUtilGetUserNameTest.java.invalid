package com.medeiros.SPRINGProject.Security;import com.medeiros.SPRINGProject.Models.User_Credentials;
import io.jsonwebtoken.Claims;
import io.jsonwebtoken.Jwts;
import io.jsonwebtoken.security.Keys;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import org.springframework.security.core.Authentication;
import java.nio.charset.StandardCharsets;
import java.security.Key;
import java.util.Date;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNull;
import static org.mockito.Mockito.when;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;

public class JwtUtilGetUserNameTest {
    private JwtUtil jwtUtil;
    private String jwtSecret = "mySecretKeymySecretKeymySecretKeymySecretKey"; // TODO: Change to actual secret key
    private long jwtExpirationMilliseg = 3600000; // 1 hour
    @BeforeEach
    public void setUp() {
        jwtUtil = new JwtUtil();
        // Assuming a setter method is available for jwtSecret
        jwtUtil.setJwtSecret(jwtSecret);
    }
    @Test
    @Tag("valid")
    public void validTokenWithCorrectClaims() {
        Authentication authentication = Mockito.mock(Authentication.class);
        User_Credentials user = Mockito.mock(User_Credentials.class);
        when(authentication.getPrincipal()).thenReturn(user);
        when(user.getUsername()).thenReturn("testUser");
        String token = jwtUtil.newToken(authentication);
        String username = jwtUtil.getUserName(token);
        assertEquals("testUser", username);
    }
    @Test
    @Tag("invalid")
    public void invalidTokenWithIncorrectSignature() {
        String token = Jwts.builder()
                .setSubject("testUser")
                .setIssuedAt(new Date())
                .setExpiration(new Date(System.currentTimeMillis() + jwtExpirationMilliseg))
                .signWith(Keys.hmacShaKeyFor("wrongSecretKeywrongSecretKeywrongSecretKey".getBytes(StandardCharsets.UTF_8)))
                .compact();
        String username = jwtUtil.getUserName(token);
        assertNull(username);
    }
    @Test
    @Tag("invalid")
    public void expiredToken() {
        String token = Jwts.builder()
                .setSubject("testUser")
                .setIssuedAt(new Date(System.currentTimeMillis() - jwtExpirationMilliseg))
                .setExpiration(new Date(System.currentTimeMillis() - 1000))
                .signWith(Keys.hmacShaKeyFor(jwtSecret.getBytes(StandardCharsets.UTF_8)))
                .compact();
        String username = jwtUtil.getUserName(token);
        assertNull(username);
    }
    @Test
    @Tag("boundary")
    public void nullTokenInput() {
        String username = jwtUtil.getUserName(null);
        assertNull(username);
    }
    @Test
    @Tag("invalid")
    public void tokenWithNoSubjectClaim() {
        String token = Jwts.builder()
                .setIssuedAt(new Date())
                .setExpiration(new Date(System.currentTimeMillis() + jwtExpirationMilliseg))
                .signWith(Keys.hmacShaKeyFor(jwtSecret.getBytes(StandardCharsets.UTF_8)))
                .compact();
        String username = jwtUtil.getUserName(token);
        assertNull(username);
    }
    @Test
    @Tag("invalid")
    public void tokenWithMalformedStructure() {
        String malformedToken = "malformed.token.structure";
        String username = jwtUtil.getUserName(malformedToken);
        assertNull(username);
    }
}