package com.medeiros.SPRINGProject.Security;import com.medeiros.SPRINGProject.Models.User_Credentials;
import io.jsonwebtoken.Claims;
import io.jsonwebtoken.Jwts;
import io.jsonwebtoken.security.Keys;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import org.springframework.security.core.Authentication;
import java.nio.charset.StandardCharsets;
import java.security.Key;
import java.util.Date;
import static org.junit.jupiter.api.Assertions.assertFalse;
import static org.junit.jupiter.api.Assertions.assertTrue;
import static org.mockito.Mockito.when;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;

public class JwtUtilIsValidTokenTest {
    private JwtUtil jwtUtil;
    private Authentication authentication;
    private User_Credentials user;
    @BeforeEach
    public void setUp() {
        jwtUtil = new JwtUtil();
        authentication = Mockito.mock(Authentication.class);
        user = new User_Credentials();
        user.setUsername("testuser");
        when(authentication.getPrincipal()).thenReturn(user);
    }
    @Test
    @Tag("valid")
    public void validTokenNonExpiredDate() {
        String token = jwtUtil.newToken(authentication);
        assertTrue(jwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void validTokenExpiredDate() {
        // TODO: Change the expiration time to a past date
        jwtUtil.jwtExpirationMilliseg = -100000L;
        String token = jwtUtil.newToken(authentication);
        assertFalse(jwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void invalidTokenFormat() {
        String token = "invalid.token.format";
        assertFalse(jwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void tokenWithNullClaims() {
        JwtUtil spyJwtUtil = Mockito.spy(jwtUtil);
        Mockito.doReturn(null).when(spyJwtUtil).getClaims(Mockito.anyString());
        String token = "dummy.token";
        assertFalse(spyJwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void tokenWithNullSubject() {
        JwtUtil spyJwtUtil = Mockito.spy(jwtUtil);
        Claims mockClaims = Mockito.mock(Claims.class);
        when(mockClaims.getSubject()).thenReturn(null);
        Mockito.doReturn(mockClaims).when(spyJwtUtil).getClaims(Mockito.anyString());
        String token = "dummy.token";
        assertFalse(spyJwtUtil.isValidToken(token));
    }
    @Test
    @Tag("valid")
    public void tokenWithFutureExpirationDate() {
        // TODO: Change the expiration time to a future date
        jwtUtil.jwtExpirationMilliseg = 1000000000L;
        String token = jwtUtil.newToken(authentication);
        assertTrue(jwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void tokenWithCurrentTimeExpirationDate() {
        jwtUtil.jwtExpirationMilliseg = 0L;
        String token = jwtUtil.newToken(authentication);
        assertFalse(jwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void tokenWithNullExpirationDate() {
        JwtUtil spyJwtUtil = Mockito.spy(jwtUtil);
        Claims mockClaims = Mockito.mock(Claims.class);
        when(mockClaims.getExpiration()).thenReturn(null);
        Mockito.doReturn(mockClaims).when(spyJwtUtil).getClaims(Mockito.anyString());
        String token = "dummy.token";
        assertFalse(spyJwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void tokenWithEmptyString() {
        String token = "";
        assertFalse(jwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void tokenWithSpecialCharacters() {
        String token = "!@#$%^&*()";
        assertFalse(jwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void tokenWithDifferentSecretKey() {
        // TODO: Change the secret key
        jwtUtil.jwtSecret = "differentsecretkey";
        String token = jwtUtil.newToken(authentication);
        assertFalse(jwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void tokenWithNoExpirationClaim() {
        JwtUtil spyJwtUtil = Mockito.spy(jwtUtil);
        Claims mockClaims = Mockito.mock(Claims.class);
        when(mockClaims.getExpiration()).thenReturn(null);
        Mockito.doReturn(mockClaims).when(spyJwtUtil).getClaims(Mockito.anyString());
        String token = "dummy.token";
        assertFalse(spyJwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void tokenWithNoSubjectClaim() {
        JwtUtil spyJwtUtil = Mockito.spy(jwtUtil);
        Claims mockClaims = Mockito.mock(Claims.class);
        when(mockClaims.getSubject()).thenReturn(null);
        Mockito.doReturn(mockClaims).when(spyJwtUtil).getClaims(Mockito.anyString());
        String token = "dummy.token";
        assertFalse(spyJwtUtil.isValidToken(token));
    }
