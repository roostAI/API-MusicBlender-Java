package com.medeiros.SPRINGProject.Security;import com.medeiros.SPRINGProject.Models.User_Credentials;
import io.jsonwebtoken.Claims;
import io.jsonwebtoken.Jwts;
import io.jsonwebtoken.security.Keys;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import org.springframework.security.core.Authentication;
import java.nio.charset.StandardCharsets;
import java.security.Key;
import java.util.Date;
import static org.junit.jupiter.api.Assertions.assertFalse;
import static org.junit.jupiter.api.Assertions.assertTrue;
import static org.mockito.Mockito.when;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;

public class JwtUtilIsValidTokenTest {
    private JwtUtil jwtUtil;
    private String jwtSecret = "mySecretKeymySecretKeymySecretKeymySecretKey"; // TODO: Change to actual secret key
    private long jwtExpirationMilliseg = 3600000L; // 1 hour
    @BeforeEach
    public void setUp() {
        jwtUtil = new JwtUtil();
        // Assuming there are setter methods or a constructor to set these values
        jwtUtil.setJwtSecret(jwtSecret);
        jwtUtil.setJwtExpirationMilliseg(jwtExpirationMilliseg);
    }
    @Test
    @Tag("valid")
    public void isValidTokenWithValidToken() {
        Authentication authentication = Mockito.mock(Authentication.class);
        User_Credentials user = new User_Credentials();
        user.setUsername("testUser");
        when(authentication.getPrincipal()).thenReturn(user);
        String token = jwtUtil.newToken(authentication);
        assertTrue(jwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void isValidTokenWithExpiredToken() {
        Authentication authentication = Mockito.mock(Authentication.class);
        User_Credentials user = new User_Credentials();
        user.setUsername("testUser");
        when(authentication.getPrincipal()).thenReturn(user);
        jwtUtil.setJwtExpirationMilliseg(1L); // Expire immediately
        String token = jwtUtil.newToken(authentication);
        try {
            Thread.sleep(10); // Ensure token is expired
        } catch (InterruptedException e) {
            e.printStackTrace();
        }
        assertFalse(jwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void isValidTokenWithMissingSubject() {
        String token = Jwts.builder()
                .setIssuedAt(new Date())
                .setExpiration(new Date(System.currentTimeMillis() + jwtExpirationMilliseg))
                .signWith(Keys.hmacShaKeyFor(jwtSecret.getBytes(StandardCharsets.UTF_8)))
                .compact();
        assertFalse(jwtUtil.isValidToken(token));
    }
    @Test
    @Tag("invalid")
    public void isValidTokenWithInvalidToken() {
        String invalidToken = "invalidTokenString";
        assertFalse(jwtUtil.isValidToken(invalidToken));
    }
    @Test
    @Tag("valid")
    public void isValidTokenWithFutureExpiration() {
        Authentication authentication = Mockito.mock(Authentication.class);
        User_Credentials user = new User_Credentials();
        user.setUsername("testUser");
        when(authentication.getPrincipal()).thenReturn(user);
        jwtUtil.setJwtExpirationMilliseg(1000000000L); // Far future expiration
        String token = jwtUtil.newToken(authentication);
        assertTrue(jwtUtil.isValidToken(token));
    }
}