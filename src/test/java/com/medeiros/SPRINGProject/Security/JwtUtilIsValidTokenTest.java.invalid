import io.jsonwebtoken.security.Keys;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import org.springframework.security.core.Authentication;
import java.nio.charset.StandardCharsets;
import java.security.Key;
import java.util.Date;
import static org.junit.jupiter.api.Assertions.assertTrue;
import static org.mockito.Mockito.when;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;

public class JwtUtilIsValidTokenTest {
    @Test
    @Tag("valid")
    public void testValidToken() {
        // Arrange
        String jwtSecret = "secret";
        long jwtExpirationMilliseg = 10000;
        String token = "token";
        String username = "username";
        Date expirationDate = new Date(System.currentTimeMillis() + jwtExpirationMilliseg);
        Key secretKey = Keys.hmacShaKeyFor(jwtSecret.getBytes(StandardCharsets.UTF_8));
        User_Credentials user = Mockito.mock(User_Credentials.class);
        when(user.getUsername()).thenReturn(username);
        Authentication authentication = Mockito.mock(Authentication.class);
        when(authentication.getPrincipal()).thenReturn(user);
        Claims claims = Jwts.claims().setSubject(username).setIssuedAt(new Date()).setExpiration(expirationDate);
        JwtUtil jwtUtil = Mockito.spy(new JwtUtil());
        when(jwtUtil.getClaims(token)).thenReturn(claims);
        // Act
        boolean isValid = jwtUtil.isValidToken(token);
        // Assert
        assertTrue(isValid);
    }
}