        Claims claims = mock(Claims.class);
        when(claims.getSubject()).thenReturn("user@example.com");
        when(claims.getExpiration()).thenReturn(new Date(System.currentTimeMillis()));
        JwtUtil spyJwtUtil = Mockito.spy(jwtUtil);
