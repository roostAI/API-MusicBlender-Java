package com.medeiros.SPRINGProject.Security;import com.medeiros.SPRINGProject.Models.User_Credentials;
import io.jsonwebtoken.Claims;
import io.jsonwebtoken.Jwts;
import io.jsonwebtoken.security.Keys;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.security.core.Authentication;
import org.springframework.stereotype.Component;
import java.nio.charset.StandardCharsets;
import java.security.Key;
import java.util.Date;

public class JwtUtilNewTokenTest {
    @Test
    @Tag("valid")
    public void newTokenWithValidAuthentication() {
        // Arrange
        Authentication authentication = Mockito.mock(Authentication.class);
        User_Credentials user = new User_Credentials();
        user.setUsername("testUser");
        Mockito.when(authentication.getPrincipal()).thenReturn(user);
        JwtUtil jwtUtil = new JwtUtil();
        jwtUtil.setJwtSecret("testSecret");
        jwtUtil.setJwtExpirationMilliseg(60000L);
        // Act
        String token = jwtUtil.newToken(authentication);
        // Assert
        assertNotNull(token);
        assertTrue(token instanceof String);
    }
    @Test
    @Tag("invalid")
    public void newTokenWithInvalidAuthentication() {
        // Arrange
        Authentication authentication = Mockito.mock(Authentication.class);
        Mockito.when(authentication.getPrincipal()).thenReturn(null);
        JwtUtil jwtUtil = new JwtUtil();
        jwtUtil.setJwtSecret("testSecret");
        jwtUtil.setJwtExpirationMilliseg(60000L);
        // Act
        String token = jwtUtil.newToken(authentication);
        // Assert
        assertNull(token);
    }
}