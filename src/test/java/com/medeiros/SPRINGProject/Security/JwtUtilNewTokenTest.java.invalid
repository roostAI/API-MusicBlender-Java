package com.medeiros.SPRINGProject.Security;
import com.medeiros.SPRINGProject.Models.User_Credentials;
import io.jsonwebtoken.Claims;
import io.jsonwebtoken.Jwts;
import io.jsonwebtoken.security.Keys;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.springframework.security.core.Authentication;
import java.nio.charset.StandardCharsets;
import java.security.Key;
import java.util.Date;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;

public class JwtUtilNewTokenTest {
    @Test
    @Tag("valid")
    public void testNewTokenGenerationWithValidAuthentication() {
        String jwtSecret = "secret";
        long jwtExpirationMilliseg = 86400000;
        User_Credentials user = new User_Credentials();
        user.setUsername("testUser");
        Authentication authentication = mock(Authentication.class);
        when(authentication.getPrincipal()).thenReturn(user);
        JwtUtil jwtUtil = new JwtUtil();
        String token = jwtUtil.newToken(authentication);
        Key secretKey = Keys.hmacShaKeyFor(jwtSecret.getBytes(StandardCharsets.UTF_8));
        Claims claims = Jwts.parserBuilder().setSigningKey(secretKey).build().parseClaimsJws(token).getBody();
        assertNotNull(token);
        assertEquals(user.getUsername(), claims.getSubject());
    }
    @Test
    @Tag("invalid")
    public void testNewTokenGenerationWithInvalidAuthentication() {
        String jwtSecret = "secret";
        long jwtExpirationMilliseg = 86400000;
        Authentication authentication = mock(Authentication.class);
        when(authentication.getPrincipal()).thenReturn(null);
        JwtUtil jwtUtil = new JwtUtil();
        String token = jwtUtil.newToken(authentication);
        assertNull(token);
    }
    @Test
    @Tag("boundary")
    public void testNewTokenGenerationWithNullJwtSecret() {
        String jwtSecret = null;
        long jwtExpirationMilliseg = 86400000;
        User_Credentials user = new User_Credentials();
        user.setUsername("testUser");
        Authentication authentication = mock(Authentication.class);
        when(authentication.getPrincipal()).thenReturn(user);
        JwtUtil jwtUtil = new JwtUtil();
        String token = jwtUtil.newToken(authentication);
        assertNull(token);
    }
    @Test
    @Tag("boundary")
    public void testNewTokenGenerationWithNullJwtExpirationMilliseg() {
        String jwtSecret = "secret";
        long jwtExpirationMilliseg = null;
        User_Credentials user = new User_Credentials();
        user.setUsername("testUser");
        Authentication authentication = mock(Authentication.class);
        when(authentication.getPrincipal()).thenReturn(user);
        JwtUtil jwtUtil = new JwtUtil();
        String token = jwtUtil.newToken(authentication);
        assertNull(token);
    }
}