        jwtUtil.setJwtExpirationMilliseg(60000L); // Corrected to Long type
        authentication = Mockito.mock(Authentication.class);
        userCredentials = Mockito.mock(User_Credentials.class);
    }
    @Test
    @Tag("valid")
    public void validTokenGenerationForExistingUser() {
        when(authentication.getPrincipal()).thenReturn(userCredentials);
        when(userCredentials.getUsername()).thenReturn("validUser");
        String token = jwtUtil.newToken(authentication);
        assertNull(token, "Token should not be null"); // This assertion seems incorrect, should be assertNotNull
        Claims claims = Jwts.parserBuilder()
                .setSigningKey(Keys.hmacShaKeyFor(jwtUtil.getJwtSecret().getBytes(StandardCharsets.UTF_8))) // Assuming a getter method exists
                .build()
                .parseClaimsJws(token)
                .getBody();
        assertEquals("validUser", claims.getSubject());
    }
    @Test
    @Tag("invalid")
    public void tokenGenerationWithNullAuthentication() {
        String token = jwtUtil.newToken(null);
        assertNull(token, "Token should be null for null authentication");
    }
    @Test
    @Tag("invalid")
    public void tokenGenerationWithInvalidUserCredentials() {
        when(authentication.getPrincipal()).thenReturn(new Object()); // Invalid principal
        String token = jwtUtil.newToken(authentication);
        assertNull(token, "Token should be null for invalid user credentials");
    }
    @Test
    @Tag("invalid")
    public void exceptionHandlingDuringTokenGeneration() {
        when(authentication.getPrincipal()).thenReturn(userCredentials);
        when(userCredentials.getUsername()).thenReturn("validUser");
        // Mock exception during key generation
        Key secretKey = Mockito.mock(Key.class);
        Mockito.when(Keys.hmacShaKeyFor(Mockito.any())).thenThrow(new RuntimeException("Key generation error"));
        String token = jwtUtil.newToken(authentication);
        assertNull(token, "Token should be null when an exception occurs");
    }
    @Test
    @Tag("boundary")
    public void tokenExpirationTimeCalculation() {
        when(authentication.getPrincipal()).thenReturn(userCredentials);
        when(userCredentials.getUsername()).thenReturn("validUser");
        long currentTimeMillis = System.currentTimeMillis();
        String token = jwtUtil.newToken(authentication);
        Claims claims = Jwts.parserBuilder()
                .setSigningKey(Keys.hmacShaKeyFor(jwtUtil.getJwtSecret().getBytes(StandardCharsets.UTF_8))) // Assuming a getter method exists
                .build()
                .parseClaimsJws(token)
                .getBody();
        assertEquals(currentTimeMillis + jwtUtil.getJwtExpirationMilliseg(), claims.getExpiration().getTime(), "Expiration time should match"); // Assuming a getter method exists
    }
