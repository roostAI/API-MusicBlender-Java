package com.medeiros.SPRINGProject.algorithm;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import java.util.Arrays;
import java.util.HashMap;
import java.util.Map;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.Mockito.when;
import org.junit.jupiter.api.*;
import com.medeiros.SPRINGProject.Models.MusicModel;
import com.medeiros.SPRINGProject.utils.hashMapFunctions;

public class AlgorithmBlenderAlgorithmCalcTest {
    @Mock
    private AlgorithmBlender AD;
    private AlgorithmBlenderAlgorithmCalc algorithmBlenderAlgorithmCalc;
    @BeforeEach
    public void setup() {
        MockitoAnnotations.initMocks(this);
        algorithmBlenderAlgorithmCalc = new AlgorithmBlenderAlgorithmCalc();
    }
    @Test
    public void testAlgorithmCalc() {
        MusicModel music1 = new MusicModel("Song1", 10, 20);
        MusicModel music2 = new MusicModel("Song2", 30, 40);
        Iterable<MusicModel> listMusics = Arrays.asList(music1, music2);
        when(AD.rithmPointsByLike(music1.getNumberOfLikes())).thenReturn(100);
        when(AD.rithmPointsByLike(music2.getNumberOfLikes())).thenReturn(300);
        when(AD.rithmPointsByComents(music1.getNumberOfComents())).thenReturn(200);
        when(AD.rithmPointsByComents(music2.getNumberOfComents())).thenReturn(400);
        Map<String, Integer> expected = new HashMap<>();
        expected.put(music1.getMusicName(), 300);
        expected.put(music2.getMusicName(), 700);
        Map<String, Integer> actual = algorithmBlenderAlgorithmCalc.algorithmCalc(listMusics);
        assertEquals(expected, actual);
    }
    @Test
    public void testAlgorithmCalcWithEmptyList() {
        Iterable<MusicModel> listMusics = Arrays.asList();
        Map<String, Integer> expected = new HashMap<>();
        Map<String, Integer> actual = algorithmBlenderAlgorithmCalc.algorithmCalc(listMusics);
        assertEquals(expected, actual);
    }
}