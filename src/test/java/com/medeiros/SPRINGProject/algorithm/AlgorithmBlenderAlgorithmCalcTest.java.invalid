package com.medeiros.SPRINGProject.algorithm;import com.medeiros.SPRINGProject.Models.MusicModel;
import com.medeiros.SPRINGProject.utils.hashMapFunctions;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.BeforeEach;
import org.mockito.Mockito;
import java.util.Arrays;
import java.util.HashMap;
import java.util.Map;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertThrows;
import org.junit.jupiter.api.*;

public class AlgorithmBlenderAlgorithmCalcTest {
    private algorithmBlender algorithmBlender;
    private algorithmData AD;
    @BeforeEach
    public void setup() {
        AD = Mockito.mock(algorithmData.class);
        algorithmBlender = new algorithmBlender();
        algorithmBlender.setAD(AD);
    }
    @Test
    @Tag("valid")
    public void testAlgorithmCalcWithValidList() {
        MusicModel music1 = new MusicModel(1, 1, "Song1", "Music1", "Description1", 10, 5, 0);
        MusicModel music2 = new MusicModel(2, 2, "Song2", "Music2", "Description2", 20, 10, 0);
        Iterable<MusicModel> listMusics = Arrays.asList(music1, music2);
        Mockito.when(AD.rithmPointsByLike(10)).thenReturn(50);
        Mockito.when(AD.rithmPointsByLike(20)).thenReturn(100);
        Mockito.when(AD.rithmPointsByComents(5)).thenReturn(25);
        Mockito.when(AD.rithmPointsByComents(10)).thenReturn(50);
        Map<String, Integer> expected = new HashMap<>();
        expected.put("Song1", 75);
        expected.put("Song2", 150);
        Map<String, Integer> actual = algorithmBlender.algorithmCalc(listMusics);
        assertEquals(expected, actual);
    }
    @Test
    @Tag("boundary")
    public void testAlgorithmCalcWithEmptyList() {
        Iterable<MusicModel> listMusics = Arrays.asList();
        Map<String, Integer> expected = new HashMap<>();
        Map<String, Integer> actual = algorithmBlender.algorithmCalc(listMusics);
        assertEquals(expected, actual);
    }
    @Test
    @Tag("invalid")
    public void testAlgorithmCalcWithNullValues() {
        Iterable<MusicModel> listMusics = Arrays.asList(null, null);
        assertThrows(NullPointerException.class, () -> {
            algorithmBlender.algorithmCalc(listMusics);
        });
    }
}