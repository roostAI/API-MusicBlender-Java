package com.medeiros.SPRINGProject.algorithm;import com.medeiros.SPRINGProject.Models.MusicModel;
import com.medeiros.SPRINGProject.utils.hashMapFunctions;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import java.util.*;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.when;
import org.junit.jupiter.api.*;
import java.util.HashMap;
import java.util.Map;

public class AlgorithmBlenderAlgorithmCalcTest extends algorithmData {
    @Mock
    private algorithmData AD;
    @InjectMocks
    private algorithmBlender algorithmBlender;
    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void testNormalOperationWithMultipleMusicModels() {
        List<MusicModel> musicModels = Arrays.asList(
                new MusicModel(1, 1, "Music1", "Music", "Description", 10, 5, 0, 0),
                new MusicModel(2, 2, "Music2", "Music", "Description", 20, 10, 0, 0),
                new MusicModel(3, 3, "Music3", "Music", "Description", 30, 15, 0, 0)
        );
        when(AD.rithmPointsByLike(10)).thenReturn(100);
        when(AD.rithmPointsByComents(5)).thenReturn(50);
        when(AD.rithmPointsByLike(20)).thenReturn(200);
        when(AD.rithmPointsByComents(10)).thenReturn(100);
        when(AD.rithmPointsByLike(30)).thenReturn(300);
        when(AD.rithmPointsByComents(15)).thenReturn(150);
        Map<String, Integer> result = algorithmBlender.algorithmCalc(musicModels);
        assertEquals(150, result.get("Music1").intValue());
        assertEquals(300, result.get("Music2").intValue());
        assertEquals(450, result.get("Music3").intValue());
    }
    @Test
    @Tag("valid")
    public void testEmptyListOfMusicModels() {
        List<MusicModel> musicModels = new ArrayList<>();
        Map<String, Integer> result = algorithmBlender.algorithmCalc(musicModels);
        assertTrue(result.isEmpty());
    }
    @Test
    @Tag("valid")
    public void testSingleMusicModelWithZeroLikesAndComments() {
        List<MusicModel> musicModels = Collections.singletonList(
                new MusicModel(1, 1, "Music1", "Music", "Description", 0, 0, 0, 0)
        );
        when(AD.rithmPointsByLike(0)).thenReturn(0);
        when(AD.rithmPointsByComents(0)).thenReturn(0);
        Map<String, Integer> result = algorithmBlender.algorithmCalc(musicModels);
        assertEquals(0, result.get("Music1").intValue());
    }
    @Test
    @Tag("valid")
    public void testSingleMusicModelWithMaximumLikesAndComments() {
        List<MusicModel> musicModels = Collections.singletonList(
                new MusicModel(1, 1, "Music1", "Music", "Description", Integer.MAX_VALUE, Integer.MAX_VALUE, 0, 0)
        );
        when(AD.rithmPointsByLike(Integer.MAX_VALUE)).thenReturn(Integer.MAX_VALUE);
        when(AD.rithmPointsByComents(Integer.MAX_VALUE)).thenReturn(Integer.MAX_VALUE);
        Map<String, Integer> result = algorithmBlender.algorithmCalc(musicModels);
        assertEquals(Integer.MAX_VALUE * 2, result.get("Music1").intValue());
    }
    @Test
    @Tag("invalid")
    public void testMusicModelsWithNegativeLikesAndComments() {
        List<MusicModel> musicModels = Arrays.asList(
                new MusicModel(1, 1, "Music1", "Music", "Description", -10, -5, 0, 0),
                new MusicModel(2, 2, "Music2", "Music", "Description", -20, -10, 0, 0)
        );
        when(AD.rithmPointsByLike(-10)).thenReturn(-100);
        when(AD.rithmPointsByComents(-5)).thenReturn(-50);
        when(AD.rithmPointsByLike(-20)).thenReturn(-200);
        when(AD.rithmPointsByComents(-10)).thenReturn(-100);
        Map<String, Integer> result = algorithmBlender.algorithmCalc(musicModels);
        assertEquals(-150, result.get("Music1").intValue());
        assertEquals(-300, result.get("Music2").intValue());
    }
    @Test
    @Tag("valid")
    public void testMusicModelsWithMixedPositiveAndNegativeLikesAndComments() {
        List<MusicModel> musicModels = Arrays.asList(
                new MusicModel(1, 1, "Music1", "Music", "Description", 10, -5, 0, 0),
                new MusicModel(2, 2, "Music2", "Music", "Description", -20, 10, 0, 0)
        );
        when(AD.rithmPointsByLike(10)).thenReturn(100);
        when(AD.rithmPointsByComents(-5)).thenReturn(-50);
        when(AD.rithmPointsByLike(-20)).thenReturn(-200);
        when(AD.rithmPointsByComents(10)).thenReturn(100);
        Map<String, Integer> result = algorithmBlender.algorithmCalc(musicModels);
        assertEquals(50, result.get("Music1").intValue());
        assertEquals(-100, result.get("Music2").intValue());
    }
    @Test
    @Tag("invalid")
    public void testNullListOfMusicModels() {
        Map<String, Integer> result = algorithmBlender.algorithmCalc(null);
        assertTrue(result.isEmpty());
    }
    @Test
    @Tag("valid")
    public void testMusicModelsWithDuplicateNames() {
        List<MusicModel> musicModels = Arrays.asList(
                new MusicModel(1, 1, "Music1", "Music", "Description", 10, 5, 0, 0),
                new MusicModel(2, 2, "Music1", "Music", "Description", 20, 10, 0, 0)
        );
        when(AD.rithmPointsByLike(10)).thenReturn(100);
        when(AD.rithmPointsByComents(5)).thenReturn(50);
        when(AD.rithmPointsByLike(20)).thenReturn(200);
        when(AD.rithmPointsByComents(10)).thenReturn(100);
        Map<String, Integer> result = algorithmBlender.algorithmCalc(musicModels);
        assertEquals(300, result.get("Music1").intValue());
    }
    @Test
    @Tag("valid")
    public void testMusicModelsWithSpecialCharactersInNames() {
        List<MusicModel> musicModels = Arrays.asList(
                new MusicModel(1, 1, "Music@1", "Music", "Description", 10, 5, 0, 0),
                new MusicModel(2, 2, "Music#2", "Music", "Description", 20, 10, 0, 0)
        );
        when(AD.rithmPointsByLike(10)).thenReturn(100);
        when(AD.rithmPointsByComents(5)).thenReturn(50);
        when(AD.rithmPointsByLike(20)).thenReturn(200);
        when(AD.rithmPointsByComents(10)).thenReturn(100);
        Map<String, Integer> result = algorithmBlender.algorithmCalc(musicModels);
        assertEquals(150, result.get("Music@1").intValue());
        assertEquals(300, result.get("Music#2").intValue());
    }
    @Test
    @Tag("valid")
    public void testLargeNumberOfMusicModels() {
        List<MusicModel> musicModels = new ArrayList<>();
        for (int i = 0; i < 10000; i++) {
            musicModels.add(new MusicModel(i, i, "Music" + i, "Music", "Description", i, i, 0, 0));
            when(AD.rithmPointsByLike(i)).thenReturn(i * 10);
            when(AD.rithmPointsByComents(i)).thenReturn(i * 5);
        }
        Map<String, Integer> result = algorithmBlender.algorithmCalc(musicModels);
        for (int i = 0; i < 10000; i++) {
            assertEquals((i * 10) + (i * 5), result.get("Music" + i).intValue());
        }
    }
}