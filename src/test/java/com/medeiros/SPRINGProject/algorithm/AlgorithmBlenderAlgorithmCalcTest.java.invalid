        Mockito.when(musicModel.getNumberOfComents()).thenReturn(5);
        Mockito.when(musicModel.getMusicName()).thenReturn("Test Song");
        Mockito.when(getRithmPointsByLike(10)).thenReturn(20);
        Mockito.when(getRithmPointsByComents(5)).thenReturn(15);
        List<MusicModel> musicList = new ArrayList<>();
        musicList.add(musicModel);
        // Act
        Map<String, Integer> result = algorithmBlender.algorithmCalc(musicList);
        // Assert
        assertEquals(35, (int) result.get("Test Song"));
    }
