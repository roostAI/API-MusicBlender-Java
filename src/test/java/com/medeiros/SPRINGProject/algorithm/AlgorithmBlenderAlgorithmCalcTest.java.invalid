        Mockito.when(musicModel2.getMusicName()).thenReturn("Song B");
        Mockito.when(getRithmPointsByLike(7)).thenReturn(14);
        Mockito.when(getRithmPointsByComents(2)).thenReturn(6);
        List<MusicModel> musicList = new ArrayList<>();
        musicList.add(musicModel1);
        musicList.add(musicModel2);
        // Act
        Map<String, Integer> result = algorithmBlender.algorithmCalc(musicList);
        // Assert
        assertEquals(19, (int) result.get("Song A"));
        assertEquals(20, (int) result.get("Song B"));
    }
