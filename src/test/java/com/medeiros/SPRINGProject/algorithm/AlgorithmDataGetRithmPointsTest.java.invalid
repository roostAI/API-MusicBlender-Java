package com.medeiros.SPRINGProject.algorithm;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;

public class AlgorithmDataGetRithmPointsTest {
    @Test
    @Tag("valid")
    public void testDefaultRithmPointsValue() {
        AlgorithmData data = new AlgorithmData();
        int expected = 0;
        int actual = data.getRithmPoints();
        assertEquals(expected, actual);
    }
    @Test
    @Tag("valid")
    public void testRithmPointsAfterSettingValue() {
        AlgorithmData data = new AlgorithmData();
        int expected = 100;
        data.setRithmPoints(expected);
        int actual = data.getRithmPoints();
        assertEquals(expected, actual);
    }
    @Test
    @Tag("valid")
    public void testRithmPointsWhenUserIsBlocked() {
        AlgorithmData data = new AlgorithmData();
        data.setRithmPoints(100);
        data.setBlocked(true);
        int expected = 0;
        int actual = data.getRithmPoints();
        assertEquals(expected, actual);
    }
}