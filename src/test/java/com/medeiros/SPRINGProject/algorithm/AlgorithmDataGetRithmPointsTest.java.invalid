package com.medeiros.SPRINGProject.algorithm;import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;

public class AlgorithmDataGetRithmPointsTest {
    @Test
    @Tag("valid")
    public void testGetRithmPoints() {
        AlgorithmData algorithmData = new AlgorithmData();
        algorithmData.setRithmPoints(100);
        int result = algorithmData.getRithmPoints();
        assertEquals(100, result);
    }
    @Test
    @Tag("boundary")
    public void testGetRithmPointsWithoutSettingValue() {
        AlgorithmData algorithmData = new AlgorithmData();
        int result = algorithmData.getRithmPoints();
        assertEquals(0, result);
    }
    @Test
    @Tag("valid")
    public void testGetRithmPointsAfterUpdatingValue() {
        AlgorithmData algorithmData = new AlgorithmData();
        algorithmData.setRithmPoints(100);
        algorithmData.setRithmPoints(200);
        int result = algorithmData.getRithmPoints();
        assertEquals(200, result);
    }
}