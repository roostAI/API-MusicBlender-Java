import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

 // Assuming that AlgorithmData class AlgorithmDataIsBlackListTest in this package
 class AlgorithmDataIsBlackListTest {
    @Test
    @Tag("valid")
    public void testIsUserBlacklisted() {
        AlgorithmData algorithmData = new AlgorithmData();
        algorithmData.setBlack_list(true);
        assertTrue(algorithmData.isBlack_list(), "Expected black_list status to be true");
    }
    @Test
    @Tag("valid")
    public void testIsUserNotBlacklisted() {
        AlgorithmData algorithmData = new AlgorithmData();
        algorithmData.setBlack_list(false);
        assertFalse(algorithmData.isBlack_list(), "Expected black_list status to be false");
    }
    @Test
