package com.medeiros.SPRINGProject.algorithm;import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

// Import the AlgorithmData AlgorithmDataIsBlackListTest com.medeiros.SPRINGProject.algorithm.AlgorithmData;
 AlgorithmDataIsBlackListTest {
    @Test
    @Tag("valid")
    public void testDefaultBlackListValue() {
        AlgorithmData algorithmData = new AlgorithmData();
        assertFalse(algorithmData.isBlack_list(), "Default value of black_list should be false");
    }
    @Test
    @Tag("valid")
    public void testChangeBlackListValue() {
        AlgorithmData algorithmData = new AlgorithmData();
        algorithmData.setBlack_list(true);
        assertTrue(algorithmData.isBlack_list(), "Value of black_list should be true after being set to true");
    }
}