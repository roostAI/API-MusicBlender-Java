package com.medeiros.SPRINGProject.algorithm;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;

public class AlgorithmDataIsBlackListTest {
    @Test
    @Tag("valid")
    public void testIsBlackListWhenSetTrue() {
        AlgorithmData algorithmData = new AlgorithmData();
        algorithmData.setBlack_list(true);
        assertTrue(algorithmData.isBlack_list(), "Expected true but returned false");
    }
    @Test
    @Tag("valid")
    public void testIsBlackListWhenSetFalse() {
        AlgorithmData algorithmData = new AlgorithmData();
        algorithmData.setBlack_list(false);
        assertFalse(algorithmData.isBlack_list(), "Expected false but returned true");
    }
    @Test
    @Tag("boundary")
    public void testIsBlackListDefaultValue() {
        AlgorithmData algorithmData = new AlgorithmData();
        assertFalse(algorithmData.isBlack_list(), "Expected false but returned true");
    }
}