package com.medeiros.SPRINGProject.algorithm;
import org.junit.jupiter.api.Assertions;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.*;

public class AlgorithmDataIsBlockedTest {
    private AlgorithmData algorithmData;
    @BeforeEach
    public void setUp() {
        algorithmData = new AlgorithmData();
    }
    @Test
    @Tag("valid")
    public void testDefaultStateOfBlocked() {
        Assertions.assertEquals(false, algorithmData.isBlocked(),
                "Default state of 'blocked' should be false");
    }
    @Test
    @Tag("valid")
    public void testSetBlockedToTrue() {
        algorithmData.setBlocked(true);
        Assertions.assertEquals(true, algorithmData.isBlocked(),
                "'blocked' should be true after being set to true");
    }
    @Test
    @Tag("valid")
    public void testBlockedRemainsTrue() {
        algorithmData.setBlocked(true);
        Assertions.assertEquals(true, algorithmData.isBlocked(),
                "'blocked' should be true after being set to true");
        Assertions.assertEquals(true, algorithmData.isBlocked(),
                "'blocked' should remain true after being set to true");
    }
}