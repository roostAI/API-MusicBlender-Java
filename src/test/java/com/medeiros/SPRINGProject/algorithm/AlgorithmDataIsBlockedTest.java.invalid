package com.medeiros.SPRINGProject.algorithm;import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.*;

public class AlgorithmDataIsBlockedTest {
    private AlgorithmData algorithmData;
    @BeforeEach
    public void setUp() {
        algorithmData = new AlgorithmData();
    }
    @Test
    @Tag("valid")
    public void isBlockedReturnsTrueWhenBlockedIsTrue() {
        algorithmData.setBlocked(true);
        assertTrue(algorithmData.isBlocked());
    }
    @Test
    @Tag("valid")
    public void isBlockedReturnsFalseWhenBlockedIsFalse() {
        algorithmData.setBlocked(false);
        assertFalse(algorithmData.isBlocked());
    }
    @Test
    @Tag("valid")
    public void isBlockedReturnsFalseWhenBlockedIsNotSet() {
        assertFalse(algorithmData.isBlocked());
    }
    @Test
    @Tag("valid")
    public void isBlockedReturnsTrueAfterMultipleSetsToTrue() {
        algorithmData.setBlocked(true);
        assertTrue(algorithmData.isBlocked());
        algorithmData.setBlocked(true);
        assertTrue(algorithmData.isBlocked());
    }
    @Test
    @Tag("valid")
    public void isBlockedReturnsFalseAfterMultipleSetsToFalse() {
        algorithmData.setBlocked(false);
        assertFalse(algorithmData.isBlocked());
        algorithmData.setBlocked(false);
        assertFalse(algorithmData.isBlocked());
    }
    @Test
    @Tag("valid")
    public void isBlockedReturnsFalseWhenBlackListIsTrue() {
        algorithmData.setBlack_list(true);
        assertFalse(algorithmData.isBlocked());
    }
    @Test
    @Tag("valid")
    public void isBlockedReturnsFalseWhenRithmPointsIsZero() {
        algorithmData.setRithmPoints(0);
        assertFalse(algorithmData.isBlocked());
    }
    @Test
    @Tag("valid")
    public void isBlockedReturnsFalseWhenRithmPointsIsNegative() {
        algorithmData.setRithmPoints(-1);
        assertFalse(algorithmData.isBlocked());
    }
}