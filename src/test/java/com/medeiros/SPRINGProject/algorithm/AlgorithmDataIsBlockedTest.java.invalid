package com.medeiros.SPRINGProject.algorithm;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;

public class AlgorithmDataIsBlockedTest {
    @Test
    @Tag("valid")
    public void testIsUserBlocked() {
        AlgorithmData algorithmData = new AlgorithmData();
        algorithmData.setBlocked(true);
        assertTrue(algorithmData.isBlocked());
    }
    @Test
    @Tag("valid")
    public void testIsUserNotBlocked() {
        AlgorithmData algorithmData = new AlgorithmData();
        algorithmData.setBlocked(false);
        assertFalse(algorithmData.isBlocked());
    }
    @Test
    @Tag("boundary")
    public void testDefaultBlockedStatus() {
        AlgorithmData algorithmData = new AlgorithmData();
        assertFalse(algorithmData.isBlocked());
    }
}