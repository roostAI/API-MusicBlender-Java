package com.medeiros.SPRINGProject.algorithm;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;

public class AlgorithmDataRithmPointsByComentsTest {
    @Test
    @Tag("valid")
    public void rithmPointsByComentsBasicTest() {
        AlgorithmData algorithmData = new AlgorithmData();
        int coments = 5;
        int expectedPoints = coments * 15;
        assertEquals(expectedPoints, algorithmData.rithmPointsByComents(coments));
    }
    @Test
    @Tag("boundary")
    public void rithmPointsByComentsZeroTest() {
        AlgorithmData algorithmData = new AlgorithmData();
        int coments = 0;
        int expectedPoints = 0;
        assertEquals(expectedPoints, algorithmData.rithmPointsByComents(coments));
    }
    @Test
    @Tag("invalid")
    public void rithmPointsByComentsNegativeTest() {
        AlgorithmData algorithmData = new AlgorithmData();
        int coments = -5;
        assertThrows(IllegalArgumentException.class, () -> algorithmData.rithmPointsByComents(coments));
    }
    @Test
    @Tag("invalid")
    public void rithmPointsByComentsBlockedTest() {
        AlgorithmData algorithmData = new AlgorithmData();
        algorithmData.setBlocked(true);
        int coments = 5;
        assertThrows(IllegalStateException.class, () -> algorithmData.rithmPointsByComents(coments));
    }
}