package com.medeiros.SPRINGProject.algorithm;import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;

public class AlgorithmDataRithmPointsByLikeTest {
    private final AlgorithmData algorithmData = new AlgorithmData(); // Ensure AlgorithmData class is defined
    @Test
    @Tag("boundary")
    public void rithmPointsByLike_zeroLikes() {
        int likes = 0;
        int expected = 0;
        int actual = algorithmData.rithmPointsByLike(likes);
        assertEquals((Integer) expected, (Integer) actual);
    }
    @Test
    @Tag("valid")
    public void rithmPointsByLike_positiveLikes() {
        int likes = 5;
        int expected = 50;
        int actual = algorithmData.rithmPointsByLike(likes);
        assertEquals((Integer) expected, (Integer) actual);
    }
    @Test
    @Tag("invalid")
    public void rithmPointsByLike_negativeLikes() {
        int likes = -3;
        int expected = -30;
        int actual = algorithmData.rithmPointsByLike(likes);
        assertEquals((Integer) expected, (Integer) actual);
    }
    @Test
    @Tag("valid")
    public void rithmPointsByLike_largeLikes() {
        int likes = 1000000;
        int expected = 10000000;
        int actual = algorithmData.rithmPointsByLike(likes);
        assertEquals((Integer) expected, (Integer) actual);
    }
    @Test
    @Tag("boundary")
    public void rithmPointsByLike_maxIntegerLikes() {
        int likes = Integer.MAX_VALUE;
        long expected = (long) Integer.MAX_VALUE * 10;
        long actual = (long) algorithmData.rithmPointsByLike(likes);
        assertEquals(expected, actual);
    }
    @Test
    @Tag("valid")
    public void rithmPointsByLike_stateUnchanged() {
        algorithmData.setRithmPoints(0);
        algorithmData.setBlack_list(false);
        algorithmData.setBlocked(false);
        
        int likes = 10;
        algorithmData.rithmPointsByLike(likes);
        
        assertEquals((Integer) 0, (Integer) algorithmData.getRithmPoints());
        assertEquals((Boolean) false, (Boolean) algorithmData.isBlack_list());
        assertEquals((Boolean) false, (Boolean) algorithmData.isBlocked());
    }
}