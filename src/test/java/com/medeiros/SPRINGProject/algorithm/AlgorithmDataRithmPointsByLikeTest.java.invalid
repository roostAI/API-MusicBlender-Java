package com.medeiros.SPRINGProject.algorithm;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.junit.jupiter.api.*;

public class AlgorithmDataRithmPointsByLikeTest {
    @Test
    @Tag("valid")
    public void testRithmPointsByLikeCalculation() {
        // Arrange
        AlgorithmData algorithmData = new AlgorithmData();
        int likes = 5;
        // Act
        int actualRithmPoints = algorithmData.rithmPointsByLike(likes);
        // Assert
        int expectedRithmPoints = likes * 10;
        assertEquals(expectedRithmPoints, actualRithmPoints);
    }
    @Test
    @Tag("boundary")
    public void testRithmPointsByLikeWithNegativeLikes() {
        // Arrange
        AlgorithmData algorithmData = new AlgorithmData();
        int likes = -5;
        // Act
        int actualRithmPoints = algorithmData.rithmPointsByLike(likes);
        // Assert
        int expectedRithmPoints = likes * 10;
        assertEquals(expectedRithmPoints, actualRithmPoints);
    }
    @Test
    @Tag("boundary")
    public void testRithmPointsByLikeWithZeroLikes() {
        // Arrange
        AlgorithmData algorithmData = new AlgorithmData();
        int likes = 0;
        // Act
        int actualRithmPoints = algorithmData.rithmPointsByLike(likes);
        // Assert
        int expectedRithmPoints = 0;
        assertEquals(expectedRithmPoints, actualRithmPoints);
    }
}