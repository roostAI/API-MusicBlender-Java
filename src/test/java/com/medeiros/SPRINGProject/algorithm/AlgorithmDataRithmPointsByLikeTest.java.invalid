        int likes = 0;
        int expectedRithmPoints = likes * 10;
        assertEquals(expectedRithmPoints, algorithmData.rithmPointsByLike(likes));
    }
    @Test
    @Tag("valid")
    public void testRithmPointsByPositiveLikes() {
        AlgorithmData algorithmData = new AlgorithmData();
        int likes = 5;
        int expectedRithmPoints = likes * 10;
        assertEquals(expectedRithmPoints, algorithmData.rithmPointsByLike(likes));
    }
