    when(AD.rithmPointsByLike(0)).thenReturn(0);
    when(AD.rithmPointsByComents(0)).thenReturn(0);
    Map<String, Integer> result = algorithmBlender.algorithmCalc(musicModels);
    assertEquals(1, result.size());
    assertEquals(0, result.get("Song1"));
}

