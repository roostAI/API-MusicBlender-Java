/*ROOST_METHOD_HASH=algorithmCalc_e489e5c1fc
ROOST_METHOD_SIG_HASH=algorithmCalc_009085eae1

*/
@Test
@Tag("valid")
void normalOperationWithMultipleMusicModels() {
    List<MusicModel> musicModels = Arrays.asList(new MusicModel("Song1", 10, 5), new MusicModel("Song2", 20, 10), new MusicModel("Song3", 30, 15));
    when(AD.rithmPointsByLike(10)).thenReturn(100);
    when(AD.rithmPointsByComents(5)).thenReturn(50);
    when(AD.rithmPointsByLike(20)).thenReturn(200);
    when(AD.rithmPointsByComents(10)).thenReturn(100);
    when(AD.rithmPointsByLike(30)).thenReturn(300);
    when(AD.rithmPointsByComents(15)).thenReturn(150);
    Map<String, Integer> result = algorithmBlender.algorithmCalc(musicModels);
    assertEquals(3, result.size());
    assertEquals(150, result.get("Song1"));
    assertEquals(300, result.get("Song2"));
    assertEquals(450, result.get("Song3"));
}

/*ROOST_METHOD_HASH=algorithmCalc_e489e5c1fc
