    @Test
    @Tag("integration")
    public void testSortLargeHashMap() {
        // Arrange
        HashMap<String, Integer> input = new LinkedHashMap<>();
        int count = 1000; // TODO: Increase/decrease for larger tests
        for (int i = 0; i < count; i++) {
            input.put("key" + i, (int)(Math.random() * 100000));
        }
        // Act
        HashMap<String, Integer> result = HashMapFunctions.ordenarHashMapPorValor(input);
        // Assert
        Integer previous = null;
        int checked = 0;
        for (Integer value : result.values()) {
            if (previous != null) {
                assertTrue(previous >= value);
            }
            previous = value;
            checked++;
        }
        assertEquals(count, checked);
    }
