    @Test
    @Tag("valid")
    public void testOriginalHashMapImmutability() {
        // Arrange
        LinkedHashMap<String, Integer> original = new LinkedHashMap<>();
        original.put("f", 3);
        original.put("g", 2);
        original.put("h", 1);
        LinkedHashMap<String, Integer> originalCopy = new LinkedHashMap<>(original);
        // Act
        HashMapFunctions.ordenarHashMapPorValor(original);
        // Assert
        assertEquals(originalCopy, original);
        Iterator<String> origIter = original.keySet().iterator();
        Iterator<String> copyIter = originalCopy.keySet().iterator();
        while (origIter.hasNext() && copyIter.hasNext()) {
            String origKey = origIter.next();
            String copyKey = copyIter.next();
            assertEquals(copyKey, origKey);
        }
        assertEquals(originalCopy.size(), original.size());
    }
