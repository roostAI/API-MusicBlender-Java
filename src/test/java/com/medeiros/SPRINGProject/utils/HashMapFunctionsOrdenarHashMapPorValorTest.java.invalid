package com.medeiros.SPRINGProject.utils;import org.junit.jupiter.api.*;
import java.util.*;
import static org.junit.jupiter.api.Assertions.*;

class HashMapFunctionsOrdenarHashMapPorValorTest {
    @Test
    @Tag("valid")
    public void testSortHashMapWithDistinctValuesDescending() {
        // Arrange
        HashMap<String, Integer> input = new HashMap<>();
        input.put("a", 10);
        input.put("b", 30);
        input.put("c", 20);
        input.put("d", 40);
        // Act
        HashMap<String, Integer> result = HashMapFunctions.ordenarHashMapPorValor(input);
        // Assert
        Iterator<Map.Entry<String, Integer>> iterator = result.entrySet().iterator();
        Map.Entry<String, Integer> entry1 = iterator.next();
        assertEquals("d", entry1.getKey());
        assertEquals(Integer.valueOf(40), entry1.getValue());
        Map.Entry<String, Integer> entry2 = iterator.next();
        assertEquals("b", entry2.getKey());
        assertEquals(Integer.valueOf(30), entry2.getValue());
        Map.Entry<String, Integer> entry3 = iterator.next();
        assertEquals("c", entry3.getKey());
        assertEquals(Integer.valueOf(20), entry3.getValue());
        Map.Entry<String, Integer> entry4 = iterator.next();
        assertEquals("a", entry4.getKey());
        assertEquals(Integer.valueOf(10), entry4.getValue());
        assertFalse(iterator.hasNext());
    }
